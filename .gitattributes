# Ensure shell scripts always have LF line endings
*.sh text eol=lf
hooks/session-start text eol=lf

# Ensure the polyglot wrapper keeps LF (it's parsed by both cmd and bash)
*.cmd text eol=lf

# Common text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf

# pi-superpowers fork: always use ours for these files on merge
README.md merge=ours
skills/using-git-worktrees/SKILL.md merge=ours

# Explicitly mark binary files
*.png binary
*.jpg binary
*.gif binary
