#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

find_runtime_bin() {
  local candidate

  if [[ -n "${SUPERPOWERS_COMPAT_BIN:-}" ]]; then
    printf '%s\n' "$SUPERPOWERS_COMPAT_BIN"
    return 0
  fi

  for candidate in \
    "$RUNTIME_ROOT/bin/superpowers" \
    "$RUNTIME_ROOT/bin/superpowers.exe" \
    "$RUNTIME_ROOT/target/debug/superpowers" \
    "$RUNTIME_ROOT/target/debug/superpowers.exe" \
    "$HOME/.superpowers/install/bin/superpowers" \
    "$HOME/.superpowers/install/bin/superpowers.exe"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

if runtime_bin="$(find_runtime_bin)"; then
  exec "$runtime_bin" "$@"
fi

if [[ -f "$RUNTIME_ROOT/Cargo.toml" ]] && command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$RUNTIME_ROOT/Cargo.toml" --bin superpowers -- "$@"
fi

printf 'Superpowers runtime binary not found. Expected bin/superpowers, target/debug/superpowers, or SUPERPOWERS_COMPAT_BIN.\n' >&2
exit 127
