digraph STYLE_GUIDE {
    // 我们流程DSL的样式指南，使用DSL本身编写

    // 节点类型示例及其形状
    subgraph cluster_node_types {
        label="节点类型和形状";

        // 问题是菱形
        "这是一个问题吗？" [shape=diamond];

        // 动作是方框（默认）
        "执行一个动作" [shape=box];

        // 命令是纯文本
        "git commit -m 'msg'" [shape=plaintext];

        // 状态是椭圆形
        "当前状态" [shape=ellipse];

        // 警告是八边形
        "停止：严重警告" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        // 入口/出口是双圆
        "流程开始" [shape=doublecircle];
        "流程完成" [shape=doublecircle];

        // 各类型的示例
        "测试通过了吗？" [shape=diamond];
        "先编写测试" [shape=box];
        "npm test" [shape=plaintext];
        "我被卡住了" [shape=ellipse];
        "绝对不要使用 git add -A" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
    }

    // 边的命名约定
    subgraph cluster_edge_types {
        label="边的标签";

        "二元决策？" [shape=diamond];
        "是的路径" [shape=box];
        "否的路径" [shape=box];

        "二元决策？" -> "是的路径" [label="是"];
        "二元决策？" -> "否的路径" [label="否"];

        "多项选择？" [shape=diamond];
        "选项A" [shape=box];
        "选项B" [shape=box];
        "选项C" [shape=box];

        "多项选择？" -> "选项A" [label="条件A"];
        "多项选择？" -> "选项B" [label="条件B"];
        "多项选择？" -> "选项C" [label="其他"];

        "流程A完成" [shape=doublecircle];
        "流程B开始" [shape=doublecircle];

        "流程A完成" -> "流程B开始" [label="触发", style=dotted];
    }

    // 命名模式
    subgraph cluster_naming_patterns {
        label="命名模式";

        // 问题以？结尾
        "我应该做X吗？";
        "这能变成Y吗？";
        "Z是真的吗？";
        "我做了W吗？";

        // 动作以动词开头
        "编写测试";
        "搜索模式";
        "提交更改";
        "寻求帮助";

        // 命令保持原样
        "grep -r 'pattern' .";
        "git status";
        "npm run build";

        // 状态描述情况
        "测试失败中";
        "构建完成";
        "卡在错误上";
    }

    // 流程结构模板
    subgraph cluster_structure {
        label="流程结构模板";

        "触发：某事发生了" [shape=ellipse];
        "初始检查？" [shape=diamond];
        "主要动作" [shape=box];
        "git status" [shape=plaintext];
        "另一个检查？" [shape=diamond];
        "替代动作" [shape=box];
        "停止：不要这样做" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];
        "流程完毕" [shape=doublecircle];

        "触发：某事发生了" -> "初始检查？";
        "初始检查？" -> "主要动作" [label="是"];
        "初始检查？" -> "替代动作" [label="否"];
        "主要动作" -> "git status";
        "git status" -> "另一个检查？";
        "另一个检查？" -> "流程完毕" [label="正常"];
        "另一个检查？" -> "停止：不要这样做" [label="有问题"];
        "替代动作" -> "流程完毕";
    }

    // 何时使用哪种形状
    subgraph cluster_shape_rules {
        label="何时使用每种形状";

        "选择形状" [shape=ellipse];

        "这是一个决策吗？" [shape=diamond];
        "使用菱形" [shape=diamond, style=filled, fillcolor=lightblue];

        "这是一个命令吗？" [shape=diamond];
        "使用纯文本" [shape=plaintext, style=filled, fillcolor=lightgray];

        "这是一个警告吗？" [shape=diamond];
        "使用八边形" [shape=octagon, style=filled, fillcolor=pink];

        "这是入口/出口吗？" [shape=diamond];
        "使用双圆" [shape=doublecircle, style=filled, fillcolor=lightgreen];

        "这是一个状态吗？" [shape=diamond];
        "使用椭圆" [shape=ellipse, style=filled, fillcolor=lightyellow];

        "默认：使用方框" [shape=box, style=filled, fillcolor=lightcyan];

        "选择形状" -> "这是一个决策吗？";
        "这是一个决策吗？" -> "使用菱形" [label="是"];
        "这是一个决策吗？" -> "这是一个命令吗？" [label="否"];
        "这是一个命令吗？" -> "使用纯文本" [label="是"];
        "这是一个命令吗？" -> "这是一个警告吗？" [label="否"];
        "这是一个警告吗？" -> "使用八边形" [label="是"];
        "这是一个警告吗？" -> "这是入口/出口吗？" [label="否"];
        "这是入口/出口吗？" -> "使用双圆" [label="是"];
        "这是入口/出口吗？" -> "这是一个状态吗？" [label="否"];
        "这是一个状态吗？" -> "使用椭圆" [label="是"];
        "这是一个状态吗？" -> "默认：使用方框" [label="否"];
    }

    // 好的与不好的示例
    subgraph cluster_examples {
        label="好的与不好的示例";

        // 好的：具体且形状正确
        "测试失败" [shape=ellipse];
        "阅读错误信息" [shape=box];
        "能重现吗？" [shape=diamond];
        "git diff HEAD~1" [shape=plaintext];
        "绝对不要忽略错误" [shape=octagon, style=filled, fillcolor=red, fontcolor=white];

        "测试失败" -> "阅读错误信息";
        "阅读错误信息" -> "能重现吗？";
        "能重现吗？" -> "git diff HEAD~1" [label="是"];

        // 不好的：含糊且形状错误
        bad_1 [label="出了点问题", shape=box];  // 应该是椭圆（状态）
        bad_2 [label="修一下", shape=box];  // 太含糊
        bad_3 [label="检查", shape=box];  // 应该是菱形
        bad_4 [label="运行命令", shape=box];  // 应该是纯文本，并写明实际命令

        bad_1 -> bad_2;
        bad_2 -> bad_3;
        bad_3 -> bad_4;
    }
}
