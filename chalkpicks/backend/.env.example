# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./chalkpicks.db

# The Odds API (https://the-odds-api.com - free tier available)
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_monthly_id
STRIPE_ELITE_PRICE_ID=price_elite_monthly_id
STRIPE_PRO_ANNUAL_PRICE_ID=price_pro_annual_id
STRIPE_ELITE_ANNUAL_PRICE_ID=price_elite_annual_id

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@sharpaction.io
EMAIL_PASS=your_app_password_here
EMAIL_FROM=SharpAction <noreply@sharpaction.io>

# AI Analysis (optional - uses Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ESPN Public API (no key needed)
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports
