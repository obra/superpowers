#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
COMMON_PATH="$SCRIPT_DIR/superpowers-runtime-common.sh"

source "$COMMON_PATH"

if ! host_target="$(resolve_superpowers_host_target)"; then
  printf 'No checked-in runtime is available for this host; the first Rust cutover supports only darwin-arm64 and windows-x64.\n' >&2
  exit 127
fi

if ! runtime_bin="$(resolve_superpowers_repo_runtime_binary "$RUNTIME_ROOT" "$host_target")"; then
  exit 127
fi

exec "$runtime_bin" "$@"
