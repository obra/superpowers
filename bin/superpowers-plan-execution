#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/superpowers-runtime-common.sh
. "$SCRIPT_DIR/superpowers-runtime-common.sh"
# shellcheck source=bin/superpowers-plan-structure-common
. "$SCRIPT_DIR/superpowers-plan-structure-common"

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SP_STATE_DIR="${SUPERPOWERS_STATE_DIR:-$HOME/.superpowers}"
PLAN_EXECUTION_STATUS_CACHE_SCHEMA=1
PLAN_EXECUTION_GATE_CACHE_SCHEMA=1
NO_REPO_FILES_MARKER="__superpowers__/no-repo-files"

usage() {
  cat <<'EOF' >&2
Usage:
  superpowers-plan-execution status --plan <approved-plan-path>
  superpowers-plan-execution recommend --plan <approved-plan-path> [--isolated-agents available|unavailable] [--session-intent stay|separate|unknown] [--workspace-prepared yes|no|unknown]
  superpowers-plan-execution preflight --plan <approved-plan-path>
  superpowers-plan-execution gate-review --plan <approved-plan-path>
  superpowers-plan-execution gate-finish --plan <approved-plan-path>
  superpowers-plan-execution begin ...
  superpowers-plan-execution transfer ...
  superpowers-plan-execution complete ...
  superpowers-plan-execution note ...
  superpowers-plan-execution reopen ...
EOF
}

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  printf '%s' "$value"
}

emit_error() {
  local klass="$1"
  local message="$2"
  printf '{"error_class":"%s","message":"%s"}\n' \
    "$(json_escape "$klass")" \
    "$(json_escape "$message")"
}

hash_stream() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}'
    return
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}'
    return
  fi
  cksum | awk '{print $1}'
}

hash_file() {
  local path="$1"
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$path" | awk '{print $1}'
    return
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$path" | awk '{print $1}'
    return
  fi
  cksum "$path" | awk '{print $1}'
}

file_stamp() {
  local path="$1"
  local stamp=""

  stamp="$(stat -f '%m:%z' "$path" 2>/dev/null || true)"
  if [[ -n "$stamp" ]]; then
    printf '%s\n' "$stamp"
    return 0
  fi

  stamp="$(stat -c '%Y:%s' "$path" 2>/dev/null || true)"
  if [[ -n "$stamp" ]]; then
    printf '%s\n' "$stamp"
    return 0
  fi

  return 1
}

cache_file_stamp() {
  local path="$1"
  local metadata=""
  local digest=""

  metadata="$(stat -f '%m:%c:%z:%i' "$path" 2>/dev/null || true)"
  if [[ -z "$metadata" ]]; then
    metadata="$(stat -c '%Y:%Z:%s:%i' "$path" 2>/dev/null || true)"
  fi
  [[ -n "$metadata" ]] || return 1

  digest="$(hash_file "$path" 2>/dev/null || true)"
  [[ -n "$digest" ]] || return 1

  printf '%s:%s\n' "$metadata" "$digest"
}

batch_file_hashes() {
  if [[ "$#" -eq 0 ]]; then
    return 0
  fi

  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$@" | awk '{print $1}'
    return 0
  fi

  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$@" | awk '{print $1}'
    return 0
  fi

  cksum "$@" | awk '{print $1}'
}

batch_cache_file_stamps() {
  local -a metadata_lines=()
  local -a digest_lines=()
  local line=""
  local i

  if [[ "$#" -eq 0 ]]; then
    return 0
  fi

  if stat -f '%m:%c:%z:%i' "$@" 2>/dev/null >/tmp/superpowers-plan-execution-stat.$$; then
    :
  else
    stat -c '%Y:%Z:%s:%i' "$@" 2>/dev/null >/tmp/superpowers-plan-execution-stat.$$ || {
      rm -f /tmp/superpowers-plan-execution-stat.$$
      return 1
    }
  fi

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    metadata_lines+=("$line")
  done < /tmp/superpowers-plan-execution-stat.$$
  rm -f /tmp/superpowers-plan-execution-stat.$$

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    digest_lines+=("$line")
  done < <(batch_file_hashes "$@" 2>/dev/null || true)

  (( ${#metadata_lines[@]} == $# )) || return 1
  (( ${#digest_lines[@]} == $# )) || return 1

  for ((i=0; i<$#; i++)); do
    printf '%s:%s\n' "${metadata_lines[$i]}" "${digest_lines[$i]}"
  done
}

dir_stamp() {
  cache_file_stamp "$1"
}

spec_catalog_cache_stamp() {
  local specs_dir="$REPO_ROOT/docs/superpowers/specs"
  local file stamp rel

  [[ -d "$specs_dir" ]] || {
    printf 'missing\n'
    return 0
  }

  # Execution-state freshness only depends on the latest approved spec, so the
  # cache key tracks that artifact instead of hashing every spec on every call.
  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    parse_spec_headers "$file" || continue
    [[ "$spec_state" == "CEO Approved" ]] || continue
    stamp="$(cache_file_stamp "$file" 2>/dev/null || true)"
    [[ -n "$stamp" ]] || return 1
    rel="$(rel_from_root "$file" 2>/dev/null || true)"
    [[ -n "$rel" ]] || return 1
    printf '%s|%s|%s\n' "$rel" "$spec_revision" "$stamp"
    return 0
  done < <(ls -1t "$specs_dir"/*.md 2>/dev/null || true)

  printf 'none\n'
  return 0
}

plan_execution_status_cache_dir() {
  printf '%s/plan-execution-status-cache\n' "$SP_STATE_DIR"
}

plan_execution_status_cache_path() {
  local plan_rel="$1"
  local plan_abs=""
  local source_spec_abs=""
  local evidence_rel=""
  local evidence_abs=""
  local plan_stamp=""
  local source_spec_stamp=""
  local evidence_stamp="missing"
  local spec_catalog_stamp=""
  local cache_key=""
  local cache_hash=""

  plan_abs="$(plan_rel_to_abs "$plan_rel")"
  [[ -f "$plan_abs" ]] || return 1
  plan_structure_parse_plan_headers "$plan_abs" || return 1
  source_spec_abs="$(plan_rel_to_abs "$PLAN_STRUCTURE_PLAN_SOURCE_SPEC")"
  [[ -f "$source_spec_abs" ]] || return 1
  evidence_rel="$(derive_evidence_rel_path "$plan_rel" "$PLAN_STRUCTURE_PLAN_REVISION")"
  evidence_abs="$(plan_rel_to_abs "$evidence_rel")"

  plan_stamp="$(cache_file_stamp "$plan_abs")" || return 1
  source_spec_stamp="$(cache_file_stamp "$source_spec_abs")" || return 1
  if [[ -f "$evidence_abs" ]]; then
    evidence_stamp="$(cache_file_stamp "$evidence_abs")" || return 1
  fi
  spec_catalog_stamp="$(spec_catalog_cache_stamp 2>/dev/null || true)"
  [[ -n "$spec_catalog_stamp" ]] || return 1
  cache_key="$PLAN_EXECUTION_STATUS_CACHE_SCHEMA|$plan_rel|$plan_stamp|$source_spec_stamp|$evidence_stamp|$spec_catalog_stamp"
  cache_hash="$(printf '%s' "$cache_key" | hash_stream)"
  printf '%s/%s.json\n' "$(plan_execution_status_cache_dir)" "$cache_hash"
}

read_cached_status_output() {
  local cache_path="$1"
  [[ -f "$cache_path" ]] || return 1
  cat "$cache_path"
}

write_cached_status_output() {
  local cache_path="$1"
  local payload="$2"
  local tmp_path

  mkdir -p "$(dirname "$cache_path")"
  tmp_path="$(mktemp "${cache_path}.tmp.XXXXXX")"
  printf '%s\n' "$payload" > "$tmp_path"
  mv "$tmp_path" "$cache_path"
}

plan_execution_gate_cache_dir() {
  printf '%s/plan-execution-gate-cache\n' "$SP_STATE_DIR"
}

plan_execution_gate_cache_path() {
  local gate_name="$1"
  local plan_rel="$2"
  local plan_abs=""
  local source_spec_abs=""
  local evidence_rel=""
  local evidence_abs=""
  local plan_stamp=""
  local source_spec_stamp=""
  local spec_catalog_stamp=""
  local cache_key=""
  local cache_hash=""

  plan_abs="$(plan_rel_to_abs "$plan_rel")"
  [[ -f "$plan_abs" ]] || return 1
  plan_structure_parse_plan_headers "$plan_abs" || return 1
  source_spec_abs="$(plan_rel_to_abs "$PLAN_STRUCTURE_PLAN_SOURCE_SPEC")"
  [[ -f "$source_spec_abs" ]] || return 1
  evidence_rel="$(derive_evidence_rel_path "$plan_rel" "$PLAN_STRUCTURE_PLAN_REVISION")"
  evidence_abs="$(plan_rel_to_abs "$evidence_rel")"

  plan_stamp="$(cache_file_stamp "$plan_abs" 2>/dev/null || true)"
  source_spec_stamp="$(cache_file_stamp "$source_spec_abs" 2>/dev/null || true)"
  [[ -n "$plan_stamp" && -n "$source_spec_stamp" ]] || return 1
  if [[ -f "$evidence_abs" ]]; then
    evidence_abs="$(cache_file_stamp "$evidence_abs" 2>/dev/null || true)"
  else
    evidence_abs="missing"
  fi
  [[ -n "$evidence_abs" ]] || return 1
  spec_catalog_stamp="$(spec_catalog_cache_stamp 2>/dev/null || true)"
  [[ -n "$spec_catalog_stamp" ]] || return 1

  cache_key="$PLAN_EXECUTION_GATE_CACHE_SCHEMA|$gate_name|$plan_rel|$plan_stamp|$source_spec_stamp|$evidence_abs|$spec_catalog_stamp"
  cache_hash="$(printf '%s' "$cache_key" | hash_stream)"
  printf '%s/%s.json\n' "$(plan_execution_gate_cache_dir)" "$cache_hash"
}

gate_cache_meta_path() {
  local cache_path="$1"
  printf '%s.meta\n' "${cache_path%.json}"
}

build_gate_cache_metadata() {
  local i path
  local -a lines=()
  local -a existing_paths=()
  local -a existing_abs_paths=()
  local -a stamps=()
  local stat_output=""

  for ((i=0; i<LATEST_COMPLETED_FILE_PROOF_COUNT; i++)); do
    path="${LATEST_COMPLETED_FILE_PROOF_PATHS[$i]}"
    if [[ -e "$REPO_ROOT/$path" || -L "$REPO_ROOT/$path" ]]; then
      existing_paths+=("$path")
      existing_abs_paths+=("$REPO_ROOT/$path")
    else
      lines+=("$path|missing")
    fi
  done

  if (( ${#existing_abs_paths[@]} > 0 )); then
    stat_output="$(batch_cache_file_stamps "${existing_abs_paths[@]}" 2>/dev/null || true)"
    [[ -n "$stat_output" ]] || return 1
    while IFS= read -r path; do
      [[ -n "$path" ]] || continue
      stamps+=("$path")
    done <<< "$stat_output"
    (( ${#stamps[@]} == ${#existing_paths[@]} )) || return 1
    for ((i=0; i<${#existing_paths[@]}; i++)); do
      lines+=("${existing_paths[$i]}|${stamps[$i]}")
    done
  fi

  if (( ${#lines[@]} == 0 )); then
    GATE_CACHE_METADATA=""
    return 0
  fi

  GATE_CACHE_METADATA="$(printf '%s\n' "${lines[@]}" | LC_ALL=C sort)"
  return 0
}

read_cached_gate_output() {
  local cache_path="$1"
  local meta_path="$2"
  local payload="" path="" cached_stamp="" current_stamp=""
  local -a existing_paths=()
  local -a existing_abs_paths=()
  local -a cached_stamps=()
  local -a current_stamps=()
  local stat_output=""
  local i

  [[ -f "$cache_path" && -f "$meta_path" ]] || return 1
  while IFS='|' read -r path cached_stamp; do
    [[ -n "$path" ]] || continue
    if [[ -e "$REPO_ROOT/$path" || -L "$REPO_ROOT/$path" ]]; then
      existing_paths+=("$path")
      existing_abs_paths+=("$REPO_ROOT/$path")
      cached_stamps+=("$cached_stamp")
    else
      current_stamp="missing"
      [[ "$current_stamp" == "$cached_stamp" ]] || return 1
    fi
  done < "$meta_path"

  if (( ${#existing_abs_paths[@]} > 0 )); then
    stat_output="$(batch_cache_file_stamps "${existing_abs_paths[@]}" 2>/dev/null || true)"
    [[ -n "$stat_output" ]] || return 1
    while IFS= read -r current_stamp; do
      [[ -n "$current_stamp" ]] || continue
      current_stamps+=("$current_stamp")
    done <<< "$stat_output"
    (( ${#current_stamps[@]} == ${#cached_stamps[@]} )) || return 1
    for ((i=0; i<${#cached_stamps[@]}; i++)); do
      [[ "${current_stamps[$i]}" == "${cached_stamps[$i]}" ]] || return 1
    done
  fi

  payload="$(read_cached_status_output "$cache_path" 2>/dev/null || true)"
  [[ -n "$payload" ]] || return 1
  printf '%s\n' "$payload"
}

write_cached_gate_output() {
  local cache_path="$1"
  local meta_path="$2"
  local payload="$3"
  local metadata="$4"
  local meta_tmp=""

  write_cached_status_output "$cache_path" "$payload"
  mkdir -p "$(dirname "$meta_path")"
  meta_tmp="$(mktemp "${meta_path}.tmp.XXXXXX")"
  printf '%s\n' "$metadata" > "$meta_tmp"
  mv "$meta_tmp" "$meta_path"
}

camel_to_snake() {
  printf '%s' "$1" | sed -E 's/([a-z0-9])([A-Z])/\1_\2/g' | tr 'A-Z' 'a-z'
}

emit_string_array_json() {
  local value
  local first=1
  printf '['
  for value in "$@"; do
    [[ -n "$value" ]] || continue
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '"%s"' "$(json_escape "$value")"
    first=0
  done
  printf ']'
}

emit_boolean_json() {
  if [[ "$1" == true ]]; then
    printf 'true'
  else
    printf 'false'
  fi
}

emit_diagnostics_json() {
  local diagnostic
  local first=1
  printf '['
  for diagnostic in "$@"; do
    [[ -n "$diagnostic" ]] || continue
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '%s' "$diagnostic"
    first=0
  done
  printf ']'
}

GATE_ALLOWED=true
GATE_FAILURE_CLASS=""
GATE_REASON_CODES=()
GATE_WARNING_CODES=()
GATE_DIAGNOSTICS=()

reset_gate_state() {
  GATE_ALLOWED=true
  GATE_FAILURE_CLASS=""
  GATE_REASON_CODES=()
  GATE_WARNING_CODES=()
  GATE_DIAGNOSTICS=()
}

gate_add_reason_code() {
  local code="$1"
  local existing
  [[ -n "$code" ]] || return 0
  for existing in "${GATE_REASON_CODES[@]:-}"; do
    [[ "$existing" == "$code" ]] && return 0
  done
  GATE_REASON_CODES+=("$code")
}

gate_add_warning_code() {
  local code="$1"
  local existing
  [[ -n "$code" ]] || return 0
  for existing in "${GATE_WARNING_CODES[@]:-}"; do
    [[ "$existing" == "$code" ]] && return 0
  done
  GATE_WARNING_CODES+=("$code")
}

gate_add_diagnostic() {
  local code="$1"
  local severity="$2"
  local message="$3"
  local remediation="$4"
  GATE_DIAGNOSTICS+=('{"code":"'"$(json_escape "$code")"'","severity":"'"$(json_escape "$severity")"'","message":"'"$(json_escape "$message")"'","remediation":"'"$(json_escape "$remediation")"'"}')
}

gate_fail() {
  local failure_class="$1"
  local reason_code="$2"
  local message="$3"
  local remediation="$4"
  GATE_ALLOWED=false
  [[ -n "$GATE_FAILURE_CLASS" ]] || GATE_FAILURE_CLASS="$failure_class"
  gate_add_reason_code "$reason_code"
  gate_add_diagnostic "$reason_code" "error" "$message" "$remediation"
}

emit_gate_json() {
  printf '{'
  printf '"allowed":'
  emit_boolean_json "$GATE_ALLOWED"
  printf ','
  printf '"failure_class":"%s",' "$(json_escape "$GATE_FAILURE_CLASS")"
  printf '"reason_codes":'
  emit_string_array_json "${GATE_REASON_CODES[@]:-}"
  printf ','
  printf '"warning_codes":'
  emit_string_array_json "${GATE_WARNING_CODES[@]:-}"
  printf ','
  printf '"diagnostics":'
  emit_diagnostics_json "${GATE_DIAGNOSTICS[@]:-}"
  printf '}\n'
}

spec_state=""
spec_revision=""
spec_reviewer=""

parse_spec_headers() {
  local path="$1"
  local line
  spec_state=""
  spec_revision=""
  spec_reviewer=""
  [ -f "$path" ] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$spec_state" && "$line" =~ ^\*\*Workflow\ State:\*\*\ (Draft|CEO\ Approved)$ ]]; then
      spec_state="${BASH_REMATCH[1]}"
    elif [[ -z "$spec_revision" && "$line" =~ ^\*\*Spec\ Revision:\*\*\ ([0-9]+)$ ]]; then
      spec_revision="${BASH_REMATCH[1]}"
    elif [[ -z "$spec_reviewer" && "$line" =~ ^\*\*Last\ Reviewed\ By:\*\*\ (brainstorming|plan-ceo-review)$ ]]; then
      spec_reviewer="${BASH_REMATCH[1]}"
    fi

    [[ -n "$spec_state" && -n "$spec_revision" && -n "$spec_reviewer" ]] && break
  done < "$path"

  [ -n "$spec_state" ] && [ -n "$spec_revision" ] && [ -n "$spec_reviewer" ]
}

rel_from_root() {
  local abs="$1"
  case "$abs" in
    "$REPO_ROOT"/*) printf '%s\n' "${abs#"$REPO_ROOT"/}" ;;
    *) return 1 ;;
  esac
}

count_pattern_matches() {
  local path="$1"
  local pattern="$2"
  grep -cE "$pattern" "$path" 2>/dev/null || true
}

extract_single_value() {
  local path="$1"
  local expr="$2"
  sed -nE "$expr" "$path" | head -n1
}

PROJECT_ARTIFACT_DIR=""
PROJECT_ARTIFACT_SLUG=""
PROJECT_ARTIFACT_SAFE_BRANCH=""
PROJECT_ARTIFACT_BRANCH_RAW=""

load_project_artifact_context() {
  local branch_raw slug_env=""

  branch_raw="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo current)"
  [[ -n "$branch_raw" ]] || branch_raw="current"
  [[ "$branch_raw" != "HEAD" ]] || branch_raw="current"
  PROJECT_ARTIFACT_BRANCH_RAW="$branch_raw"

  if [[ -x "$SCRIPT_DIR/superpowers-slug" ]]; then
    slug_env="$(cd "$REPO_ROOT" && "$SCRIPT_DIR/superpowers-slug" 2>/dev/null || true)"
  fi

  if [[ -n "$slug_env" ]]; then
    eval "$slug_env"
    PROJECT_ARTIFACT_SLUG="$SLUG"
    PROJECT_ARTIFACT_SAFE_BRANCH="$BRANCH"
  else
    PROJECT_ARTIFACT_SLUG="$(normalize_identifier_token "$(basename "$REPO_ROOT")")"
    PROJECT_ARTIFACT_SAFE_BRANCH="$(normalize_identifier_token "$branch_raw")"
  fi

  PROJECT_ARTIFACT_DIR="$SP_STATE_DIR/projects/$PROJECT_ARTIFACT_SLUG"
}

latest_project_artifact_path() {
  local kind="$1"
  local candidate=""

  load_project_artifact_context
  [[ -d "$PROJECT_ARTIFACT_DIR" ]] || return 1

  candidate="$(ls -t "$PROJECT_ARTIFACT_DIR"/*-"$PROJECT_ARTIFACT_SAFE_BRANCH"-"$kind"-*.md 2>/dev/null | head -n1)"
  [[ -n "$candidate" ]] || candidate="$(ls -t "$PROJECT_ARTIFACT_DIR"/*-"$kind"-*.md 2>/dev/null | head -n1)"
  [[ -n "$candidate" ]] || return 1
  printf '%s\n' "$candidate"
}

latest_branch_artifact_path() {
  local kind="$1"
  local candidate=""

  load_project_artifact_context
  [[ -d "$PROJECT_ARTIFACT_DIR" ]] || return 1

  candidate="$(ls -t "$PROJECT_ARTIFACT_DIR"/*-"$PROJECT_ARTIFACT_SAFE_BRANCH"-"$kind"-*.md 2>/dev/null | head -n1)"
  [[ -n "$candidate" ]] || return 1
  printf '%s\n' "$candidate"
}

expand_leading_tilde() {
  local raw="$1"
  case "$raw" in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s\n' "$HOME/${raw#~/}" ;;
    *) printf '%s\n' "$raw" ;;
  esac
}

reset_test_plan_artifact_state() {
  TEST_PLAN_SOURCE_PLAN=""
  TEST_PLAN_SOURCE_PLAN_REVISION=""
  TEST_PLAN_BRANCH=""
  TEST_PLAN_REPO=""
  TEST_PLAN_BROWSER_QA_REQUIRED=""
  TEST_PLAN_GENERATED_BY=""
  TEST_PLAN_GENERATED_AT=""
}

parse_test_plan_artifact() {
  local path="$1"
  reset_test_plan_artifact_state
  [[ -f "$path" ]] || return 1

  [[ "$(count_pattern_matches "$path" '^# Test Plan$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Plan:\*\* `.+`$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Plan Revision:\*\* [0-9]+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Branch:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Repo:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Browser QA Required:\*\* (yes|no)$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Generated By:\*\* superpowers:plan-eng-review$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Generated At:\*\* .+$')" == "1" ]] || return 1

  TEST_PLAN_SOURCE_PLAN="$(extract_single_value "$path" 's/^\*\*Source Plan:\*\* `(.+)`$/\1/p')"
  TEST_PLAN_SOURCE_PLAN_REVISION="$(extract_single_value "$path" 's/^\*\*Source Plan Revision:\*\* ([0-9]+)$/\1/p')"
  TEST_PLAN_BRANCH="$(extract_single_value "$path" 's/^\*\*Branch:\*\* (.+)$/\1/p')"
  TEST_PLAN_REPO="$(extract_single_value "$path" 's/^\*\*Repo:\*\* (.+)$/\1/p')"
  TEST_PLAN_BROWSER_QA_REQUIRED="$(extract_single_value "$path" 's/^\*\*Browser QA Required:\*\* (yes|no)$/\1/p')"
  TEST_PLAN_GENERATED_BY="$(extract_single_value "$path" 's/^\*\*Generated By:\*\* (.+)$/\1/p')"
  TEST_PLAN_GENERATED_AT="$(extract_single_value "$path" 's/^\*\*Generated At:\*\* (.+)$/\1/p')"
  return 0
}

reset_qa_result_artifact_state() {
  QA_RESULT_SOURCE_PLAN=""
  QA_RESULT_SOURCE_PLAN_REVISION=""
  QA_RESULT_SOURCE_TEST_PLAN=""
  QA_RESULT_BRANCH=""
  QA_RESULT_REPO=""
  QA_RESULT_HEAD_SHA=""
  QA_RESULT_VALUE=""
  QA_RESULT_GENERATED_BY=""
  QA_RESULT_GENERATED_AT=""
}

parse_qa_result_artifact() {
  local path="$1"
  reset_qa_result_artifact_state
  [[ -f "$path" ]] || return 1

  [[ "$(count_pattern_matches "$path" '^# QA Result$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Plan:\*\* `.+`$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Plan Revision:\*\* [0-9]+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Test Plan:\*\* `.+`$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Branch:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Repo:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Head SHA:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Result:\*\* (pass|fail|blocked)$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Generated By:\*\* superpowers:qa-only$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Generated At:\*\* .+$')" == "1" ]] || return 1

  QA_RESULT_SOURCE_PLAN="$(extract_single_value "$path" 's/^\*\*Source Plan:\*\* `(.+)`$/\1/p')"
  QA_RESULT_SOURCE_PLAN_REVISION="$(extract_single_value "$path" 's/^\*\*Source Plan Revision:\*\* ([0-9]+)$/\1/p')"
  QA_RESULT_SOURCE_TEST_PLAN="$(extract_single_value "$path" 's/^\*\*Source Test Plan:\*\* `(.+)`$/\1/p')"
  QA_RESULT_BRANCH="$(extract_single_value "$path" 's/^\*\*Branch:\*\* (.+)$/\1/p')"
  QA_RESULT_REPO="$(extract_single_value "$path" 's/^\*\*Repo:\*\* (.+)$/\1/p')"
  QA_RESULT_HEAD_SHA="$(extract_single_value "$path" 's/^\*\*Head SHA:\*\* (.+)$/\1/p')"
  QA_RESULT_VALUE="$(extract_single_value "$path" 's/^\*\*Result:\*\* (pass|fail|blocked)$/\1/p')"
  QA_RESULT_GENERATED_BY="$(extract_single_value "$path" 's/^\*\*Generated By:\*\* (.+)$/\1/p')"
  QA_RESULT_GENERATED_AT="$(extract_single_value "$path" 's/^\*\*Generated At:\*\* (.+)$/\1/p')"
  return 0
}

reset_release_artifact_state() {
  RELEASE_SOURCE_PLAN=""
  RELEASE_SOURCE_PLAN_REVISION=""
  RELEASE_BRANCH=""
  RELEASE_REPO=""
  RELEASE_BASE_BRANCH=""
  RELEASE_HEAD_SHA=""
  RELEASE_RESULT_VALUE=""
  RELEASE_GENERATED_BY=""
  RELEASE_GENERATED_AT=""
}

parse_release_readiness_artifact() {
  local path="$1"
  reset_release_artifact_state
  [[ -f "$path" ]] || return 1

  [[ "$(count_pattern_matches "$path" '^# Release Readiness Result$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Plan:\*\* `.+`$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Source Plan Revision:\*\* [0-9]+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Branch:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Repo:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Base Branch:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Head SHA:\*\* .+$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Result:\*\* (pass|needs-user-input|blocked)$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Generated By:\*\* superpowers:document-release$')" == "1" ]] || return 1
  [[ "$(count_pattern_matches "$path" '^\*\*Generated At:\*\* .+$')" == "1" ]] || return 1

  RELEASE_SOURCE_PLAN="$(extract_single_value "$path" 's/^\*\*Source Plan:\*\* `(.+)`$/\1/p')"
  RELEASE_SOURCE_PLAN_REVISION="$(extract_single_value "$path" 's/^\*\*Source Plan Revision:\*\* ([0-9]+)$/\1/p')"
  RELEASE_BRANCH="$(extract_single_value "$path" 's/^\*\*Branch:\*\* (.+)$/\1/p')"
  RELEASE_REPO="$(extract_single_value "$path" 's/^\*\*Repo:\*\* (.+)$/\1/p')"
  RELEASE_BASE_BRANCH="$(extract_single_value "$path" 's/^\*\*Base Branch:\*\* (.+)$/\1/p')"
  RELEASE_HEAD_SHA="$(extract_single_value "$path" 's/^\*\*Head SHA:\*\* (.+)$/\1/p')"
  RELEASE_RESULT_VALUE="$(extract_single_value "$path" 's/^\*\*Result:\*\* (pass|needs-user-input|blocked)$/\1/p')"
  RELEASE_GENERATED_BY="$(extract_single_value "$path" 's/^\*\*Generated By:\*\* (.+)$/\1/p')"
  RELEASE_GENERATED_AT="$(extract_single_value "$path" 's/^\*\*Generated At:\*\* (.+)$/\1/p')"
  return 0
}

find_latest_approved_spec() {
  local candidate rel

  LATEST_APPROVED_SPEC_PATH=""
  LATEST_APPROVED_SPEC_REVISION=""

  # shellcheck disable=SC2012
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    parse_spec_headers "$candidate" || continue
    [[ "$spec_state" == "CEO Approved" ]] || continue
    rel="$(rel_from_root "$candidate")" || continue
    LATEST_APPROVED_SPEC_PATH="$rel"
    LATEST_APPROVED_SPEC_REVISION="$spec_revision"
    return 0
  done < <(ls -1t "$REPO_ROOT"/docs/superpowers/specs/*.md 2>/dev/null || true)

  return 1
}

current_base_branch_name() {
  local branch=""
  local current_branch=""
  local candidate=""
  local local_branch_count=0

  if command -v gh >/dev/null 2>&1; then
    branch="$(cd "$REPO_ROOT" && gh pr view --json baseRefName -q .baseRefName 2>/dev/null || true)"
    [[ -n "$branch" ]] || branch="$(cd "$REPO_ROOT" && gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null || true)"
  fi

  current_branch="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  if [[ -n "$current_branch" && "$current_branch" != "HEAD" ]]; then
    [[ -n "$branch" ]] || branch="$(git -C "$REPO_ROOT" config --get "branch.$current_branch.gh-merge-base" 2>/dev/null || true)"
  fi
  [[ -n "$branch" ]] || branch="$(git -C "$REPO_ROOT" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's#^refs/remotes/origin/##' || true)"

  if [[ -z "$branch" ]]; then
    for candidate in main master develop dev trunk; do
      if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$candidate" ||
         git -C "$REPO_ROOT" show-ref --verify --quiet "refs/remotes/origin/$candidate"; then
        branch="$candidate"
        break
      fi
    done
  fi

  if [[ -z "$branch" ]]; then
    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      candidate="${candidate#refs/heads/}"
      branch="$candidate"
      local_branch_count=$((local_branch_count + 1))
      if (( local_branch_count > 1 )); then
        branch=""
        break
      fi
    done < <(git -C "$REPO_ROOT" for-each-ref --format='%(refname)' refs/heads 2>/dev/null || true)
  fi

  [[ -n "$branch" ]] || return 1
  printf '%s\n' "$branch"
}

derive_tasks_independent_from_plan() {
  local plan_abs="$1"
  local tasks_independent="unknown"
  local -a task_scopes=()
  local task_count=0
  local i j write_count
  local entries action raw_path normalized_path path compare

  plan_structure_parse_for_execution "$plan_abs" || {
    printf '%s\n' "$tasks_independent"
    return 0
  }

  task_count="$PLAN_STRUCTURE_TASK_COUNT"

  if (( task_count < 2 )); then
    printf '%s\n' "$tasks_independent"
    return 0
  fi

  for ((i=0; i<task_count; i++)); do
    write_count=0
    entries="${PLAN_STRUCTURE_TASK_FILE_ENTRIES[$i]:-}"
    while IFS=$'\t' read -r action raw_path normalized_path; do
      [[ -n "$action" ]] || continue
      case "$action" in
        Create|Modify|Delete)
          write_count=$((write_count + 1))
          if [[ -n "${task_scopes[$i]:-}" ]]; then
            task_scopes[$i]+=$'\n'"$normalized_path"
          else
            task_scopes[$i]="$normalized_path"
          fi
          ;;
      esac
    done <<< "$entries"
    if (( write_count == 0 )); then
      printf '%s\n' "$tasks_independent"
      return 0
    fi
  done

  for ((i=0; i<task_count; i++)); do
    while IFS= read -r path; do
      [[ -n "$path" ]] || continue
      for ((j=i+1; j<task_count; j++)); do
        while IFS= read -r compare; do
          [[ -n "$compare" ]] || continue
          if [[ "$path" == "$compare" ]]; then
            printf 'no\n'
            return 0
          fi
        done <<< "${task_scopes[$j]}"
      done
    done <<< "${task_scopes[$i]}"
  done

  printf 'yes\n'
  return 0
}

plan_structure_parse_for_execution() {
  local plan_abs="$1"
  local previous_setting="${PLAN_STRUCTURE_REQUIRE_FULL_TASK_FIELDS-__unset__}"
  local status=0

  PLAN_STRUCTURE_REQUIRE_FULL_TASK_FIELDS="no"
  plan_structure_parse "$plan_abs" || status=$?
  if [[ "$previous_setting" == "__unset__" ]]; then
    unset PLAN_STRUCTURE_REQUIRE_FULL_TASK_FIELDS
  else
    PLAN_STRUCTURE_REQUIRE_FULL_TASK_FIELDS="$previous_setting"
  fi

  return "$status"
}

validate_persisted_normalized_text() {
  local raw_value="$1"
  local message="$2"
  local overlong_message="${3:-}"
  local max_len="${4:-}"
  local normalized
  local status

  if normalized="$(normalize_whitespace_bounded "$raw_value" "$max_len")"; then
    :
  else
    status=$?
    if [[ "$status" == "2" ]]; then
      set_failure "MalformedExecutionState" "${overlong_message:-$message}"
    else
      set_failure "MalformedExecutionState" "$message"
    fi
    return 1
  fi

  PERSISTED_NORMALIZED_VALUE="$normalized"
  return 0
}

validate_persisted_repo_relative_path() {
  local raw_value="$1"
  local message="$2"
  local normalized

  normalized="$(trim_surrounding_whitespace "$raw_value")"
  if [[ "$normalized" == "$NO_REPO_FILES_MARKER" ]]; then
    PERSISTED_NORMALIZED_PATH="$NO_REPO_FILES_MARKER"
    return 0
  fi
  normalized="$(normalize_repo_relative_path "$normalized")" || {
    set_failure "MalformedExecutionState" "$message"
    return 1
  }

  PERSISTED_NORMALIZED_PATH="$normalized"
  return 0
}

validate_persisted_execution_source() {
  local raw_value="$1"
  local normalized

  normalized="$(normalize_whitespace "$raw_value")"
  case "$normalized" in
    superpowers:executing-plans|superpowers:subagent-driven-development) ;;
    *)
      set_failure "MalformedExecutionState" "Execution evidence source must be one of the supported execution modes."
      return 1
      ;;
  esac

  if [[ "$PLAN_EXECUTION_MODE" != "none" && "$normalized" != "$PLAN_EXECUTION_MODE" ]]; then
    set_failure "MalformedExecutionState" "Execution evidence source must exactly match the persisted execution mode for this plan revision."
    return 1
  fi

  PERSISTED_EXECUTION_SOURCE="$normalized"
  return 0
}

plan_rel_to_abs() {
  local rel="$1"
  printf '%s/%s\n' "$REPO_ROOT" "$rel"
}

derive_evidence_rel_path() {
  local plan_rel="$1"
  local revision="$2"
  local base
  base="$(basename "$plan_rel" .md)"
  printf 'docs/superpowers/execution-evidence/%s-r%s-evidence.md\n' "$base" "$revision"
}

set_failure() {
  LOAD_ERROR_CLASS="$1"
  LOAD_ERROR_MESSAGE="$2"
  return 1
}

json_string_field() {
  local json="$1"
  local key="$2"
  local value

  value="${json#*"\"$key\":\""}"
  if [[ "$value" == "$json" ]]; then
    printf '%s' ""
    return 0
  fi
  value="${value%%\"*}"
  printf '%s' "$value"
}

reset_plan_parse_state() {
  PLAN_WORKFLOW_STATE=""
  PLAN_REVISION=""
  PLAN_EXECUTION_MODE=""
  PLAN_SOURCE_SPEC=""
  PLAN_SOURCE_SPEC_REVISION=""
  PLAN_LAST_REVIEWED_BY=""

  STEP_COUNT=0
  STEP_TASKS=()
  STEP_NUMBERS=()
  STEP_CHECKED=()
  STEP_TITLES=()
  STEP_NOTE_STATES=()
  STEP_NOTE_SUMMARIES=()

  PLAN_ACTIVE_TASK="null"
  PLAN_ACTIVE_STEP="null"
  PLAN_BLOCKING_TASK="null"
  PLAN_BLOCKING_STEP="null"
  PLAN_RESUME_TASK="null"
  PLAN_RESUME_STEP="null"
  PLAN_CHECKED_COUNT=0
  PLAN_NOTE_COUNT=0
}

find_step_index() {
  local task="$1"
  local step="$2"
  local i
  for ((i=0; i<STEP_COUNT; i++)); do
    if [[ "${STEP_TASKS[$i]}" == "$task" && "${STEP_NUMBERS[$i]}" == "$step" ]]; then
      printf '%s\n' "$i"
      return 0
    fi
  done
  return 1
}

add_step() {
  local task="$1"
  local step="$2"
  local checked="$3"
  local title="$4"

  if find_step_index "$task" "$step" >/dev/null 2>&1; then
    set_failure "MalformedExecutionState" "Duplicate Task ${task} Step ${step} in approved plan."
    return 1
  fi

  STEP_TASKS[$STEP_COUNT]="$task"
  STEP_NUMBERS[$STEP_COUNT]="$step"
  STEP_CHECKED[$STEP_COUNT]="$checked"
  STEP_TITLES[$STEP_COUNT]="$title"
  STEP_NOTE_STATES[$STEP_COUNT]=""
  STEP_NOTE_SUMMARIES[$STEP_COUNT]=""
  if [[ "$checked" == "x" ]]; then
    PLAN_CHECKED_COUNT=$((PLAN_CHECKED_COUNT + 1))
  fi
  STEP_COUNT=$((STEP_COUNT + 1))
  return 0
}

parse_plan_file() {
  local plan_abs="$1"
  local line line_no=0 current_task="" pending_index="" note_state note_summary
  local active_count=0 blocked_count=0 interrupted_count=0 current_work_count=0
  local in_files_block=0 task_files_seen=0 task_file_entries_count=0 task_step_count=0

  plan_structure_parse "$plan_abs" || {
    set_failure "PlanNotExecutionReady" "${PLAN_STRUCTURE_ERROR_MESSAGE:-Approved plan task structure is malformed.}"
    return 1
  }

  reset_plan_parse_state

  finalize_current_task_structure() {
    if [[ -z "$current_task" ]]; then
      return 0
    fi
    if (( task_files_seen == 0 || task_file_entries_count == 0 )); then
      set_failure "MalformedExecutionState" "Task $current_task is missing a parseable Files block."
      return 1
    fi
    if (( task_step_count == 0 )); then
      set_failure "MalformedExecutionState" "Task $current_task must include at least one step."
      return 1
    fi
    return 0
  }

  while IFS= read -r line || [[ -n "$line" ]]; do
    line_no=$((line_no + 1))

    if [[ "$line" =~ ^\*\*Workflow\ State:\*\*\ (.+)$ ]]; then
      PLAN_WORKFLOW_STATE="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^\*\*Plan\ Revision:\*\*\ ([0-9]+)$ ]]; then
      PLAN_REVISION="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^\*\*Execution\ Mode:\*\*\ (.+)$ ]]; then
      PLAN_EXECUTION_MODE="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^\*\*Source\ Spec:\*\*\ \`(.+)\`$ ]]; then
      PLAN_SOURCE_SPEC="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^\*\*Source\ Spec\ Revision:\*\*\ ([0-9]+)$ ]]; then
      PLAN_SOURCE_SPEC_REVISION="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^\*\*Last\ Reviewed\ By:\*\*\ (.+)$ ]]; then
      PLAN_LAST_REVIEWED_BY="${BASH_REMATCH[1]}"
      continue
    fi

    if [[ "$line" =~ ^###\ Task\ ([0-9]+): ]]; then
      set_failure "MalformedExecutionState" "Task headings must use canonical '## Task N:' form."
      return 1
    fi
    if [[ "$line" =~ ^##\ Task\ ([0-9]+): ]]; then
      finalize_current_task_structure || return 1
      current_task="${BASH_REMATCH[1]}"
      pending_index=""
      in_files_block=0
      task_files_seen=0
      task_file_entries_count=0
      task_step_count=0
      continue
    fi

    if [[ -n "$current_task" && "$line" == "**Files:**" ]]; then
      in_files_block=1
      task_files_seen=1
      pending_index=""
      continue
    fi
    if (( in_files_block == 1 )); then
      if [[ "$line" =~ ^-\ (Create|Modify|Delete|Test):\ .+$ ]]; then
        task_file_entries_count=$((task_file_entries_count + 1))
        continue
      fi
      if [[ -z "$line" || "$line" =~ ^[[:space:]]+$ ]]; then
        continue
      fi
      in_files_block=0
    fi

    if [[ "$line" =~ ^-\ \[([[:space:]x])\]\ \*\*Step\ ([0-9]+):\ (.*)\*\*$ ]]; then
      [[ -n "$current_task" ]] || set_failure "MalformedExecutionState" "Found a step outside any task heading in approved plan." || return 1
      add_step "$current_task" "${BASH_REMATCH[2]}" "$([[ "${BASH_REMATCH[1]}" == "x" ]] && printf 'x' || printf ' ')" "${BASH_REMATCH[3]}" || return 1
      pending_index=$((STEP_COUNT - 1))
      task_step_count=$((task_step_count + 1))
      continue
    fi
    if [[ "$line" =~ ^[[:space:]]+\*\*Execution\ Note:\*\*\ (.+)$ ]]; then
      [[ -n "$pending_index" ]] || set_failure "MalformedExecutionState" "Execution note is not adjacent to an unchecked step." || return 1
      [[ -z "${STEP_NOTE_STATES[$pending_index]}" ]] || set_failure "MalformedExecutionState" "Unchecked steps may not carry more than one execution note." || return 1
      if [[ "${STEP_CHECKED[$pending_index]}" == "x" ]]; then
        set_failure "MalformedExecutionState" "Checked steps may not retain execution notes."
        return 1
      fi

      if [[ "${BASH_REMATCH[1]}" =~ ^(Active|Interrupted|Blocked)\ -\ (.+)$ ]]; then
        note_state="${BASH_REMATCH[1]}"
        note_summary="${BASH_REMATCH[2]}"
      else
        set_failure "MalformedExecutionState" "Execution notes must use canonical '<State> - <summary>' form."
        return 1
      fi

      validate_persisted_normalized_text \
        "$note_summary" \
        "Execution note summaries may not be blank after whitespace normalization." \
        "Execution note summaries may not exceed 120 characters after whitespace normalization." \
        120 || return 1
      STEP_NOTE_STATES[$pending_index]="$note_state"
      STEP_NOTE_SUMMARIES[$pending_index]="$PERSISTED_NORMALIZED_VALUE"
      PLAN_NOTE_COUNT=$((PLAN_NOTE_COUNT + 1))
      continue
    fi
    if [[ -n "$pending_index" && -n "$line" && ! "$line" =~ ^[[:space:]]+$ ]]; then
      pending_index=""
    fi
  done < "$plan_abs"

  finalize_current_task_structure || return 1

  local i task step
  for ((i=0; i<STEP_COUNT; i++)); do
    task="${STEP_TASKS[$i]}"
    step="${STEP_NUMBERS[$i]}"
    case "${STEP_NOTE_STATES[$i]}" in
      Active)
        active_count=$((active_count + 1))
        current_work_count=$((current_work_count + 1))
        PLAN_ACTIVE_TASK="$task"
        PLAN_ACTIVE_STEP="$step"
        ;;
      Blocked)
        blocked_count=$((blocked_count + 1))
        current_work_count=$((current_work_count + 1))
        PLAN_BLOCKING_TASK="$task"
        PLAN_BLOCKING_STEP="$step"
        ;;
      Interrupted)
        interrupted_count=$((interrupted_count + 1))
        PLAN_RESUME_TASK="$task"
        PLAN_RESUME_STEP="$step"
        ;;
      '')
        ;;
      *)
        set_failure "MalformedExecutionState" "Unsupported execution note state '${STEP_NOTE_STATES[$i]}'."
        return 1
        ;;
    esac
  done

  if (( current_work_count > 1 )); then
    set_failure "MalformedExecutionState" "Plan may have at most one current-work note at a time."
    return 1
  fi
  if (( interrupted_count > 1 )); then
    set_failure "MalformedExecutionState" "Plan may have at most one interrupted resume note at a time."
    return 1
  fi

  return 0
}

validate_source_spec() {
  local source_rel="$1"
  local expected_revision="$2"
  local normalized source_abs

  normalized="$(normalize_repo_relative_path "$source_rel")" || {
    set_failure "PlanNotExecutionReady" "Approved plan source spec path is malformed."
    return 1
  }
  source_abs="$(plan_rel_to_abs "$normalized")"
  if [[ ! -f "$source_abs" ]]; then
    set_failure "PlanNotExecutionReady" "Approved plan source spec does not exist."
    return 1
  fi

  parse_spec_headers "$source_abs" || {
    set_failure "PlanNotExecutionReady" "Approved plan source spec headers are missing or malformed."
    return 1
  }

  if [[ "$spec_state" != "CEO Approved" ]]; then
    set_failure "PlanNotExecutionReady" "Approved plan source spec is not CEO Approved."
    return 1
  fi
  if [[ "$spec_revision" != "$expected_revision" ]]; then
    set_failure "PlanNotExecutionReady" "Approved plan source spec path or revision is stale."
    return 1
  fi
  if find_latest_approved_spec; then
    if [[ "$normalized" != "$LATEST_APPROVED_SPEC_PATH" || "$expected_revision" != "$LATEST_APPROVED_SPEC_REVISION" ]]; then
      set_failure "PlanNotExecutionReady" "Approved plan source spec path or revision is stale."
      return 1
    fi
  fi
  spec_reviewer="$(normalize_whitespace "$spec_reviewer")"
  case "$spec_reviewer" in
    brainstorming|plan-ceo-review) ;;
    *)
      set_failure "PlanNotExecutionReady" "Approved plan source spec Last Reviewed By header is missing or malformed."
      return 1
      ;;
  esac

  return 0
}

reset_evidence_parse_state() {
  EVIDENCE_EXISTS=0
  EVIDENCE_EMPTY_STATE=1
  EVIDENCE_FORMAT="empty"
  EVIDENCE_ATTEMPT_COUNT=0
  EVIDENCE_SOURCE_COUNT=0
  EVIDENCE_SOURCE_ONE=""
  EVIDENCE_SOURCE_TWO=""
  EVIDENCE_PATH_LINE=""
  EVIDENCE_REVISION_LINE=""
  EVIDENCE_PLAN_FINGERPRINT=""
  EVIDENCE_SOURCE_SPEC_PATH=""
  EVIDENCE_SOURCE_SPEC_REVISION=""
  EVIDENCE_SOURCE_SPEC_FINGERPRINT=""
}

parse_evidence_file() {
  local evidence_abs="$1"
  local expected_plan_rel="$2"
  local expected_revision="$3"
  local line
  local title_count=0 path_count=0 revision_count=0 section_count=0 step_section_count=0 attempt_count=0
  local plan_fingerprint_count=0 source_spec_path_count=0 source_spec_revision_count=0 source_spec_fingerprint_count=0
  local v2_header_count

  reset_evidence_parse_state
  if [[ ! -f "$evidence_abs" ]]; then
    EVIDENCE_EXISTS=0
    EVIDENCE_EMPTY_STATE=1
    return 0
  fi

  EVIDENCE_EXISTS=1

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^#\ Execution\ Evidence: ]]; then
      title_count=$((title_count + 1))
    elif [[ "$line" =~ ^\*\*Plan\ Path:\*\*\ (.+)$ ]]; then
      path_count=$((path_count + 1))
      [[ -z "$EVIDENCE_PATH_LINE" ]] && EVIDENCE_PATH_LINE="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^\*\*Plan\ Revision:\*\*\ ([0-9]+)$ ]]; then
      revision_count=$((revision_count + 1))
      [[ -z "$EVIDENCE_REVISION_LINE" ]] && EVIDENCE_REVISION_LINE="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^\*\*Plan\ Fingerprint:\*\*\ (.+)$ ]]; then
      plan_fingerprint_count=$((plan_fingerprint_count + 1))
      [[ -z "$EVIDENCE_PLAN_FINGERPRINT" ]] && EVIDENCE_PLAN_FINGERPRINT="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^\*\*Source\ Spec\ Path:\*\*\ (.+)$ ]]; then
      source_spec_path_count=$((source_spec_path_count + 1))
      [[ -z "$EVIDENCE_SOURCE_SPEC_PATH" ]] && EVIDENCE_SOURCE_SPEC_PATH="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^\*\*Source\ Spec\ Revision:\*\*\ ([0-9]+)$ ]]; then
      source_spec_revision_count=$((source_spec_revision_count + 1))
      [[ -z "$EVIDENCE_SOURCE_SPEC_REVISION" ]] && EVIDENCE_SOURCE_SPEC_REVISION="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^\*\*Source\ Spec\ Fingerprint:\*\*\ (.+)$ ]]; then
      source_spec_fingerprint_count=$((source_spec_fingerprint_count + 1))
      [[ -z "$EVIDENCE_SOURCE_SPEC_FINGERPRINT" ]] && EVIDENCE_SOURCE_SPEC_FINGERPRINT="${BASH_REMATCH[1]}"
    elif [[ "$line" == "## Step Evidence" ]]; then
      section_count=$((section_count + 1))
    elif [[ "$line" =~ ^###\ Task\ [0-9][0-9]*\ Step\ [0-9][0-9]*$ ]]; then
      step_section_count=$((step_section_count + 1))
    elif [[ "$line" =~ ^####\ Attempt\ [0-9][0-9]*$ ]]; then
      attempt_count=$((attempt_count + 1))
    fi
  done < "$evidence_abs"
  v2_header_count=$(( plan_fingerprint_count + source_spec_path_count + source_spec_revision_count + source_spec_fingerprint_count ))

  if [[ "$title_count" != "1" || "$path_count" != "1" || "$revision_count" != "1" || "$section_count" != "1" ]]; then
    set_failure "MalformedExecutionState" "Execution evidence artifact header structure is malformed."
    return 1
  fi

  if [[ "$EVIDENCE_PATH_LINE" != "$expected_plan_rel" || "$EVIDENCE_REVISION_LINE" != "$expected_revision" ]]; then
    set_failure "MalformedExecutionState" "Execution evidence artifact does not match the current approved plan revision."
    return 1
  fi

  if (( v2_header_count > 0 )); then
    if [[ "$plan_fingerprint_count" != "1" || "$source_spec_path_count" != "1" || "$source_spec_revision_count" != "1" || "$source_spec_fingerprint_count" != "1" ]]; then
      set_failure "MalformedExecutionState" "Execution evidence v2 header metadata is incomplete."
      return 1
    fi
    EVIDENCE_FORMAT="v2"
  else
    EVIDENCE_FORMAT="legacy"
  fi

  if [[ "$step_section_count" == "0" && "$attempt_count" == "0" ]]; then
    EVIDENCE_EMPTY_STATE=1
    EVIDENCE_FORMAT="empty"
    return 0
  fi

  if [[ "$step_section_count" == "0" || "$attempt_count" == "0" ]]; then
    set_failure "MalformedExecutionState" "Execution evidence artifact is missing required step sections or attempts."
    return 1
  fi

  EVIDENCE_EMPTY_STATE=0
  EVIDENCE_ATTEMPT_COUNT="$attempt_count"

  return 0
}

compute_execution_fingerprint() {
  local plan_abs="$1"
  local evidence_abs="$2"
  {
    printf 'plan\n'
    cat "$plan_abs"
    printf '\n--evidence--\n'
    if [[ "$EVIDENCE_EMPTY_STATE" == "1" ]]; then
      printf '__EMPTY_EVIDENCE__\n'
    else
      cat "$evidence_abs"
    fi
  } | hash_stream
}

truncate_with_ellipsis() {
  local text="$1"
  local max_len="$2"
  if (( ${#text} <= max_len )); then
    printf '%s' "$text"
    return
  fi
  if (( max_len <= 3 )); then
    printf '%.*s' "$max_len" "$text"
    return
  fi
  printf '%s...' "${text:0:max_len-3}"
}

active_summary_from_title() {
  local normalized
  normalized="$(normalize_whitespace "$1")"
  truncate_with_ellipsis "$normalized" 120
}

reopen_note_summary() {
  local normalized
  normalized="$(normalize_whitespace "$1")"
  truncate_with_ellipsis "Reopened: $normalized" 120
}

validate_required_normalized_text() {
  local raw_value="$1"
  local empty_message="$2"
  local overlong_message="${3:-}"
  local max_len="${4:-}"
  local normalized
  local status

  if normalized="$(normalize_whitespace_bounded "$raw_value" "$max_len")"; then
    :
  else
    status=$?
    if [[ "$status" == "2" ]]; then
      set_failure "InvalidCommandInput" "${overlong_message:-$empty_message}"
    else
      set_failure "InvalidCommandInput" "$empty_message"
    fi
    return 1
  fi
  REQUIRED_TEXT_NORMALIZED="$normalized"
  return 0
}

validate_note_message() {
  validate_required_normalized_text \
    "$1" \
    "Execution note summaries may not be blank after whitespace normalization." \
    "Normalized execution note summaries may not exceed 120 characters." \
    120 || return 1
  NOTE_MESSAGE_NORMALIZED="$REQUIRED_TEXT_NORMALIZED"
  return 0
}

assert_expected_fingerprint() {
  local expected="$1"
  if [[ "$expected" != "$EXECUTION_FINGERPRINT" ]]; then
    set_failure "StaleMutation" "Execution state changed since the last parsed execution fingerprint."
    return 1
  fi
  return 0
}

validate_execution_mode_source() {
  local source="$1"
  case "$source" in
    superpowers:executing-plans|superpowers:subagent-driven-development) ;;
    *)
      set_failure "InvalidExecutionMode" "Execution source must be one of the supported execution modes."
      return 1
      ;;
  esac
  if [[ "$PLAN_EXECUTION_MODE" == "none" || "$source" != "$PLAN_EXECUTION_MODE" ]]; then
    set_failure "InvalidExecutionMode" "Execution source must exactly match the persisted execution mode for this plan revision."
    return 1
  fi
  return 0
}

scan_diff_name_status_stream() {
  local query="$1"
  local status path_one path_two

  while IFS= read -r -d '' status; do
    case "$status" in
      R*|C*)
        IFS= read -r -d '' path_one || return 1
        IFS= read -r -d '' path_two || return 1
        if [[ "$query" == "$path_one" || "$query" == "$path_two" ]]; then
          printf '%s\n' "$path_two"
          return 0
        fi
        ;;
      *)
        IFS= read -r -d '' path_one || return 1
        if [[ "$query" == "$path_one" ]]; then
          printf '%s\n' "$path_one"
          return 0
        fi
        ;;
    esac
  done

  return 1
}

resolve_path_from_current_change_set() {
  local query="$1"
  local resolved=""
  local untracked=""

  if resolved="$(
    scan_diff_name_status_stream "$query" < <(
      git -C "$REPO_ROOT" diff --name-status -z -M --cached 2>/dev/null || true
      git -C "$REPO_ROOT" diff --name-status -z -M 2>/dev/null || true
    )
  )"; then
    printf '%s\n' "$resolved"
    return 0
  fi

  untracked="$(git -C "$REPO_ROOT" ls-files --others --exclude-standard -- "$query" 2>/dev/null | head -n1)"
  if [[ "$untracked" == "$query" ]]; then
    printf '%s\n' "$query"
    return 0
  fi

  return 1
}

build_no_repo_files_entry() {
  FILES_ENTRY="$NO_REPO_FILES_MARKER"
  return 0
}

build_default_files_entry_for_task() {
  local task="$1"
  local task_index entries action normalized_path resolved
  local collected=()

  if plan_structure_parse_for_execution "$PLAN_ABS_PATH" 2>/dev/null; then
    task_index="$(plan_structure_find_task_index "$task" 2>/dev/null || true)"
    if [[ -n "$task_index" ]]; then
      entries="${PLAN_STRUCTURE_TASK_FILE_ENTRIES[$task_index]:-}"
      while IFS=$'\t' read -r action _ normalized_path; do
        [[ -n "$action" && -n "$normalized_path" ]] || continue
        if [[ -e "$REPO_ROOT/$normalized_path" || -L "$REPO_ROOT/$normalized_path" ]]; then
          collected+=("$normalized_path")
          continue
        fi
        resolved="$(resolve_path_from_current_change_set "$normalized_path" 2>/dev/null || true)"
        [[ -n "$resolved" ]] || continue
        collected+=("$resolved")
      done <<< "$entries"
    fi
  fi

  if (( ${#collected[@]} == 0 )); then
    build_no_repo_files_entry
    return 0
  fi

  build_files_entry "${collected[@]}"
}

build_files_entry() {
  local inputs=("$@")
  local input normalized resolved
  local collected=()

  if (( ${#inputs[@]} == 0 )); then
    build_no_repo_files_entry
    return 0
  fi

  for input in "${inputs[@]}"; do
    if [[ "$input" == "$NO_REPO_FILES_MARKER" ]]; then
      set_failure "InvalidCommandInput" "Evidence file paths may not use the reserved no-file marker."
      return 1
    fi
    normalized="$(normalize_repo_relative_path "$input")" || {
      set_failure "InvalidCommandInput" "Evidence file paths must be normalized repo-relative paths inside the repo root."
      return 1
    }

    if [[ -e "$REPO_ROOT/$normalized" || -L "$REPO_ROOT/$normalized" ]]; then
      resolved="$normalized"
    else
      resolved="$(resolve_path_from_current_change_set "$normalized")" || {
        set_failure "InvalidCommandInput" "Evidence file paths must exist or be represented in the current change set."
        return 1
      }
    fi

    collected+=("$resolved")
  done

  FILES_ENTRY="$(printf '%s\n' "${collected[@]}" | LC_ALL=C sort -u)"
  return 0
}

reset_attempts_state() {
  ATT_COUNT=0
  ATT_TASKS=()
  ATT_STEPS=()
  ATT_NUMBERS=()
  ATT_FORMATS=()
  ATT_STATUS=()
  ATT_RECORDED_AT=()
  ATT_SOURCES=()
  ATT_PACKET_FINGERPRINTS=()
  ATT_HEAD_SHAS=()
  ATT_BASE_SHAS=()
  ATT_CLAIMS=()
  ATT_FILES=()
  ATT_FILE_PROOFS=()
  ATT_VERIFICATION=()
  ATT_VERIFICATION_SUMMARIES=()
  ATT_INVALIDATION_REASONS=()
}

push_attempt() {
  local task="$1"
  local step="$2"
  local number="$3"
  ATT_TASKS[$ATT_COUNT]="$task"
  ATT_STEPS[$ATT_COUNT]="$step"
  ATT_NUMBERS[$ATT_COUNT]="$number"
  ATT_FORMATS[$ATT_COUNT]=""
  ATT_STATUS[$ATT_COUNT]=""
  ATT_RECORDED_AT[$ATT_COUNT]=""
  ATT_SOURCES[$ATT_COUNT]=""
  ATT_PACKET_FINGERPRINTS[$ATT_COUNT]=""
  ATT_HEAD_SHAS[$ATT_COUNT]=""
  ATT_BASE_SHAS[$ATT_COUNT]=""
  ATT_CLAIMS[$ATT_COUNT]=""
  ATT_FILES[$ATT_COUNT]=""
  ATT_FILE_PROOFS[$ATT_COUNT]=""
  ATT_VERIFICATION[$ATT_COUNT]=""
  ATT_VERIFICATION_SUMMARIES[$ATT_COUNT]=""
  ATT_INVALIDATION_REASONS[$ATT_COUNT]=""
  ATT_COUNT=$((ATT_COUNT + 1))
}

parse_evidence_attempts() {
  local line current_task="" current_step="" current_index="" current_format=""
  local queued_line="" have_queued_line=0
  local files_lines=()
  local file_proof_lines=()
  local expected_stage=""
  local last_task=0
  local last_step=0
  local last_attempt_number=0
  local section_key=""
  local seen_sections=""
  reset_attempts_state

  if [[ "$EVIDENCE_EXISTS" != "1" || "$EVIDENCE_EMPTY_STATE" == "1" ]]; then
    return 0
  fi

  exec 3< "$EVIDENCE_ABS_PATH"
  while true; do
    if (( have_queued_line == 1 )); then
      line="$queued_line"
      have_queued_line=0
    elif ! IFS= read -r line <&3; then
      break
    fi

    if [[ -z "$line" ]]; then
      continue
    fi

    if [[ "$line" =~ ^###\ Task\ ([0-9]+)\ Step\ ([0-9]+)$ ]]; then
      if [[ -n "$current_index" && "$expected_stage" != "done" ]]; then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence attempt is incomplete."
        return 1
      fi
      if (( ${BASH_REMATCH[1]} < last_task || (${BASH_REMATCH[1]} == last_task && ${BASH_REMATCH[2]} <= last_step) )); then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence step sections must be ordered canonically and appear once."
        return 1
      fi
      section_key="|${BASH_REMATCH[1]}:${BASH_REMATCH[2]}|"
      if [[ "$seen_sections" == *"$section_key"* ]]; then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence step sections may not repeat."
        return 1
      fi
      seen_sections+="$section_key"
      current_task="${BASH_REMATCH[1]}"
      current_step="${BASH_REMATCH[2]}"
      if ! find_step_index "$current_task" "$current_step" >/dev/null 2>&1; then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence may not reference steps that do not exist in the current approved plan."
        return 1
      fi
      last_task="${BASH_REMATCH[1]}"
      last_step="${BASH_REMATCH[2]}"
      current_index=""
      current_format=""
      last_attempt_number=0
    elif [[ "$line" =~ ^####\ Attempt\ ([0-9]+)$ ]]; then
      if [[ -n "$current_index" && "$expected_stage" != "done" ]]; then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence attempt is incomplete."
        return 1
      fi
      [[ -n "$current_task" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence attempt is missing its step heading."; return 1; }
      if (( ${BASH_REMATCH[1]} != last_attempt_number + 1 )); then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence attempts must be contiguous and start at 1 within each step section."
        return 1
      fi
      push_attempt "$current_task" "$current_step" "${BASH_REMATCH[1]}"
      current_index=$((ATT_COUNT - 1))
      last_attempt_number="${BASH_REMATCH[1]}"
      expected_stage="status"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Status:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "status" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      ATT_STATUS[$current_index]="${BASH_REMATCH[1]}"
      expected_stage="recorded_at"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Recorded\ At:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "recorded_at" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      ATT_RECORDED_AT[$current_index]="${BASH_REMATCH[1]}"
      expected_stage="execution_source"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Execution\ Source:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "execution_source" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      validate_persisted_execution_source "${BASH_REMATCH[1]}" || {
        exec 3<&-
        return 1
      }
      ATT_SOURCES[$current_index]="$PERSISTED_EXECUTION_SOURCE"
      if [[ "$EVIDENCE_SOURCE_COUNT" == "0" ]]; then
        EVIDENCE_SOURCE_COUNT=1
        EVIDENCE_SOURCE_ONE="$PERSISTED_EXECUTION_SOURCE"
      elif [[ "$PERSISTED_EXECUTION_SOURCE" != "$EVIDENCE_SOURCE_ONE" ]]; then
        EVIDENCE_SOURCE_COUNT=2
        EVIDENCE_SOURCE_TWO="$PERSISTED_EXECUTION_SOURCE"
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence contains multiple distinct persisted execution sources for one revision."
        return 1
      fi
      expected_stage="post_source"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Task\ Number:\*\*\ ([0-9]+)$ ]]; then
      [[ "$expected_stage" == "post_source" && "$EVIDENCE_FORMAT" == "v2" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      [[ "${BASH_REMATCH[1]}" == "$current_task" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence Task Number must match its step heading."; return 1; }
      current_format="v2"
      ATT_FORMATS[$current_index]="v2"
      expected_stage="step_number"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Step\ Number:\*\*\ ([0-9]+)$ ]]; then
      [[ "$expected_stage" == "step_number" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      [[ "${BASH_REMATCH[1]}" == "$current_step" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence Step Number must match its step heading."; return 1; }
      expected_stage="packet_fingerprint"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Packet\ Fingerprint:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "packet_fingerprint" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      validate_persisted_normalized_text "${BASH_REMATCH[1]}" "Execution evidence Packet Fingerprint may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_PACKET_FINGERPRINTS[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      expected_stage="head_sha"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Head\ SHA:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "head_sha" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      validate_persisted_normalized_text "${BASH_REMATCH[1]}" "Execution evidence Head SHA may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_HEAD_SHAS[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      expected_stage="claim_or_base"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Base\ SHA:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "claim_or_base" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      validate_persisted_normalized_text "${BASH_REMATCH[1]}" "Execution evidence Base SHA may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_BASE_SHAS[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      expected_stage="claim"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Claim:\*\*\ (.+)$ ]]; then
      if [[ "$expected_stage" == "post_source" ]]; then
        current_format="legacy"
        ATT_FORMATS[$current_index]="legacy"
      elif [[ "$expected_stage" != "claim_or_base" && "$expected_stage" != "claim" ]]; then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence fields are out of order."
        return 1
      fi
      validate_persisted_normalized_text \
        "${BASH_REMATCH[1]}" \
        "Execution evidence Claim text may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_CLAIMS[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      expected_stage="files"
    elif [[ -n "$current_index" && "$line" == "**Files:**" ]]; then
      [[ "$expected_stage" == "files" && "$current_format" == "legacy" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      files_lines=()
      while IFS= read -r line <&3; do
        if [[ "$line" =~ ^-\ (.+)$ ]]; then
          validate_persisted_repo_relative_path \
            "${BASH_REMATCH[1]}" \
            "Execution evidence Files bullets must be canonical repo-relative paths." || {
            exec 3<&-
            return 1
          }
          files_lines+=("$PERSISTED_NORMALIZED_PATH")
          continue
        fi
        queued_line="$line"
        have_queued_line=1
        break
      done
      if (( ${#files_lines[@]} == 0 )); then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence Files section must contain at least one bullet."
        return 1
      fi
      ATT_FILES[$current_index]="$(printf '%s\n' "${files_lines[@]}")"
      ATT_FILE_PROOFS[$current_index]="$(for line in "${files_lines[@]}"; do printf '%s\tsha256:unknown\n' "$line"; done)"
      expected_stage="verification"
    elif [[ -n "$current_index" && "$line" == "**Files Proven:**" ]]; then
      [[ "$expected_stage" == "files" && "$current_format" == "v2" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      files_lines=()
      file_proof_lines=()
      while IFS= read -r line <&3; do
        if [[ "$line" =~ ^-\ (.+)\ \|\ (sha256:[A-Za-z0-9]+)$ ]]; then
          validate_persisted_repo_relative_path \
            "${BASH_REMATCH[1]}" \
            "Execution evidence Files Proven bullets must use canonical repo-relative paths." || {
            exec 3<&-
            return 1
          }
          files_lines+=("$PERSISTED_NORMALIZED_PATH")
          file_proof_lines+=("$PERSISTED_NORMALIZED_PATH"$'\t'"${BASH_REMATCH[2]}")
          continue
        fi
        queued_line="$line"
        have_queued_line=1
        break
      done
      if (( ${#files_lines[@]} == 0 )); then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence Files Proven section must contain at least one bullet."
        return 1
      fi
      ATT_FILES[$current_index]="$(printf '%s\n' "${files_lines[@]}")"
      ATT_FILE_PROOFS[$current_index]="$(printf '%s\n' "${file_proof_lines[@]}")"
      expected_stage="verification_summary"
    elif [[ -n "$current_index" && "$line" == "**Verification:**" ]]; then
      [[ "$expected_stage" == "verification" && "$current_format" == "legacy" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      if ! IFS= read -r line <&3; then
        exec 3<&-
        set_failure "MalformedExecutionState" "Execution evidence Verification section is incomplete."
        return 1
      fi
      [[ "$line" =~ ^-\ (.+)$ ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence Verification section must contain exactly one bullet."; return 1; }
      validate_persisted_normalized_text \
        "${BASH_REMATCH[1]}" \
        "Execution evidence Verification text may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_VERIFICATION[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      ATT_VERIFICATION_SUMMARIES[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      if IFS= read -r line <&3; then
        if [[ "$line" =~ ^-\ (.+)$ ]]; then
          exec 3<&-
          set_failure "MalformedExecutionState" "Execution evidence Verification section may not contain more than one bullet."
          return 1
        fi
        queued_line="$line"
        have_queued_line=1
      fi
      expected_stage="invalidation_reason"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Verification\ Summary:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "verification_summary" && "$current_format" == "v2" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      validate_persisted_normalized_text \
        "${BASH_REMATCH[1]}" \
        "Execution evidence Verification Summary text may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_VERIFICATION[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      ATT_VERIFICATION_SUMMARIES[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      expected_stage="invalidation_reason"
    elif [[ -n "$current_index" && "$line" =~ ^\*\*Invalidation\ Reason:\*\*\ (.+)$ ]]; then
      [[ "$expected_stage" == "invalidation_reason" ]] || { exec 3<&-; set_failure "MalformedExecutionState" "Execution evidence fields are out of order."; return 1; }
      validate_persisted_normalized_text \
        "${BASH_REMATCH[1]}" \
        "Execution evidence Invalidation Reason text may not be blank after whitespace normalization." || {
        exec 3<&-
        return 1
      }
      ATT_INVALIDATION_REASONS[$current_index]="$PERSISTED_NORMALIZED_VALUE"
      expected_stage="done"
    elif [[ "$line" =~ ^#\ Execution\ Evidence: ]] || [[ "$line" =~ ^\*\*Plan\ Path:\*\* ]] || [[ "$line" =~ ^\*\*Plan\ Revision:\*\* ]] || [[ "$line" =~ ^\*\*Plan\ Fingerprint:\*\* ]] || [[ "$line" =~ ^\*\*Source\ Spec\ Path:\*\* ]] || [[ "$line" =~ ^\*\*Source\ Spec\ Revision:\*\* ]] || [[ "$line" =~ ^\*\*Source\ Spec\ Fingerprint:\*\* ]] || [[ "$line" == "## Step Evidence" ]]; then
      continue
    else
      exec 3<&-
      set_failure "MalformedExecutionState" "Execution evidence contains unexpected content."
      return 1
    fi
  done
  exec 3<&-

  if [[ -n "$current_index" && "$expected_stage" != "done" ]]; then
    set_failure "MalformedExecutionState" "Execution evidence attempt is incomplete."
    return 1
  fi

  local i
  for ((i=0; i<ATT_COUNT; i++)); do
    case "${ATT_STATUS[$i]}" in
      Completed)
        [[ -n "${ATT_INVALIDATION_REASONS[$i]}" && "${ATT_INVALIDATION_REASONS[$i]}" == "N/A" ]] || {
          set_failure "MalformedExecutionState" "Completed attempts must use 'N/A' as the invalidation reason."
          return 1
        }
        ;;
      Invalidated)
        [[ -n "${ATT_INVALIDATION_REASONS[$i]}" && "${ATT_INVALIDATION_REASONS[$i]}" != "N/A" ]] || {
          set_failure "MalformedExecutionState" "Invalidated attempts must record a non-empty invalidation reason."
          return 1
        }
        ;;
      *)
        set_failure "MalformedExecutionState" "Execution evidence attempts may only be Completed or Invalidated."
        return 1
        ;;
    esac

    [[ -n "${ATT_RECORDED_AT[$i]}" && -n "${ATT_SOURCES[$i]}" && -n "${ATT_CLAIMS[$i]}" && -n "${ATT_FILES[$i]}" && -n "${ATT_VERIFICATION[$i]}" ]] || {
      set_failure "MalformedExecutionState" "Execution evidence attempts must contain every required field."
      return 1
    }

    if [[ "${ATT_FORMATS[$i]}" == "v2" ]]; then
      [[ -n "${ATT_PACKET_FINGERPRINTS[$i]}" && -n "${ATT_HEAD_SHAS[$i]}" && -n "${ATT_FILE_PROOFS[$i]}" && -n "${ATT_VERIFICATION_SUMMARIES[$i]}" ]] || {
        set_failure "MalformedExecutionState" "Execution evidence v2 attempts must contain every required provenance field."
        return 1
      }
    fi
  done

  return 0
}

find_latest_attempt_index() {
  local task="$1"
  local step="$2"
  local latest_index="" latest_num=0 i
  for ((i=0; i<ATT_COUNT; i++)); do
    if [[ "${ATT_TASKS[$i]}" == "$task" && "${ATT_STEPS[$i]}" == "$step" ]]; then
      if (( ${ATT_NUMBERS[$i]} >= latest_num )); then
        latest_num="${ATT_NUMBERS[$i]}"
        latest_index="$i"
      fi
    fi
  done
  if [[ -n "$latest_index" ]]; then
    printf '%s\n' "$latest_index"
    return 0
  fi
  return 1
}

find_latest_completed_attempt_index() {
  local latest_index="" i
  for ((i=0; i<ATT_COUNT; i++)); do
    if [[ "${ATT_STATUS[$i]}" == "Completed" ]]; then
      latest_index="$i"
    fi
  done
  if [[ -n "$latest_index" ]]; then
    printf '%s\n' "$latest_index"
    return 0
  fi
  return 1
}

next_attempt_number() {
  local task="$1"
  local step="$2"
  local latest
  if latest="$(find_latest_attempt_index "$task" "$step" 2>/dev/null)"; then
    printf '%s\n' "$((ATT_NUMBERS[$latest] + 1))"
  else
    printf '1\n'
  fi
}

render_execution_contract_plan() {
  local src="$1"
  local dest="$2"
  local line current_task="" suppress_adjacent=0 step_index title

  while IFS= read -r line || [[ -n "$line" ]]; do
    if (( suppress_adjacent == 1 )); then
      if [[ -z "$line" || "$line" =~ ^[[:space:]]+\*\*Execution\ Note:\*\* ]]; then
        continue
      fi
      suppress_adjacent=0
    fi

    if [[ "$line" =~ ^\*\*Execution\ Mode:\*\*\ (.+)$ ]]; then
      printf '**Execution Mode:** none\n' >> "$dest"
      continue
    fi

    if [[ "$line" =~ ^##\ Task\ ([0-9]+): ]]; then
      current_task="${BASH_REMATCH[1]}"
      printf '%s\n' "$line" >> "$dest"
      continue
    fi

    if [[ "$line" =~ ^-\ \[([[:space:]x])\]\ \*\*Step\ ([0-9]+):\ (.*)\*\*$ ]]; then
      step_index="$(find_step_index "$current_task" "${BASH_REMATCH[2]}")"
      title="${STEP_TITLES[$step_index]}"
      printf -- '- [ ] **Step %s: %s**\n' "${STEP_NUMBERS[$step_index]}" "$title" >> "$dest"
      suppress_adjacent=1
      continue
    fi

    printf '%s\n' "$line" >> "$dest"
  done < "$src"
}

hash_execution_contract_plan() {
  local src="$1"
  local tmp="" plan_fingerprint=""

  tmp="$(mktemp "${src}.contract.XXXXXX")" || return 1
  render_execution_contract_plan "$src" "$tmp" || {
    rm -f "$tmp"
    return 1
  }
  plan_fingerprint="$(hash_file "$tmp")" || {
    rm -f "$tmp"
    return 1
  }
  rm -f "$tmp"
  printf '%s\n' "$plan_fingerprint"
}

compute_execution_packet_fingerprint_from_values() {
  local plan_path="$1"
  local plan_revision="$2"
  local plan_fingerprint="$3"
  local source_spec_path="$4"
  local source_spec_revision="$5"
  local source_spec_fingerprint="$6"
  local task="$7"
  local step="$8"

  {
    printf 'plan_path=%s\n' "$plan_path"
    printf 'plan_revision=%s\n' "$plan_revision"
    printf 'plan_fingerprint=%s\n' "$plan_fingerprint"
    printf 'source_spec_path=%s\n' "$source_spec_path"
    printf 'source_spec_revision=%s\n' "$source_spec_revision"
    printf 'source_spec_fingerprint=%s\n' "$source_spec_fingerprint"
    printf 'task_number=%s\n' "$task"
    printf 'step_number=%s\n' "$step"
  } | hash_stream
}

compute_current_execution_packet_fingerprint() {
  local task="$1"
  local step="$2"
  local plan_fingerprint source_spec_fingerprint source_spec_abs

  plan_fingerprint="$(hash_execution_contract_plan "$PLAN_ABS_PATH")" || return 1
  source_spec_abs="$(plan_rel_to_abs "$PLAN_SOURCE_SPEC")"
  source_spec_fingerprint="$(hash_file "$source_spec_abs")" || return 1

  compute_execution_packet_fingerprint_from_values \
    "$PLAN_REL_PATH" \
    "$PLAN_REVISION" \
    "$plan_fingerprint" \
    "$PLAN_SOURCE_SPEC" \
    "$PLAN_SOURCE_SPEC_REVISION" \
    "$source_spec_fingerprint" \
    "$task" \
    "$step"
}

compute_pending_execution_packet_fingerprint() {
  local task="$1"
  local step="$2"
  compute_current_execution_packet_fingerprint "$task" "$step"
}

current_head_sha() {
  git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null || true
}

current_base_sha() {
  git -C "$REPO_ROOT" rev-list --max-parents=0 HEAD 2>/dev/null | tail -n1 || true
}

build_files_proven_entry() {
  local files_entry="$1"
  local path digest
  local entries=()

  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    if [[ "$path" == "$NO_REPO_FILES_MARKER" ]]; then
      entries+=("$path"$'\t'"sha256:none")
      continue
    fi
    if [[ -e "$REPO_ROOT/$path" || -L "$REPO_ROOT/$path" ]]; then
      digest="$(hash_file "$REPO_ROOT/$path")" || {
        set_failure "EvidenceWriteFailed" "Could not fingerprint a proven file."
        return 1
      }
      entries+=("$path"$'\t'"sha256:$digest")
    else
      entries+=("$path"$'\t'"sha256:missing")
    fi
  done <<< "$files_entry"

  FILES_PROVEN_ENTRY="$(printf '%s\n' "${entries[@]}")"
  return 0
}

append_attempt() {
  local task="$1"
  local step="$2"
  local source="$3"
  local claim="$4"
  local files_entry="$5"
  local verification_entry="$6"
  local packet_fingerprint="$7"
  local head_sha="$8"
  local base_sha="$9"
  local files_proven_entry="${10}"
  local number recorded_at

  number="$(next_attempt_number "$task" "$step")"
  recorded_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  push_attempt "$task" "$step" "$number"
  ATT_FORMATS[$((ATT_COUNT - 1))]="v2"
  ATT_STATUS[$((ATT_COUNT - 1))]="Completed"
  ATT_RECORDED_AT[$((ATT_COUNT - 1))]="$recorded_at"
  ATT_SOURCES[$((ATT_COUNT - 1))]="$source"
  ATT_PACKET_FINGERPRINTS[$((ATT_COUNT - 1))]="$packet_fingerprint"
  ATT_HEAD_SHAS[$((ATT_COUNT - 1))]="$head_sha"
  ATT_BASE_SHAS[$((ATT_COUNT - 1))]="$base_sha"
  ATT_CLAIMS[$((ATT_COUNT - 1))]="$claim"
  ATT_FILES[$((ATT_COUNT - 1))]="$files_entry"
  ATT_FILE_PROOFS[$((ATT_COUNT - 1))]="$files_proven_entry"
  ATT_VERIFICATION[$((ATT_COUNT - 1))]="$verification_entry"
  ATT_VERIFICATION_SUMMARIES[$((ATT_COUNT - 1))]="$verification_entry"
  ATT_INVALIDATION_REASONS[$((ATT_COUNT - 1))]="N/A"
}

invalidate_attempt() {
  local attempt_index="$1"
  local source="$2"
  local reason="$3"
  local recorded_at

  recorded_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  ATT_STATUS[$attempt_index]="Invalidated"
  ATT_RECORDED_AT[$attempt_index]="$recorded_at"
  ATT_SOURCES[$attempt_index]="$source"
  ATT_INVALIDATION_REASONS[$attempt_index]="$(normalize_whitespace "$reason")"
}

render_evidence_file() {
  local dest="$1"
  local plan_fingerprint="$2"
  local source_spec_fingerprint="$3"
  local topic base i j
  local wrote_section=0
  base="$(basename "$PLAN_REL_PATH" .md)"
  topic="$base"

  {
    printf '# Execution Evidence: %s\n\n' "$topic"
    printf '**Plan Path:** %s\n' "$PLAN_REL_PATH"
    printf '**Plan Revision:** %s\n' "$PLAN_REVISION"
    printf '**Plan Fingerprint:** %s\n' "$plan_fingerprint"
    printf '**Source Spec Path:** %s\n' "$PLAN_SOURCE_SPEC"
    printf '**Source Spec Revision:** %s\n' "$PLAN_SOURCE_SPEC_REVISION"
    printf '**Source Spec Fingerprint:** %s\n\n' "$source_spec_fingerprint"
    printf '## Step Evidence\n'

    if (( ATT_COUNT > 0 )); then
      printf '\n'
    fi

    for ((i=0; i<STEP_COUNT; i++)); do
      local task step has_attempt=0 attempt_in_section=0
      task="${STEP_TASKS[$i]}"
      step="${STEP_NUMBERS[$i]}"
      for ((j=0; j<ATT_COUNT; j++)); do
        if [[ "${ATT_TASKS[$j]}" == "$task" && "${ATT_STEPS[$j]}" == "$step" ]]; then
          if (( has_attempt == 0 )); then
            if (( wrote_section == 1 )); then
              printf '\n'
            fi
            printf '### Task %s Step %s\n' "$task" "$step"
            has_attempt=1
            wrote_section=1
          fi
          if (( attempt_in_section > 0 )); then
            printf '\n'
          fi
          printf '#### Attempt %s\n' "${ATT_NUMBERS[$j]}"
          printf '**Status:** %s\n' "${ATT_STATUS[$j]}"
          printf '**Recorded At:** %s\n' "${ATT_RECORDED_AT[$j]}"
          printf '**Execution Source:** %s\n' "${ATT_SOURCES[$j]}"
          printf '**Task Number:** %s\n' "$task"
          printf '**Step Number:** %s\n' "$step"
          printf '**Packet Fingerprint:** %s\n' "${ATT_PACKET_FINGERPRINTS[$j]:-unknown}"
          printf '**Head SHA:** %s\n' "${ATT_HEAD_SHAS[$j]:-unknown}"
          if [[ -n "${ATT_BASE_SHAS[$j]}" ]]; then
            printf '**Base SHA:** %s\n' "${ATT_BASE_SHAS[$j]}"
          fi
          printf '**Claim:** %s\n' "${ATT_CLAIMS[$j]}"
          printf '**Files Proven:**\n'
          while IFS=$'\t' read -r file_entry file_proof; do
            [[ -n "$file_entry" ]] || continue
            printf -- '- %s | %s\n' "$file_entry" "${file_proof:-sha256:unknown}"
          done <<< "${ATT_FILE_PROOFS[$j]}"
          printf '**Verification Summary:** %s\n' "${ATT_VERIFICATION_SUMMARIES[$j]:-${ATT_VERIFICATION[$j]}}"
          printf '**Invalidation Reason:** %s\n' "${ATT_INVALIDATION_REASONS[$j]}"
          attempt_in_section=$((attempt_in_section + 1))
        fi
      done
    done
  } > "$dest"
}

find_step_or_fail() {
  local task="$1"
  local step="$2"
  local index
  if ! index="$(find_step_index "$task" "$step" 2>/dev/null)"; then
    set_failure "InvalidStepTransition" "Requested task/step does not exist in the approved plan."
    return 1
  fi
  STEP_INDEX_FOUND="$index"
  return 0
}

render_plan_file() {
  local src="$1"
  local dest="$2"
  local line current_task="" suppress_adjacent=0 note_state note_summary step_index mark title

  while IFS= read -r line || [[ -n "$line" ]]; do
    if (( suppress_adjacent == 1 )); then
      if [[ -z "$line" || "$line" =~ ^[[:space:]]+\*\*Execution\ Note:\*\* ]]; then
        continue
      fi
      suppress_adjacent=0
    fi

    if [[ "$line" =~ ^\*\*Execution\ Mode:\*\*\ (.+)$ ]]; then
      printf '**Execution Mode:** %s\n' "$PLAN_EXECUTION_MODE" >> "$dest"
      continue
    fi

    if [[ "$line" =~ ^##\ Task\ ([0-9]+): ]]; then
      current_task="${BASH_REMATCH[1]}"
      printf '%s\n' "$line" >> "$dest"
      continue
    fi

    if [[ "$line" =~ ^-\ \[([[:space:]x])\]\ \*\*Step\ ([0-9]+):\ (.*)\*\*$ ]]; then
      step_index="$(find_step_index "$current_task" "${BASH_REMATCH[2]}")"
      mark=' '
      [[ "${STEP_CHECKED[$step_index]}" == "x" ]] && mark='x'
      title="${STEP_TITLES[$step_index]}"
      printf -- '- [%s] **Step %s: %s**\n' "$mark" "${STEP_NUMBERS[$step_index]}" "$title" >> "$dest"
      note_state="${STEP_NOTE_STATES[$step_index]}"
      note_summary="${STEP_NOTE_SUMMARIES[$step_index]}"
      if [[ -n "$note_state" ]]; then
        printf '\n  **Execution Note:** %s - %s\n' "$note_state" "$note_summary" >> "$dest"
      fi
      suppress_adjacent=1
      continue
    fi

    printf '%s\n' "$line" >> "$dest"
  done < "$src"
}

commit_plan_only() {
  local operation="$1"
  local plan_tmp plan_backup
  plan_tmp="$(mktemp "${PLAN_ABS_PATH}.tmp.XXXXXX")"
  plan_backup="$(mktemp "${PLAN_ABS_PATH}.bak.XXXXXX")"
  cp "$PLAN_ABS_PATH" "$plan_backup"
  render_plan_file "$PLAN_ABS_PATH" "$plan_tmp"

  if [[ "${SUPERPOWERS_PLAN_EXECUTION_TEST_FAILPOINT:-}" == "${operation}_after_plan_write" ]]; then
    rm -f "$plan_tmp" "$plan_backup"
    set_failure "EvidenceWriteFailed" "Injected write failure during ${operation}."
    return 1
  fi

  if ! mv "$plan_tmp" "$PLAN_ABS_PATH"; then
    cp "$plan_backup" "$PLAN_ABS_PATH"
    rm -f "$plan_tmp" "$plan_backup"
    set_failure "EvidenceWriteFailed" "Could not persist the plan mutation."
    return 1
  fi
  rm -f "$plan_backup"
  return 0
}

commit_plan_and_evidence() {
  local operation="$1"
  local plan_tmp plan_backup evidence_tmp evidence_backup=""
  local plan_fingerprint source_spec_fingerprint source_spec_abs
  mkdir -p "$(dirname "$EVIDENCE_ABS_PATH")"
  plan_tmp="$(mktemp "${PLAN_ABS_PATH}.tmp.XXXXXX")"
  evidence_tmp="$(mktemp "${EVIDENCE_ABS_PATH}.tmp.XXXXXX")"
  plan_backup="$(mktemp "${PLAN_ABS_PATH}.bak.XXXXXX")"
  cp "$PLAN_ABS_PATH" "$plan_backup"
  if [[ -f "$EVIDENCE_ABS_PATH" ]]; then
    evidence_backup="$(mktemp "${EVIDENCE_ABS_PATH}.bak.XXXXXX")"
    cp "$EVIDENCE_ABS_PATH" "$evidence_backup"
  fi

  render_plan_file "$PLAN_ABS_PATH" "$plan_tmp"
  plan_fingerprint="$(hash_file "$plan_tmp")" || {
    rm -f "$plan_tmp" "$evidence_tmp" "$plan_backup" "$evidence_backup"
    set_failure "EvidenceWriteFailed" "Could not fingerprint the mutated approved plan."
    return 1
  }
  source_spec_abs="$(plan_rel_to_abs "$PLAN_SOURCE_SPEC")"
  source_spec_fingerprint="$(hash_file "$source_spec_abs")" || {
    rm -f "$plan_tmp" "$evidence_tmp" "$plan_backup" "$evidence_backup"
    set_failure "EvidenceWriteFailed" "Could not fingerprint the approved source spec."
    return 1
  }
  render_evidence_file "$evidence_tmp" "$plan_fingerprint" "$source_spec_fingerprint"

  if [[ "${SUPERPOWERS_PLAN_EXECUTION_TEST_FAILPOINT:-}" == "${operation}_after_plan_write" ]]; then
    rm -f "$plan_tmp" "$evidence_tmp" "$plan_backup" "$evidence_backup"
    set_failure "EvidenceWriteFailed" "Injected write failure during ${operation}."
    return 1
  fi

  if ! mv "$evidence_tmp" "$EVIDENCE_ABS_PATH"; then
    cp "$plan_backup" "$PLAN_ABS_PATH"
    rm -f "$plan_tmp" "$evidence_tmp" "$plan_backup" "$evidence_backup"
    set_failure "EvidenceWriteFailed" "Could not persist the evidence mutation."
    return 1
  fi

  if ! mv "$plan_tmp" "$PLAN_ABS_PATH"; then
    cp "$plan_backup" "$PLAN_ABS_PATH"
    if [[ -n "$evidence_backup" ]]; then
      cp "$evidence_backup" "$EVIDENCE_ABS_PATH"
    else
      rm -f "$EVIDENCE_ABS_PATH"
    fi
    rm -f "$plan_tmp" "$evidence_tmp" "$plan_backup" "$evidence_backup"
    set_failure "EvidenceWriteFailed" "Could not persist the plan mutation."
    return 1
  fi

  rm -f "$plan_backup" "$evidence_backup"
  return 0
}

load_execution_state() {
  local plan_rel="$1"
  local plan_abs evidence_rel evidence_abs

  LOAD_ERROR_CLASS=""
  LOAD_ERROR_MESSAGE=""

  PLAN_REL_PATH="$(normalize_repo_relative_path "$plan_rel")" || {
    set_failure "InvalidCommandInput" "Plan path must be a normalized repo-relative path."
    return 1
  }
  case "$PLAN_REL_PATH" in
    docs/superpowers/plans/*) ;;
    *)
      set_failure "InvalidCommandInput" "Plan path must live under docs/superpowers/plans/."
      return 1
      ;;
  esac

  plan_abs="$(plan_rel_to_abs "$PLAN_REL_PATH")"
  if [[ ! -f "$plan_abs" ]]; then
    set_failure "InvalidCommandInput" "Approved plan file does not exist."
    return 1
  fi

  parse_plan_file "$plan_abs" || return 1

  if [[ "$PLAN_WORKFLOW_STATE" != "Engineering Approved" ]]; then
    set_failure "PlanNotExecutionReady" "Plan is not Engineering Approved."
    return 1
  fi
  if [[ -z "$PLAN_REVISION" ]]; then
    set_failure "PlanNotExecutionReady" "Plan Revision header is missing or malformed."
    return 1
  fi
  case "$PLAN_EXECUTION_MODE" in
    none|superpowers:executing-plans|superpowers:subagent-driven-development) ;;
    *)
      set_failure "PlanNotExecutionReady" "Execution Mode header is missing, malformed, or out of range."
      return 1
      ;;
  esac
  if [[ -z "$PLAN_SOURCE_SPEC" || -z "$PLAN_SOURCE_SPEC_REVISION" ]]; then
    set_failure "PlanNotExecutionReady" "Approved plan source spec headers are missing or malformed."
    return 1
  fi
  PLAN_LAST_REVIEWED_BY="$(normalize_whitespace "$PLAN_LAST_REVIEWED_BY")"
  case "$PLAN_LAST_REVIEWED_BY" in
    writing-plans|plan-eng-review) ;;
    *)
      set_failure "PlanNotExecutionReady" "Approved plan Last Reviewed By header is missing or malformed."
      return 1
      ;;
  esac

  validate_source_spec "$PLAN_SOURCE_SPEC" "$PLAN_SOURCE_SPEC_REVISION" || return 1

  evidence_rel="$(derive_evidence_rel_path "$PLAN_REL_PATH" "$PLAN_REVISION")"
  evidence_abs="$(plan_rel_to_abs "$evidence_rel")"
  EVIDENCE_REL_PATH="$evidence_rel"
  EVIDENCE_ABS_PATH="$evidence_abs"
  parse_evidence_file "$evidence_abs" "$PLAN_REL_PATH" "$PLAN_REVISION" || return 1
  parse_evidence_attempts || return 1

  if [[ "$PLAN_EXECUTION_MODE" == "none" ]]; then
    if (( EVIDENCE_ATTEMPT_COUNT > 0 )); then
      set_failure "MalformedExecutionState" "Execution evidence history cannot exist while Execution Mode is none."
      return 1
    fi
    if (( PLAN_CHECKED_COUNT > 0 || PLAN_NOTE_COUNT > 0 )); then
      set_failure "PlanNotExecutionReady" "Newly approved plan revisions must start execution-clean."
      return 1
    fi
  fi

  if [[ "$PLAN_EXECUTION_MODE" == "none" ]]; then
    EXECUTION_STARTED="no"
  else
    EXECUTION_STARTED="yes"
  fi
  if (( PLAN_CHECKED_COUNT > 0 || PLAN_NOTE_COUNT > 0 || EVIDENCE_ATTEMPT_COUNT > 0 )); then
    EXECUTION_STARTED="yes"
  fi

  EXECUTION_FINGERPRINT="$(compute_execution_fingerprint "$plan_abs" "$evidence_abs")"
  PLAN_ABS_PATH="$plan_abs"
  return 0
}

print_status_json() {
  local latest_completed=""
  local latest_packet="null"
  local latest_head="null"
  local latest_base="null"
  local -a warning_codes=()

  if [[ "$EVIDENCE_FORMAT" == "legacy" && "$EVIDENCE_ATTEMPT_COUNT" -gt 0 ]]; then
    warning_codes+=("legacy_evidence_format")
  fi
  if latest_completed="$(find_latest_completed_attempt_index 2>/dev/null)"; then
    [[ -n "${ATT_PACKET_FINGERPRINTS[$latest_completed]:-}" ]] && latest_packet="\"$(json_escape "${ATT_PACKET_FINGERPRINTS[$latest_completed]}")\""
    [[ -n "${ATT_HEAD_SHAS[$latest_completed]:-}" ]] && latest_head="\"$(json_escape "${ATT_HEAD_SHAS[$latest_completed]}")\""
    [[ -n "${ATT_BASE_SHAS[$latest_completed]:-}" ]] && latest_base="\"$(json_escape "${ATT_BASE_SHAS[$latest_completed]}")\""
  fi

  printf '{'
  printf '"plan_revision":%s,' "$PLAN_REVISION"
  printf '"execution_mode":"%s",' "$(json_escape "$PLAN_EXECUTION_MODE")"
  printf '"execution_fingerprint":"%s",' "$(json_escape "$EXECUTION_FINGERPRINT")"
  printf '"evidence_path":"%s",' "$(json_escape "$EVIDENCE_REL_PATH")"
  printf '"execution_started":"%s",' "$(json_escape "$EXECUTION_STARTED")"
  printf '"warning_codes":'
  emit_string_array_json "${warning_codes[@]:-}"
  printf ','
  printf '"latest_packet_fingerprint":%s,' "$latest_packet"
  printf '"latest_head_sha":%s,' "$latest_head"
  printf '"latest_base_sha":%s,' "$latest_base"
  printf '"active_task":%s,' "$PLAN_ACTIVE_TASK"
  printf '"active_step":%s,' "$PLAN_ACTIVE_STEP"
  printf '"blocking_task":%s,' "$PLAN_BLOCKING_TASK"
  printf '"blocking_step":%s,' "$PLAN_BLOCKING_STEP"
  printf '"resume_task":%s,' "$PLAN_RESUME_TASK"
  printf '"resume_step":%s' "$PLAN_RESUME_STEP"
  printf '}\n'
}

run_status_with_plan() {
  local plan_rel="$1"
  local cache_path=""
  local output=""

  cache_path="$(plan_execution_status_cache_path "$plan_rel" 2>/dev/null || true)"
  if [[ -n "$cache_path" ]] && output="$(read_cached_status_output "$cache_path" 2>/dev/null)"; then
    printf '%s\n' "$output"
    return 0
  fi

  load_execution_state "$plan_rel" || {
    emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
    return 1
  }
  output="$(print_status_json)"
  [[ -n "$cache_path" ]] && write_cached_status_output "$cache_path" "$output"
  printf '%s\n' "$output"
}

git_path_exists() {
  local git_path=""
  git_path="$(git -C "$REPO_ROOT" rev-parse --git-path "$1" 2>/dev/null || true)"
  [[ -n "$git_path" && -e "$git_path" ]]
}

validate_workspace_safety() {
  if ! git -C "$REPO_ROOT" symbolic-ref -q HEAD >/dev/null 2>&1; then
    gate_fail "WorkspaceNotSafe" "detached_head" "Execution preflight requires a branch-based workspace." "Check out a branch before continuing execution."
  fi
  if git_path_exists MERGE_HEAD; then
    gate_fail "WorkspaceNotSafe" "merge_in_progress" "Execution preflight does not allow an in-progress merge." "Resolve or abort the merge before continuing."
  fi
  if git_path_exists rebase-merge || git_path_exists rebase-apply; then
    gate_fail "WorkspaceNotSafe" "rebase_in_progress" "Execution preflight does not allow an in-progress rebase." "Resolve or abort the rebase before continuing."
  fi
  if git_path_exists CHERRY_PICK_HEAD; then
    gate_fail "WorkspaceNotSafe" "cherry_pick_in_progress" "Execution preflight does not allow an in-progress cherry-pick." "Resolve or abort the cherry-pick before continuing."
  fi
  if [[ -n "$(git -C "$REPO_ROOT" diff --name-only --diff-filter=U 2>/dev/null || true)" ]]; then
    gate_fail "WorkspaceNotSafe" "unresolved_index_entries" "Execution preflight does not allow unresolved index entries." "Resolve index conflicts before continuing."
  fi
}

validate_repo_safety_applicability() {
  local stage="superpowers:plan-execution-preflight"
  local output=""
  local status=0
  local outcome=""

  if [[ "$PLAN_EXECUTION_MODE" != "none" ]]; then
    stage="$PLAN_EXECUTION_MODE"
  fi

  output="$(
    cd "$REPO_ROOT" &&
      "$SCRIPT_DIR/superpowers-repo-safety" check \
        --intent write \
        --stage "$stage" \
        --task-id "plan-execution-preflight-r${PLAN_REVISION}" \
        --path "$PLAN_REL_PATH" \
        --write-target execution-task-slice
  )" || status=$?

  if [[ "$status" -ne 0 || -z "$output" ]]; then
    gate_fail "WorkspaceNotSafe" "repo_safety_unavailable" "Execution preflight could not evaluate repo-safety applicability." "Restore repo-safety helper availability before continuing execution."
    return 1
  fi

  outcome="$(json_string_field "$output" "outcome")"
  case "$outcome" in
    allowed|blocked)
      return 0
      ;;
    *)
      gate_fail "WorkspaceNotSafe" "repo_safety_unavailable" "Execution preflight could not parse repo-safety applicability." "Restore repo-safety helper availability before continuing execution."
      return 1
      ;;
  esac
}

load_failure_as_gate_failure() {
  local fallback_class="$1"
  local code
  code="$(camel_to_snake "${LOAD_ERROR_CLASS:-$fallback_class}")"
  gate_fail "${LOAD_ERROR_CLASS:-$fallback_class}" "$code" "${LOAD_ERROR_MESSAGE:-Execution state could not be loaded.}" "Fix the execution state before continuing."
}

validate_checked_steps_have_evidence() {
  local i latest_attempt
  for ((i=0; i<STEP_COUNT; i++)); do
    [[ "${STEP_CHECKED[$i]}" == "x" ]] || continue
    if ! latest_attempt="$(find_latest_attempt_index "${STEP_TASKS[$i]}" "${STEP_NUMBERS[$i]}" 2>/dev/null)"; then
      gate_fail "StaleExecutionEvidence" "checked_step_missing_evidence" "A checked plan step is missing execution evidence." "Reopen the step or record matching execution evidence."
      return 1
    fi
    if [[ "${ATT_STATUS[$latest_attempt]}" != "Completed" ]]; then
      gate_fail "StaleExecutionEvidence" "checked_step_missing_evidence" "A checked plan step no longer has a completed evidence attempt." "Reopen the step or complete it again with fresh evidence."
      return 1
    fi
  done
  return 0
}

validate_all_steps_completed_for_review() {
  local i
  local task=""
  local step=""

  for ((i=0; i<STEP_COUNT; i++)); do
    [[ "${STEP_CHECKED[$i]}" == "x" ]] && continue
    task="${STEP_TASKS[$i]}"
    step="${STEP_NUMBERS[$i]}"
    gate_fail "ExecutionStateNotReady" "unfinished_steps_remaining" "Final review is blocked while Task ${task} Step ${step} remains unchecked." "Finish all approved plan steps before final review or branch completion."
    return 1
  done

  return 0
}

proof_path_is_execution_bookkeeping() {
  local path="$1"
  [[ "$path" == "$PLAN_REL_PATH" || "$path" == "$EVIDENCE_REL_PATH" || "$path" == "$NO_REPO_FILES_MARKER" ]]
}

reset_latest_completed_step_attempts() {
  LATEST_COMPLETED_STEP_ATTEMPT_COUNT=0
  LATEST_COMPLETED_STEP_ATTEMPTS=()
}

collect_latest_completed_step_attempts() {
  local i latest_attempt

  reset_latest_completed_step_attempts
  for ((i=0; i<STEP_COUNT; i++)); do
    latest_attempt="$(find_latest_attempt_index "${STEP_TASKS[$i]}" "${STEP_NUMBERS[$i]}" 2>/dev/null)" || continue
    [[ "${ATT_STATUS[$latest_attempt]}" == "Completed" ]] || continue
    LATEST_COMPLETED_STEP_ATTEMPTS[$LATEST_COMPLETED_STEP_ATTEMPT_COUNT]="$latest_attempt"
    LATEST_COMPLETED_STEP_ATTEMPT_COUNT=$((LATEST_COMPLETED_STEP_ATTEMPT_COUNT + 1))
  done
}

reset_latest_completed_file_proofs() {
  LATEST_COMPLETED_FILE_PROOF_COUNT=0
  LATEST_COMPLETED_FILE_PROOF_PATHS=()
  LATEST_COMPLETED_FILE_PROOF_VALUES=()
  LATEST_COMPLETED_FILE_PROOF_RECORDED_AT=()
  LATEST_COMPLETED_FILE_PROOF_ORDERS=()
}

remember_latest_completed_file_proof() {
  local path="$1"
  local proof="$2"
  local recorded_at="$3"
  local order="$4"
  local i

  for ((i=0; i<LATEST_COMPLETED_FILE_PROOF_COUNT; i++)); do
    [[ "${LATEST_COMPLETED_FILE_PROOF_PATHS[$i]}" == "$path" ]] || continue
    if [[ "$recorded_at" > "${LATEST_COMPLETED_FILE_PROOF_RECORDED_AT[$i]}" ]] || [[ "$recorded_at" == "${LATEST_COMPLETED_FILE_PROOF_RECORDED_AT[$i]}" && "$order" -gt "${LATEST_COMPLETED_FILE_PROOF_ORDERS[$i]}" ]]; then
      LATEST_COMPLETED_FILE_PROOF_VALUES[$i]="$proof"
      LATEST_COMPLETED_FILE_PROOF_RECORDED_AT[$i]="$recorded_at"
      LATEST_COMPLETED_FILE_PROOF_ORDERS[$i]="$order"
    fi
    return 0
  done

  LATEST_COMPLETED_FILE_PROOF_PATHS[$LATEST_COMPLETED_FILE_PROOF_COUNT]="$path"
  LATEST_COMPLETED_FILE_PROOF_VALUES[$LATEST_COMPLETED_FILE_PROOF_COUNT]="$proof"
  LATEST_COMPLETED_FILE_PROOF_RECORDED_AT[$LATEST_COMPLETED_FILE_PROOF_COUNT]="$recorded_at"
  LATEST_COMPLETED_FILE_PROOF_ORDERS[$LATEST_COMPLETED_FILE_PROOF_COUNT]="$order"
  LATEST_COMPLETED_FILE_PROOF_COUNT=$((LATEST_COMPLETED_FILE_PROOF_COUNT + 1))
}

collect_latest_completed_file_proofs() {
  local i latest_attempt path proof

  reset_latest_completed_file_proofs
  for ((i=0; i<LATEST_COMPLETED_STEP_ATTEMPT_COUNT; i++)); do
    latest_attempt="${LATEST_COMPLETED_STEP_ATTEMPTS[$i]}"
    while IFS=$'\t' read -r path proof; do
      [[ -n "$path" ]] || continue
      proof_path_is_execution_bookkeeping "$path" && continue
      remember_latest_completed_file_proof "$path" "$proof" "${ATT_RECORDED_AT[$latest_attempt]}" "$latest_attempt"
    done <<< "${ATT_FILE_PROOFS[$latest_attempt]}"
  done
}

reset_current_file_proof_cache() {
  CURRENT_FILE_PROOF_CACHE_COUNT=0
  CURRENT_FILE_PROOF_CACHE_PATHS=()
  CURRENT_FILE_PROOF_CACHE_VALUES=()
}

lookup_current_file_proof_cache() {
  local path="$1"
  local i

  for ((i=0; i<CURRENT_FILE_PROOF_CACHE_COUNT; i++)); do
    if [[ "${CURRENT_FILE_PROOF_CACHE_PATHS[$i]}" == "$path" ]]; then
      CURRENT_FILE_PROOF="${CURRENT_FILE_PROOF_CACHE_VALUES[$i]}"
      return 0
    fi
  done
  return 1
}

cache_current_file_proof() {
  local path="$1"
  local proof="$2"

  CURRENT_FILE_PROOF_CACHE_PATHS[$CURRENT_FILE_PROOF_CACHE_COUNT]="$path"
  CURRENT_FILE_PROOF_CACHE_VALUES[$CURRENT_FILE_PROOF_CACHE_COUNT]="$proof"
  CURRENT_FILE_PROOF_CACHE_COUNT=$((CURRENT_FILE_PROOF_CACHE_COUNT + 1))
}

current_file_proof_for_path() {
  local path="$1"
  local actual=""

  if lookup_current_file_proof_cache "$path"; then
    return 0
  fi

  if [[ -e "$REPO_ROOT/$path" || -L "$REPO_ROOT/$path" ]]; then
    actual="$(hash_file "$REPO_ROOT/$path")" || return 1
    CURRENT_FILE_PROOF="sha256:$actual"
  else
    CURRENT_FILE_PROOF="sha256:missing"
  fi
  cache_current_file_proof "$path" "$CURRENT_FILE_PROOF"
  return 0
}

validate_v2_evidence_provenance() {
  local current_plan_fingerprint current_contract_plan_fingerprint current_source_spec_fingerprint source_spec_abs
  local i latest_attempt expected_packet legacy_expected_packet path proof

  [[ "$EVIDENCE_FORMAT" == "v2" ]] || return 0

  current_plan_fingerprint="$(hash_file "$PLAN_ABS_PATH")" || {
    gate_fail "StaleExecutionEvidence" "plan_fingerprint_unavailable" "Current plan fingerprint could not be computed." "Re-run after the approved plan is readable."
    return 1
  }
  source_spec_abs="$(plan_rel_to_abs "$PLAN_SOURCE_SPEC")"
  current_source_spec_fingerprint="$(hash_file "$source_spec_abs")" || {
    gate_fail "StaleExecutionEvidence" "source_spec_fingerprint_unavailable" "Current source spec fingerprint could not be computed." "Re-run after the approved source spec is readable."
    return 1
  }
  current_contract_plan_fingerprint="$(hash_execution_contract_plan "$PLAN_ABS_PATH")" || {
    gate_fail "StaleExecutionEvidence" "packet_fingerprint_unavailable" "Current packet provenance could not be derived." "Rebuild the current task packet before review."
    return 1
  }
  CURRENT_SOURCE_SPEC_FINGERPRINT_FOR_GATE="$current_source_spec_fingerprint"

  if [[ "$EVIDENCE_PLAN_FINGERPRINT" != "$current_plan_fingerprint" ]]; then
    gate_fail "StaleExecutionEvidence" "plan_fingerprint_mismatch" "Execution evidence no longer matches the current approved plan fingerprint." "Rebuild packets or reopen the affected work."
    return 1
  fi
  if [[ "$EVIDENCE_SOURCE_SPEC_PATH" != "$PLAN_SOURCE_SPEC" || "$EVIDENCE_SOURCE_SPEC_REVISION" != "$PLAN_SOURCE_SPEC_REVISION" || "$EVIDENCE_SOURCE_SPEC_FINGERPRINT" != "$current_source_spec_fingerprint" ]]; then
    gate_fail "StaleExecutionEvidence" "source_spec_fingerprint_mismatch" "Execution evidence no longer matches the current approved source spec provenance." "Rebuild packets or reopen the affected work."
    return 1
  fi

  collect_latest_completed_step_attempts
  for ((i=0; i<LATEST_COMPLETED_STEP_ATTEMPT_COUNT; i++)); do
    latest_attempt="${LATEST_COMPLETED_STEP_ATTEMPTS[$i]}"
    expected_packet="$(compute_execution_packet_fingerprint_from_values \
      "$PLAN_REL_PATH" \
      "$PLAN_REVISION" \
      "$current_contract_plan_fingerprint" \
      "$PLAN_SOURCE_SPEC" \
      "$PLAN_SOURCE_SPEC_REVISION" \
      "$current_source_spec_fingerprint" \
      "${ATT_TASKS[$latest_attempt]}" \
      "${ATT_STEPS[$latest_attempt]}")"
    if [[ "${ATT_PACKET_FINGERPRINTS[$latest_attempt]}" == "$expected_packet" ]]; then
      continue
    fi
    legacy_expected_packet="$(compute_execution_packet_fingerprint_from_values \
      "$PLAN_REL_PATH" \
      "$PLAN_REVISION" \
      "$current_plan_fingerprint" \
      "$PLAN_SOURCE_SPEC" \
      "$PLAN_SOURCE_SPEC_REVISION" \
      "$current_source_spec_fingerprint" \
      "${ATT_TASKS[$latest_attempt]}" \
      "${ATT_STEPS[$latest_attempt]}")"
    if [[ -n "$legacy_expected_packet" && "${ATT_PACKET_FINGERPRINTS[$latest_attempt]}" == "$legacy_expected_packet" ]]; then
      gate_add_warning_code "legacy_packet_provenance"
      continue
    fi
      gate_fail "StaleExecutionEvidence" "packet_fingerprint_mismatch" "Execution evidence packet provenance no longer matches the current approved plan/spec pair." "Rebuild the packet and reopen the affected step."
      return 1
  done

  collect_latest_completed_file_proofs
  reset_current_file_proof_cache
  for ((i=0; i<LATEST_COMPLETED_FILE_PROOF_COUNT; i++)); do
    path="${LATEST_COMPLETED_FILE_PROOF_PATHS[$i]}"
    proof="${LATEST_COMPLETED_FILE_PROOF_VALUES[$i]}"
    current_file_proof_for_path "$path" || {
        gate_fail "MissedReopenRequired" "files_proven_drifted" "A proven file could not be re-fingerprinted during review gating." "Reopen the step and rebuild its evidence."
        return 1
      }
    if [[ "$CURRENT_FILE_PROOF" == "$proof" ]]; then
      continue
    fi
    if [[ "$proof" == "sha256:missing" ]]; then
      gate_fail "MissedReopenRequired" "files_proven_drifted" "A file proven as missing is present again after completion." "Reopen the step and rebuild its evidence."
      return 1
    fi
    if [[ "$CURRENT_FILE_PROOF" == "sha256:missing" ]]; then
      gate_fail "MissedReopenRequired" "files_proven_drifted" "A proven file is now missing after completion." "Reopen the step and rebuild its evidence."
      return 1
    fi
    gate_fail "MissedReopenRequired" "files_proven_drifted" "A proven file changed after completion without a later completed proof." "Reopen the step and rebuild its evidence."
    return 1
  done

  return 0
}

validate_finish_artifacts() {
  local current_head current_base_branch release_artifact_path qa_artifact_path test_plan_artifact_path expected_test_plan_path
  local test_plan_required="no"

  load_project_artifact_context
  current_head="$(current_head_sha)"
  current_base_branch="$(current_base_branch_name 2>/dev/null || true)"
  if [[ -z "$current_base_branch" ]]; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_base_branch_unresolved" "Finish readiness could not determine the current landing branch target." "Resolve the base branch target locally, then re-run document-release."
    return 0
  fi

  if ! test_plan_artifact_path="$(latest_branch_artifact_path "test-plan" 2>/dev/null)"; then
    gate_fail "QaArtifactNotFresh" "test_plan_artifact_missing" "Finish readiness requires the current branch test-plan artifact, but none was found." "Regenerate the test-plan artifact for the current approved plan revision."
    return 0
  fi
  if ! parse_test_plan_artifact "$test_plan_artifact_path"; then
    gate_fail "QaArtifactNotFresh" "test_plan_artifact_malformed" "The latest test-plan artifact is malformed and cannot drive finish readiness." "Regenerate the test-plan artifact from plan-eng-review before finishing."
    return 0
  fi
  if [[ "$TEST_PLAN_SOURCE_PLAN" != "$PLAN_REL_PATH" || "$TEST_PLAN_SOURCE_PLAN_REVISION" != "$PLAN_REVISION" ]]; then
    gate_fail "QaArtifactNotFresh" "test_plan_artifact_stale" "The latest test-plan artifact does not match the current approved plan path and revision." "Regenerate the test-plan artifact for the current approved plan."
  fi
  if [[ "$TEST_PLAN_BRANCH" != "$PROJECT_ARTIFACT_BRANCH_RAW" || "$TEST_PLAN_REPO" != "$PROJECT_ARTIFACT_SLUG" ]]; then
    gate_fail "QaArtifactNotFresh" "test_plan_artifact_stale" "The latest test-plan artifact does not match the current branch or repo." "Regenerate the test-plan artifact on the current branch."
  fi
  test_plan_required="$TEST_PLAN_BROWSER_QA_REQUIRED"

  if [[ "$test_plan_required" == "yes" ]]; then
    if ! qa_artifact_path="$(latest_branch_artifact_path "test-outcome" 2>/dev/null)"; then
      gate_fail "QaArtifactNotFresh" "qa_artifact_missing" "Finish readiness requires a fresh QA result artifact, but none was found." "Run qa-only and return with a fresh QA result artifact."
    elif ! parse_qa_result_artifact "$qa_artifact_path"; then
      gate_fail "QaArtifactNotFresh" "qa_artifact_malformed" "The latest QA result artifact is malformed." "Re-run qa-only so it writes a valid structured QA result artifact."
    else
      if [[ "$QA_RESULT_SOURCE_PLAN" != "$PLAN_REL_PATH" || "$QA_RESULT_SOURCE_PLAN_REVISION" != "$PLAN_REVISION" ]]; then
        gate_fail "QaArtifactNotFresh" "qa_artifact_plan_mismatch" "The latest QA result artifact does not match the current approved plan path and revision." "Re-run qa-only against the current approved plan."
      fi
      if [[ "$QA_RESULT_BRANCH" != "$PROJECT_ARTIFACT_BRANCH_RAW" || "$QA_RESULT_REPO" != "$PROJECT_ARTIFACT_SLUG" ]]; then
        gate_fail "QaArtifactNotFresh" "qa_artifact_branch_mismatch" "The latest QA result artifact does not match the current branch or repo." "Re-run qa-only on the current branch."
      fi
      if [[ "$QA_RESULT_HEAD_SHA" != "$current_head" ]]; then
        gate_fail "QaArtifactNotFresh" "qa_artifact_head_mismatch" "The latest QA result artifact does not match the current HEAD commit." "Re-run qa-only after the latest repo changes."
      fi
      expected_test_plan_path="$(expand_leading_tilde "$test_plan_artifact_path")"
      if [[ "$(expand_leading_tilde "$QA_RESULT_SOURCE_TEST_PLAN")" != "$expected_test_plan_path" ]]; then
        gate_fail "QaArtifactNotFresh" "qa_artifact_source_test_plan_mismatch" "The latest QA result artifact does not point at the current test-plan artifact." "Re-run qa-only using the latest test-plan handoff."
      fi
      if [[ "$QA_RESULT_VALUE" != "pass" ]]; then
        gate_fail "QaArtifactNotFresh" "qa_result_not_pass" "The latest QA result artifact does not report a passing QA result." "Resolve the QA outcome or re-run qa-only after fixing the issue."
      fi
    fi
  fi

  if ! release_artifact_path="$(latest_branch_artifact_path "release-readiness" 2>/dev/null)"; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_missing" "Finish readiness requires a fresh release-readiness artifact, but none was found." "Run document-release and return with a fresh release-readiness artifact."
    return 0
  fi

  if ! parse_release_readiness_artifact "$release_artifact_path"; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_malformed" "The latest release-readiness artifact is malformed." "Re-run document-release so it writes a valid structured release-readiness artifact."
    return 0
  fi

  if [[ "$RELEASE_SOURCE_PLAN" != "$PLAN_REL_PATH" || "$RELEASE_SOURCE_PLAN_REVISION" != "$PLAN_REVISION" ]]; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_plan_mismatch" "The latest release-readiness artifact does not match the current approved plan path and revision." "Re-run document-release against the current approved plan."
  fi
  if [[ "$RELEASE_BRANCH" != "$PROJECT_ARTIFACT_BRANCH_RAW" || "$RELEASE_REPO" != "$PROJECT_ARTIFACT_SLUG" ]]; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_branch_mismatch" "The latest release-readiness artifact does not match the current branch or repo." "Re-run document-release on the current branch."
  fi
  if [[ "$RELEASE_BASE_BRANCH" != "$current_base_branch" ]]; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_base_branch_mismatch" "The latest release-readiness artifact does not match the current base branch target." "Re-run document-release for the current landing branch."
  fi
  if [[ "$RELEASE_HEAD_SHA" != "$current_head" ]]; then
    gate_fail "ReleaseArtifactNotFresh" "release_artifact_head_mismatch" "The latest release-readiness artifact does not match the current HEAD commit." "Re-run document-release after the latest repo changes."
  fi
  if [[ "$RELEASE_RESULT_VALUE" != "pass" ]]; then
    gate_fail "ReleaseArtifactNotFresh" "release_result_not_pass" "The latest release-readiness artifact does not report a passing release result." "Resolve the release-readiness outcome or re-run document-release."
  fi

  return 0
}

apply_gate_review_checks() {
  if [[ "$PLAN_ACTIVE_TASK" != "null" ]]; then
    gate_fail "ExecutionStateNotReady" "active_step_in_progress" "Final review is blocked while a plan step is still active." "Complete, interrupt, or resolve the active step before review."
  fi
  if [[ "$PLAN_BLOCKING_TASK" != "null" ]]; then
    gate_fail "ExecutionStateNotReady" "blocked_step" "Final review is blocked while a plan step is blocked." "Resolve the blocked step before review."
  fi
  if [[ "$PLAN_RESUME_TASK" != "null" ]]; then
    gate_fail "ExecutionStateNotReady" "interrupted_work_unresolved" "Final review is blocked while interrupted work remains unresolved." "Resume or explicitly resolve the interrupted work before review."
  fi

  validate_all_steps_completed_for_review || true
  validate_checked_steps_have_evidence || true
  if [[ "$EVIDENCE_FORMAT" == "legacy" && "$EVIDENCE_ATTEMPT_COUNT" -gt 0 ]]; then
    gate_add_warning_code "legacy_evidence_format"
  fi
  validate_v2_evidence_provenance || true
}

evaluate_preflight() {
  local plan_rel="$1"
  reset_gate_state
  load_execution_state "$plan_rel" || {
    load_failure_as_gate_failure "PlanNotExecutionReady"
    emit_gate_json
    return 0
  }

  if [[ "$PLAN_ACTIVE_TASK" != "null" ]]; then
    gate_fail "ExecutionStateNotReady" "active_step_in_progress" "Execution preflight cannot continue while a step is already active." "Resume or resolve the active step first."
  fi
  if [[ "$PLAN_BLOCKING_TASK" != "null" ]]; then
    gate_fail "ExecutionStateNotReady" "blocked_step" "Execution preflight cannot continue while work is blocked." "Resolve the blocked step first."
  fi
  if [[ "$PLAN_RESUME_TASK" != "null" ]]; then
    gate_fail "ExecutionStateNotReady" "interrupted_work_unresolved" "Execution preflight cannot continue while interrupted work remains parked." "Resume or explicitly resolve the interrupted step first."
  fi

  validate_workspace_safety
  validate_repo_safety_applicability || true
  emit_gate_json
}

evaluate_gate_review() {
  local plan_rel="$1"
  local cache_path=""
  local meta_path=""
  local output=""

  cache_path="$(plan_execution_gate_cache_path "gate-review" "$plan_rel" 2>/dev/null || true)"
  if [[ -n "$cache_path" ]]; then
    meta_path="$(gate_cache_meta_path "$cache_path")"
    if output="$(read_cached_gate_output "$cache_path" "$meta_path" 2>/dev/null)"; then
      printf '%s\n' "$output"
      return 0
    fi
  fi

  reset_gate_state
  load_execution_state "$plan_rel" || {
    load_failure_as_gate_failure "MalformedExecutionState"
    emit_gate_json
    return 0
  }

  collect_latest_completed_step_attempts
  collect_latest_completed_file_proofs
  [[ -n "$cache_path" && -z "$meta_path" ]] && meta_path="$(gate_cache_meta_path "$cache_path")"

  apply_gate_review_checks
  output="$(emit_gate_json)"
  if [[ -n "$cache_path" ]] && build_gate_cache_metadata; then
    write_cached_gate_output "$cache_path" "$meta_path" "$output" "$GATE_CACHE_METADATA"
  fi
  printf '%s\n' "$output"
}

evaluate_gate_finish() {
  local plan_rel="$1"
  reset_gate_state
  load_execution_state "$plan_rel" || {
    load_failure_as_gate_failure "MalformedExecutionState"
    emit_gate_json
    return 0
  }

  apply_gate_review_checks
  validate_finish_artifacts || true
  emit_gate_json
}

cmd_status() {
  local plan_rel=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)
        [[ $# -ge 2 ]] || { emit_error "InvalidCommandInput" "status requires --plan."; return 1; }
        plan_rel="$2"
        shift 2
        ;;
      *)
        emit_error "InvalidCommandInput" "Unknown status argument '$1'."
        return 1
        ;;
    esac
  done

  [[ -n "$plan_rel" ]] || { emit_error "InvalidCommandInput" "status requires --plan."; return 1; }
  run_status_with_plan "$plan_rel"
}

cmd_preflight() {
  local plan_rel=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown preflight argument '$1'."; return 1 ;;
    esac
  done
  [[ -n "$plan_rel" ]] || { emit_error "InvalidCommandInput" "preflight requires --plan."; return 1; }
  evaluate_preflight "$plan_rel"
}

cmd_gate_review() {
  local plan_rel=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown gate-review argument '$1'."; return 1 ;;
    esac
  done
  [[ -n "$plan_rel" ]] || { emit_error "InvalidCommandInput" "gate-review requires --plan."; return 1; }
  evaluate_gate_review "$plan_rel"
}

cmd_gate_finish() {
  local plan_rel=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown gate-finish argument '$1'."; return 1 ;;
    esac
  done
  [[ -n "$plan_rel" ]] || { emit_error "InvalidCommandInput" "gate-finish requires --plan."; return 1; }
  evaluate_gate_finish "$plan_rel"
}

cmd_recommend() {
  local plan_rel=""
  local isolated_agents="unknown"
  local session_intent="unknown"
  local workspace_prepared="unknown"
  local tasks_independent="unknown"
  local same_session_viable="unknown"
  local recommended_skill reason

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)
        [[ $# -ge 2 ]] || { emit_error "InvalidCommandInput" "recommend requires --plan."; return 1; }
        plan_rel="$2"
        shift 2
        ;;
      --isolated-agents)
        [[ $# -ge 2 ]] || { emit_error "InvalidCommandInput" "recommend requires a value for --isolated-agents."; return 1; }
        case "$2" in
          available) isolated_agents="yes" ;;
          unavailable) isolated_agents="no" ;;
          *) emit_error "InvalidCommandInput" "isolated-agents must be available or unavailable."; return 1 ;;
        esac
        shift 2
        ;;
      --session-intent)
        [[ $# -ge 2 ]] || { emit_error "InvalidCommandInput" "recommend requires a value for --session-intent."; return 1; }
        case "$2" in
          stay|separate|unknown) session_intent="$2" ;;
          *) emit_error "InvalidCommandInput" "session-intent must be stay, separate, or unknown."; return 1 ;;
        esac
        shift 2
        ;;
      --workspace-prepared)
        [[ $# -ge 2 ]] || { emit_error "InvalidCommandInput" "recommend requires a value for --workspace-prepared."; return 1; }
        case "$2" in
          yes|no|unknown) workspace_prepared="$2" ;;
          *) emit_error "InvalidCommandInput" "workspace-prepared must be yes, no, or unknown."; return 1 ;;
        esac
        shift 2
        ;;
      *)
        emit_error "InvalidCommandInput" "Unknown recommend argument '$1'."
        return 1
        ;;
    esac
  done

  [[ -n "$plan_rel" ]] || { emit_error "InvalidCommandInput" "recommend requires --plan."; return 1; }

  load_execution_state "$plan_rel" || {
    emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
    return 1
  }
  if [[ "$EXECUTION_STARTED" == "yes" ]]; then
    emit_error "RecommendAfterExecutionStart" "recommend is only valid before execution has started for this plan revision."
    return 1
  fi
  tasks_independent="$(derive_tasks_independent_from_plan "$PLAN_ABS_PATH")"

  if [[ "$session_intent" == "stay" && "$workspace_prepared" == "yes" ]]; then
    same_session_viable="yes"
  elif [[ "$session_intent" == "separate" || "$workspace_prepared" == "no" ]]; then
    same_session_viable="no"
  else
    same_session_viable="unknown"
  fi

  if [[ "$tasks_independent" == "yes" && "$isolated_agents" == "yes" && "$same_session_viable" == "yes" ]]; then
    recommended_skill="superpowers:subagent-driven-development"
    reason="Independent tasks and same-session isolated execution are viable."
  else
    recommended_skill="superpowers:executing-plans"
    reason="Defaulting conservatively because the available signals do not positively justify isolated same-session execution."
  fi

  printf '{'
  printf '"recommended_skill":"%s",' "$(json_escape "$recommended_skill")"
  printf '"reason":"%s",' "$(json_escape "$reason")"
  printf '"decision_flags":{'
  printf '"tasks_independent":"%s",' "$(json_escape "$tasks_independent")"
  printf '"isolated_agents_available":"%s",' "$(json_escape "$isolated_agents")"
  printf '"session_intent":"%s",' "$(json_escape "$session_intent")"
  printf '"workspace_prepared":"%s",' "$(json_escape "$workspace_prepared")"
  printf '"same_session_viable":"%s"' "$(json_escape "$same_session_viable")"
  printf '}}\n'
}

cmd_begin() {
  local plan_rel="" task="" step="" execution_mode_input="" expected_fp=""
  local step_index summary

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      --task) task="${2:-}"; shift 2 ;;
      --step) step="${2:-}"; shift 2 ;;
      --execution-mode) execution_mode_input="${2:-}"; shift 2 ;;
      --expect-execution-fingerprint) expected_fp="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown begin argument '$1'."; return 1 ;;
    esac
  done

  [[ -n "$plan_rel" && -n "$task" && -n "$step" && -n "$expected_fp" ]] || { emit_error "InvalidCommandInput" "begin requires --plan, --task, --step, and --expect-execution-fingerprint."; return 1; }
  load_execution_state "$plan_rel" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  assert_expected_fingerprint "$expected_fp" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  find_step_or_fail "$task" "$step" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  step_index="$STEP_INDEX_FOUND"

  if [[ "${STEP_CHECKED[$step_index]}" == "x" ]]; then
    emit_error "InvalidStepTransition" "begin may not target a completed step."
    return 1
  fi

  case "$PLAN_EXECUTION_MODE" in
    none)
      case "$execution_mode_input" in
        superpowers:executing-plans|superpowers:subagent-driven-development) PLAN_EXECUTION_MODE="$execution_mode_input" ;;
        *) emit_error "InvalidExecutionMode" "The first begin for a plan revision must supply a valid execution mode."; return 1 ;;
      esac
      ;;
    *)
      if [[ -n "$execution_mode_input" && "$execution_mode_input" != "$PLAN_EXECUTION_MODE" ]]; then
        emit_error "InvalidExecutionMode" "begin may not change the persisted execution mode."
        return 1
      fi
      ;;
  esac

  if [[ "$PLAN_ACTIVE_TASK" != "null" || "$PLAN_BLOCKING_TASK" != "null" || "$PLAN_RESUME_TASK" != "null" ]]; then
    if [[ "$PLAN_ACTIVE_TASK" == "$task" && "$PLAN_ACTIVE_STEP" == "$step" ]]; then
      print_status_json
      return 0
    fi
    if [[ "$PLAN_BLOCKING_TASK" != "null" && ( "$PLAN_BLOCKING_TASK" != "$task" || "$PLAN_BLOCKING_STEP" != "$step" ) ]]; then
      emit_error "InvalidStepTransition" "Blocked work must resume on the same step."
      return 1
    fi
    if [[ "$PLAN_RESUME_TASK" != "null" && "$PLAN_ACTIVE_TASK" == "null" && "$PLAN_BLOCKING_TASK" == "null" && ( "$PLAN_RESUME_TASK" != "$task" || "$PLAN_RESUME_STEP" != "$step" ) ]]; then
      emit_error "InvalidStepTransition" "Interrupted work must resume on the same step."
      return 1
    fi
    if [[ "$PLAN_ACTIVE_TASK" != "null" && ( "$PLAN_ACTIVE_TASK" != "$task" || "$PLAN_ACTIVE_STEP" != "$step" ) ]]; then
      emit_error "InvalidStepTransition" "A different step is already active."
      return 1
    fi
    if [[ "$PLAN_BLOCKING_TASK" != "null" && "$PLAN_BLOCKING_TASK" == "$task" && "$PLAN_BLOCKING_STEP" == "$step" ]]; then
      :
    elif [[ "$PLAN_RESUME_TASK" != "null" && "$PLAN_RESUME_TASK" == "$task" && "$PLAN_RESUME_STEP" == "$step" ]]; then
      :
    elif [[ "$PLAN_ACTIVE_TASK" != "$task" || "$PLAN_ACTIVE_STEP" != "$step" ]]; then
      emit_error "InvalidStepTransition" "begin may not bypass existing blocked or interrupted work."
      return 1
    fi
  fi

  summary="$(active_summary_from_title "${STEP_TITLES[$step_index]}")"
  STEP_NOTE_STATES[$step_index]="Active"
  STEP_NOTE_SUMMARIES[$step_index]="$summary"

  commit_plan_only "begin" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  run_status_with_plan "$PLAN_REL_PATH"
}

cmd_transfer() {
  local plan_rel="" repair_task="" repair_step="" source="" reason="" expected_fp=""
  local active_index repair_index latest_attempt repair_summary parked_summary normalized_reason=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      --repair-task) repair_task="${2:-}"; shift 2 ;;
      --repair-step) repair_step="${2:-}"; shift 2 ;;
      --source) source="${2:-}"; shift 2 ;;
      --reason) reason="${2:-}"; shift 2 ;;
      --expect-execution-fingerprint) expected_fp="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown transfer argument '$1'."; return 1 ;;
    esac
  done

  [[ -n "$plan_rel" && -n "$repair_task" && -n "$repair_step" && -n "$source" && -n "$reason" && -n "$expected_fp" ]] || {
    emit_error "InvalidCommandInput" "transfer requires --plan, --repair-task, --repair-step, --source, --reason, and --expect-execution-fingerprint."
    return 1
  }

  validate_required_normalized_text \
    "$reason" \
    "Transfer reasons may not be blank after whitespace normalization." || {
    emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
    return 1
  }
  normalized_reason="$REQUIRED_TEXT_NORMALIZED"

  load_execution_state "$plan_rel" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  assert_expected_fingerprint "$expected_fp" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  validate_execution_mode_source "$source" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  parse_evidence_attempts || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }

  [[ "$PLAN_ACTIVE_TASK" != "null" ]] || { emit_error "InvalidStepTransition" "transfer requires a current active step."; return 1; }
  [[ "$PLAN_RESUME_TASK" == "null" ]] || { emit_error "InvalidStepTransition" "transfer may not create a second parked interrupted step."; return 1; }

  find_step_or_fail "$PLAN_ACTIVE_TASK" "$PLAN_ACTIVE_STEP" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  active_index="$STEP_INDEX_FOUND"
  find_step_or_fail "$repair_task" "$repair_step" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  repair_index="$STEP_INDEX_FOUND"

  if [[ "${STEP_CHECKED[$repair_index]}" != "x" ]]; then
    emit_error "InvalidStepTransition" "transfer may only reopen a currently completed repair step."
    return 1
  fi

  if ! latest_attempt="$(find_latest_attempt_index "$repair_task" "$repair_step" 2>/dev/null)"; then
    emit_error "EvidenceWriteFailed" "transfer could not find evidence to invalidate for the repair step."
    return 1
  fi

  invalidate_attempt "$latest_attempt" "$source" "$normalized_reason"

  parked_summary="Parked for repair of Task ${repair_task} Step ${repair_step}"
  STEP_NOTE_STATES[$active_index]="Interrupted"
  STEP_NOTE_SUMMARIES[$active_index]="$parked_summary"
  STEP_CHECKED[$repair_index]=' '
  repair_summary="$(active_summary_from_title "${STEP_TITLES[$repair_index]}")"
  STEP_NOTE_STATES[$repair_index]="Active"
  STEP_NOTE_SUMMARIES[$repair_index]="$repair_summary"

  commit_plan_and_evidence "transfer" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  run_status_with_plan "$PLAN_REL_PATH"
}

cmd_complete() {
  local plan_rel="" task="" step="" source="" claim="" verify_command="" verify_result="" manual_summary="" expected_fp=""
  local files=()
  local step_index verification_entry files_entry files_proven_entry packet_fingerprint head_sha base_sha
  local normalized_claim="" normalized_verify_command="" normalized_verify_result="" normalized_manual_summary=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      --task) task="${2:-}"; shift 2 ;;
      --step) step="${2:-}"; shift 2 ;;
      --source) source="${2:-}"; shift 2 ;;
      --claim) claim="${2:-}"; shift 2 ;;
      --file) files+=("${2:-}"); shift 2 ;;
      --verify-command) verify_command="${2:-}"; shift 2 ;;
      --verify-result) verify_result="${2:-}"; shift 2 ;;
      --manual-verify-summary) manual_summary="${2:-}"; shift 2 ;;
      --expect-execution-fingerprint) expected_fp="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown complete argument '$1'."; return 1 ;;
    esac
  done

  [[ -n "$plan_rel" && -n "$task" && -n "$step" && -n "$source" && -n "$claim" && -n "$expected_fp" ]] || {
    emit_error "InvalidCommandInput" "complete requires --plan, --task, --step, --source, --claim, and --expect-execution-fingerprint."
    return 1
  }

  validate_required_normalized_text \
    "$claim" \
    "Completion claims may not be blank after whitespace normalization." || {
    emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
    return 1
  }
  normalized_claim="$REQUIRED_TEXT_NORMALIZED"

  if [[ -n "$manual_summary" && ( -n "$verify_command" || -n "$verify_result" ) ]]; then
    emit_error "InvalidCommandInput" "complete accepts exactly one verification mode."
    return 1
  fi
  if [[ -n "$verify_command" || -n "$verify_result" ]]; then
    if [[ -z "$verify_command" || -z "$verify_result" ]]; then
      emit_error "InvalidCommandInput" "Command verification requires both --verify-command and --verify-result."
      return 1
    fi
    validate_required_normalized_text \
      "$verify_command" \
      "Verification commands may not be blank after whitespace normalization." || {
      emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
      return 1
    }
    normalized_verify_command="$REQUIRED_TEXT_NORMALIZED"
    validate_required_normalized_text \
      "$verify_result" \
      "Verification results may not be blank after whitespace normalization." || {
      emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
      return 1
    }
    normalized_verify_result="$REQUIRED_TEXT_NORMALIZED"
    verification_entry="\`$normalized_verify_command\` -> $normalized_verify_result"
  elif [[ -n "$manual_summary" ]]; then
    validate_required_normalized_text \
      "$manual_summary" \
      "Manual verification summaries may not be blank after whitespace normalization." || {
      emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
      return 1
    }
    normalized_manual_summary="$REQUIRED_TEXT_NORMALIZED"
    verification_entry="Manual inspection only: $normalized_manual_summary"
  else
    emit_error "InvalidCommandInput" "complete requires exactly one verification mode."
    return 1
  fi

  load_execution_state "$plan_rel" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  assert_expected_fingerprint "$expected_fp" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  validate_execution_mode_source "$source" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  parse_evidence_attempts || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  find_step_or_fail "$task" "$step" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  step_index="$STEP_INDEX_FOUND"

  if [[ "$PLAN_ACTIVE_TASK" != "$task" || "$PLAN_ACTIVE_STEP" != "$step" ]]; then
    emit_error "InvalidStepTransition" "complete may target only the current active step."
    return 1
  fi
  if [[ "${STEP_CHECKED[$step_index]}" == "x" ]]; then
    emit_error "InvalidStepTransition" "complete may not directly refresh an already checked step."
    return 1
  fi

  if (( ${#files[@]} > 0 )); then
    build_files_entry "${files[@]}" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  else
    build_default_files_entry_for_task "$task" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  fi
  files_entry="$FILES_ENTRY"
  build_files_proven_entry "$files_entry" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  files_proven_entry="$FILES_PROVEN_ENTRY"
  STEP_CHECKED[$step_index]='x'
  STEP_NOTE_STATES[$step_index]=""
  STEP_NOTE_SUMMARIES[$step_index]=""
  packet_fingerprint="$(compute_pending_execution_packet_fingerprint "$task" "$step")" || {
    emit_error "EvidenceWriteFailed" "Could not compute the current execution packet fingerprint."
    return 1
  }
  head_sha="$(current_head_sha)"
  base_sha="$(current_base_sha)"
  append_attempt \
    "$task" \
    "$step" \
    "$source" \
    "$normalized_claim" \
    "$files_entry" \
    "$verification_entry" \
    "$packet_fingerprint" \
    "$head_sha" \
    "$base_sha" \
    "$files_proven_entry"

  commit_plan_and_evidence "complete" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  run_status_with_plan "$PLAN_REL_PATH"
}

cmd_note() {
  local plan_rel="" task="" step="" state="" message="" expected_fp=""
  local step_index

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      --task) task="${2:-}"; shift 2 ;;
      --step) step="${2:-}"; shift 2 ;;
      --state) state="${2:-}"; shift 2 ;;
      --message) message="${2:-}"; shift 2 ;;
      --expect-execution-fingerprint) expected_fp="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown note argument '$1'."; return 1 ;;
    esac
  done

  [[ -n "$plan_rel" && -n "$task" && -n "$step" && -n "$state" && -n "$message" && -n "$expected_fp" ]] || {
    emit_error "InvalidCommandInput" "note requires --plan, --task, --step, --state, --message, and --expect-execution-fingerprint."
    return 1
  }
  case "$state" in
    interrupted|blocked) ;;
    *) emit_error "InvalidCommandInput" "note state must be interrupted or blocked."; return 1 ;;
  esac

  validate_note_message "$message" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  load_execution_state "$plan_rel" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  assert_expected_fingerprint "$expected_fp" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  find_step_or_fail "$task" "$step" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  step_index="$STEP_INDEX_FOUND"

  if [[ "$PLAN_ACTIVE_TASK" == "$task" && "$PLAN_ACTIVE_STEP" == "$step" ]]; then
    if [[ "$state" == "interrupted" && "$PLAN_RESUME_TASK" != "null" ]]; then
      emit_error "InvalidStepTransition" "The current repair step cannot become interrupted while a parked step already exists."
      return 1
    fi
  elif [[ "$state" == "blocked" && "$PLAN_ACTIVE_TASK" == "null" && "$PLAN_RESUME_TASK" == "$task" && "$PLAN_RESUME_STEP" == "$step" ]]; then
    :
  else
    emit_error "InvalidStepTransition" "note may target only the current active step, except blocked follow-up after reopen."
    return 1
  fi

  STEP_NOTE_STATES[$step_index]="$([[ "$state" == "interrupted" ]] && printf 'Interrupted' || printf 'Blocked')"
  STEP_NOTE_SUMMARIES[$step_index]="$NOTE_MESSAGE_NORMALIZED"

  commit_plan_only "note" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  run_status_with_plan "$PLAN_REL_PATH"
}

cmd_reopen() {
  local plan_rel="" task="" step="" source="" reason="" expected_fp=""
  local step_index latest_attempt normalized_reason=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      --task) task="${2:-}"; shift 2 ;;
      --step) step="${2:-}"; shift 2 ;;
      --source) source="${2:-}"; shift 2 ;;
      --reason) reason="${2:-}"; shift 2 ;;
      --expect-execution-fingerprint) expected_fp="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown reopen argument '$1'."; return 1 ;;
    esac
  done

  [[ -n "$plan_rel" && -n "$task" && -n "$step" && -n "$source" && -n "$reason" && -n "$expected_fp" ]] || {
    emit_error "InvalidCommandInput" "reopen requires --plan, --task, --step, --source, --reason, and --expect-execution-fingerprint."
    return 1
  }

  validate_required_normalized_text \
    "$reason" \
    "Reopen reasons may not be blank after whitespace normalization." || {
    emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"
    return 1
  }
  normalized_reason="$REQUIRED_TEXT_NORMALIZED"

  load_execution_state "$plan_rel" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  assert_expected_fingerprint "$expected_fp" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  validate_execution_mode_source "$source" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  parse_evidence_attempts || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  find_step_or_fail "$task" "$step" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  step_index="$STEP_INDEX_FOUND"

  if [[ "${STEP_CHECKED[$step_index]}" != "x" ]]; then
    emit_error "InvalidStepTransition" "reopen may target only a currently completed step."
    return 1
  fi
  if [[ "$PLAN_RESUME_TASK" != "null" ]]; then
    emit_error "InvalidStepTransition" "reopen may not create a second parked interrupted step while one already exists."
    return 1
  fi
  if ! latest_attempt="$(find_latest_attempt_index "$task" "$step" 2>/dev/null)"; then
    emit_error "EvidenceWriteFailed" "reopen could not find evidence to invalidate for the target step."
    return 1
  fi

  invalidate_attempt "$latest_attempt" "$source" "$normalized_reason"
  STEP_CHECKED[$step_index]=' '
  STEP_NOTE_STATES[$step_index]="Interrupted"
  STEP_NOTE_SUMMARIES[$step_index]="$(reopen_note_summary "$normalized_reason")"

  commit_plan_and_evidence "reopen" || { emit_error "$LOAD_ERROR_CLASS" "$LOAD_ERROR_MESSAGE"; return 1; }
  run_status_with_plan "$PLAN_REL_PATH"
}

main() {
  local command="${1:-}"
  case "$command" in
    status) shift; cmd_status "$@" ;;
    recommend) shift; cmd_recommend "$@" ;;
    preflight) shift; cmd_preflight "$@" ;;
    gate-review) shift; cmd_gate_review "$@" ;;
    gate-finish) shift; cmd_gate_finish "$@" ;;
    begin) shift; cmd_begin "$@" ;;
    transfer) shift; cmd_transfer "$@" ;;
    complete) shift; cmd_complete "$@" ;;
    note) shift; cmd_note "$@" ;;
    reopen) shift; cmd_reopen "$@" ;;
    ''|-h|--help|help)
      usage
      exit 1
      ;;
    *)
      emit_error "InvalidCommandInput" "Unknown subcommand '$command'."
      return 1
      ;;
  esac
}

main "$@"
