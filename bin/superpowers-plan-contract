#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
FORWARDED_ARGS=("$@")

resolve_runtime_entry() {
  if [[ -x "$SCRIPT_DIR/../compat/bash/superpowers" ]]; then
    printf '%s\n' "$SCRIPT_DIR/../compat/bash/superpowers"
    return 0
  fi

  local source="$SCRIPT_PATH"
  while [[ -L "$source" ]]; do
    local source_dir target
    source_dir="$(cd "$(dirname "$source")" && pwd)"
    target="$(readlink "$source")"
    if [[ "$target" == /* ]]; then
      source="$target"
    else
      source="$source_dir/$target"
    fi
  done

  local real_dir
  real_dir="$(cd "$(dirname "$source")" && pwd)"
  printf '%s\n' "$real_dir/../compat/bash/superpowers"
}

if [[ "${FORWARDED_ARGS[0]:-}" == "plan" && "${FORWARDED_ARGS[1]:-}" == "contract" ]]; then
  FORWARDED_ARGS=("${FORWARDED_ARGS[@]:2}")
elif [[ "${FORWARDED_ARGS[0]:-}" == "contract" ]]; then
  FORWARDED_ARGS=("${FORWARDED_ARGS[@]:1}")
fi

if [[ ${#FORWARDED_ARGS[@]} -eq 0 ]]; then
  exec "$(resolve_runtime_entry)" plan contract
fi

exec "$(resolve_runtime_entry)" plan contract "${FORWARDED_ARGS[@]}"
