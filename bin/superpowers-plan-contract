#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/superpowers-runtime-common.sh
. "$SCRIPT_DIR/superpowers-runtime-common.sh"
# shellcheck source=bin/superpowers-plan-structure-common
. "$SCRIPT_DIR/superpowers-plan-structure-common"

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
STATE_DIR="${SUPERPOWERS_STATE_DIR:-$HOME/.superpowers}"
USER_NAME="$(whoami 2>/dev/null || echo user)"
PACKET_RETENTION_LIMIT="${SUPERPOWERS_PLAN_PACKET_RETENTION:-20}"

usage() {
  cat <<'EOF' >&2
Usage:
  superpowers-plan-contract lint --spec <spec-path> --plan <plan-path>
  superpowers-plan-contract build-task-packet --plan <plan-path> --task <N> [--format json|markdown] [--persist yes|no]
EOF
}

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  printf '%s' "$value"
}

emit_error() {
  local klass="$1"
  local message="$2"
  printf '{"error_class":"%s","message":"%s"}\n' \
    "$(json_escape "$klass")" \
    "$(json_escape "$message")"
}

emit_lint_error() {
  local klass="$1"
  local message="$2"
  local spec_path="${3:-}"
  local plan_path="${4:-}"
  printf '{'
  printf '"status":"invalid",'
  printf '"error_class":"%s",' "$(json_escape "$klass")"
  printf '"message":"%s",' "$(json_escape "$message")"
  printf '"spec_path":"%s",' "$(json_escape "$spec_path")"
  printf '"plan_path":"%s",' "$(json_escape "$plan_path")"
  printf '"errors":[{"code":"%s","message":"%s"}],' "$(json_escape "$klass")" "$(json_escape "$message")"
  printf '"warnings":[]'
  printf '}\n'
}

hash_stream() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}'
    return
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}'
    return
  fi
  cksum | awk '{print $1}'
}

hash_file() {
  local path="$1"
  [[ -f "$path" ]] || return 1
  hash_stream < "$path"
}

timestamp_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

plan_rel_to_abs() {
  printf '%s/%s\n' "$REPO_ROOT" "$1"
}

normalize_required_repo_path() {
  local raw="$1"
  local label="$2"
  local normalized

  normalized="$(normalize_repo_relative_path "$raw")" || {
    emit_error "InvalidCommandInput" "$label must be a normalized repo-relative path."
    return 1
  }

  printf '%s\n' "$normalized"
}

join_by() {
  local delimiter="$1"
  shift || true
  local first=1
  local item

  for item in "$@"; do
    if [[ $first -eq 1 ]]; then
      printf '%s' "$item"
      first=0
    else
      printf '%s%s' "$delimiter" "$item"
    fi
  done
}

SPEC_REQUIREMENT_COUNT=0
SPEC_REQUIREMENT_IDS=()
SPEC_REQUIREMENT_TYPES=()
SPEC_REQUIREMENT_STATEMENTS=()
SPEC_REQUIREMENT_SEEN="|"
SPEC_REVISION=""

reset_spec_parse_state() {
  SPEC_REQUIREMENT_COUNT=0
  SPEC_REQUIREMENT_IDS=()
  SPEC_REQUIREMENT_TYPES=()
  SPEC_REQUIREMENT_STATEMENTS=()
  SPEC_REQUIREMENT_SEEN="|"
  SPEC_REVISION=""
}

find_spec_requirement_index() {
  local requirement_id="$1"
  local i

  for ((i=0; i<SPEC_REQUIREMENT_COUNT; i++)); do
    if [[ "${SPEC_REQUIREMENT_IDS[$i]}" == "$requirement_id" ]]; then
      printf '%s\n' "$i"
      return 0
    fi
  done

  return 1
}

parse_spec_headers() {
  local spec_abs="$1"

  SPEC_REVISION="$(sed -nE 's/^\*\*Spec Revision:\*\* ([0-9]+)$/\1/p' "$spec_abs" | head -n1)"
  [[ -n "$SPEC_REVISION" ]] || return 1
  return 0
}

parse_requirement_index() {
  local spec_abs="$1"
  local line
  local in_index=0
  local in_fence=0
  local saw_index=0
  local normalized=""
  local requirement_id=""
  local requirement_type=""
  local requirement_statement=""

  reset_spec_parse_state
  [[ -f "$spec_abs" ]] || return 1
  parse_spec_headers "$spec_abs" || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    if (( in_index == 0 )) && [[ "$line" =~ ^[[:space:]]*\`\`\` ]]; then
      if (( in_fence )); then
        in_fence=0
      else
        in_fence=1
      fi
      continue
    fi
    if (( in_fence )); then
      continue
    fi

    if [[ "$line" == "## Requirement Index" ]]; then
      saw_index=1
      in_index=1
      continue
    fi

    if (( in_index )); then
      if [[ "$line" =~ ^##\  ]]; then
        break
      fi
      normalized="$(normalize_whitespace "$line")"
      if [[ -z "$normalized" ]]; then
        continue
      fi
      if [[ "$line" =~ ^-\ \[([A-Z]+-[0-9]+)\]\[([A-Za-z-]+)\]\ (.+)$ ]]; then
        requirement_id="${BASH_REMATCH[1]}"
        requirement_type="${BASH_REMATCH[2]}"
        requirement_statement="${BASH_REMATCH[3]}"
        case "$SPEC_REQUIREMENT_SEEN" in
          *"|$requirement_id|"*)
            return 2
            ;;
        esac
        SPEC_REQUIREMENT_IDS[$SPEC_REQUIREMENT_COUNT]="$requirement_id"
        SPEC_REQUIREMENT_TYPES[$SPEC_REQUIREMENT_COUNT]="$requirement_type"
        SPEC_REQUIREMENT_STATEMENTS[$SPEC_REQUIREMENT_COUNT]="$requirement_statement"
        SPEC_REQUIREMENT_SEEN+="$requirement_id|"
        SPEC_REQUIREMENT_COUNT=$((SPEC_REQUIREMENT_COUNT + 1))
        continue
      fi
      return 2
    fi
  done < "$spec_abs"

  if (( saw_index == 0 )); then
    return 3
  fi
  if (( SPEC_REQUIREMENT_COUNT == 0 )); then
    return 2
  fi
  return 0
}

PLAN_REL=""
PLAN_ABS=""
PLAN_REVISION=""
PLAN_SOURCE_SPEC=""
PLAN_SOURCE_SPEC_REVISION=""

parse_plan_headers() {
  local plan_abs="$1"

  PLAN_REVISION="$(sed -nE 's/^\*\*Plan Revision:\*\* ([0-9]+)$/\1/p' "$plan_abs" | head -n1)"
  PLAN_SOURCE_SPEC="$(sed -nE 's/^\*\*Source Spec:\*\* \`(.+)\`$/\1/p' "$plan_abs" | head -n1)"
  PLAN_SOURCE_SPEC_REVISION="$(sed -nE 's/^\*\*Source Spec Revision:\*\* ([0-9]+)$/\1/p' "$plan_abs" | head -n1)"

  [[ -n "$PLAN_REVISION" && -n "$PLAN_SOURCE_SPEC" && -n "$PLAN_SOURCE_SPEC_REVISION" ]]
}

COVERAGE_MATRIX_COUNT=0
COVERAGE_MATRIX_IDS=()
COVERAGE_MATRIX_TASKS=()

reset_coverage_matrix() {
  COVERAGE_MATRIX_COUNT=0
  COVERAGE_MATRIX_IDS=()
  COVERAGE_MATRIX_TASKS=()
}

find_coverage_matrix_index() {
  local requirement_id="$1"
  local i

  for ((i=0; i<COVERAGE_MATRIX_COUNT; i++)); do
    if [[ "${COVERAGE_MATRIX_IDS[$i]}" == "$requirement_id" ]]; then
      printf '%s\n' "$i"
      return 0
    fi
  done

  return 1
}

coverage_matrix_contains_task() {
  local requirement_id="$1"
  local task_number="$2"
  local matrix_index tasks task

  matrix_index="$(find_coverage_matrix_index "$requirement_id")" || return 1
  tasks="${COVERAGE_MATRIX_TASKS[$matrix_index]}"
  while IFS= read -r task; do
    [[ -n "$task" ]] || continue
    if [[ "$task" == "$task_number" ]]; then
      return 0
    fi
  done <<< "$tasks"
  return 1
}

parse_requirement_coverage_matrix() {
  local plan_abs="$1"
  local line
  local in_matrix=0
  local saw_matrix=0
  local normalized=""
  local requirement_id=""
  local task_list=""
  local raw_task=""
  local normalized_task=""
  local task_numbers=""
  local task_number=""
  local tasks_seen=""

  reset_coverage_matrix

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "## Requirement Coverage Matrix" ]]; then
      saw_matrix=1
      in_matrix=1
      continue
    fi

    if (( in_matrix )); then
      if [[ "$line" =~ ^##\  ]]; then
        break
      fi
      normalized="$(normalize_whitespace "$line")"
      if [[ -z "$normalized" ]]; then
        continue
      fi

      if [[ "$normalized" == "- "* && "$normalized" == *" -> "* ]]; then
        requirement_id="${normalized#- }"
        requirement_id="${requirement_id%% -> *}"
        task_list="${normalized#* -> }"
        [[ "$requirement_id" =~ ^[A-Z]+-[0-9]+$ ]] || return 2
        task_numbers=""
        tasks_seen="|"
        IFS=',' read -r -a raw_tasks <<< "$task_list"
        for raw_task in "${raw_tasks[@]}"; do
          normalized_task="$(normalize_whitespace "$raw_task")"
          [[ "$normalized_task" =~ ^Task\ ([0-9]+)$ ]] || return 2
          task_number="${BASH_REMATCH[1]}"
          case "$tasks_seen" in
            *"|$task_number|"*) return 2 ;;
          esac
          tasks_seen+="$task_number|"
          task_numbers+="$task_number"$'\n'
        done
        COVERAGE_MATRIX_IDS[$COVERAGE_MATRIX_COUNT]="$requirement_id"
        COVERAGE_MATRIX_TASKS[$COVERAGE_MATRIX_COUNT]="${task_numbers%$'\n'}"
        COVERAGE_MATRIX_COUNT=$((COVERAGE_MATRIX_COUNT + 1))
        continue
      fi

      return 2
    fi
  done < "$plan_abs"

  if (( saw_matrix == 0 || COVERAGE_MATRIX_COUNT == 0 )); then
    return 3
  fi
  return 0
}

parse_task_coverage_ids() {
  local raw_ids="$1"
  local raw_item=""
  local normalized_item=""
  local result=""
  local seen="|"

  IFS=',' read -r -a raw_items <<< "$raw_ids"
  for raw_item in "${raw_items[@]}"; do
    normalized_item="$(normalize_whitespace "$raw_item")"
    [[ -n "$normalized_item" ]] || continue
    case "$seen" in
      *"|$normalized_item|"*) continue ;;
    esac
    seen+="$normalized_item|"
    result+="$normalized_item"$'\n'
  done

  printf '%s' "${result%$'\n'}"
}

AMBIGUOUS_PHRASES=(
  "if needed"
  "as appropriate"
  "handle edge cases"
  "clean up related code"
  "support similar behavior"
  "or equivalent"
  "use a reasonable default"
  "consider adding"
  "if useful"
  "etc."
)

detect_ambiguous_task_wording() {
  local task_block="$1"
  local task_number="$2"
  local lower_task
  local phrase

  lower_task="$(printf '%s' "$task_block" | tr '[:upper:]' '[:lower:]')"
  for phrase in "${AMBIGUOUS_PHRASES[@]}"; do
    if [[ "$lower_task" == *"$phrase"* ]]; then
      CONTRACT_ERROR_CLASS="AmbiguousTaskWording"
      CONTRACT_ERROR_MESSAGE="Task $task_number uses ambiguous wording ('$phrase')."
      return 1
    fi
  done

  return 0
}

detect_requirement_weakening() {
  local task_block="$1"
  local task_number="$2"
  local coverage_ids="$3"
  local lower_task
  local requirement_id
  local requirement_index
  local requirement_statement
  local normalized_requirement
  local weakened_variant
  local anchor=""
  local shared_tokens=""
  local shared_token=""

  lower_task="$(printf '%s' "$task_block" | tr '[:upper:]' '[:lower:]')"
  while IFS= read -r requirement_id; do
    [[ -n "$requirement_id" ]] || continue
    requirement_index="$(find_spec_requirement_index "$requirement_id")" || continue
    requirement_statement="${SPEC_REQUIREMENT_STATEMENTS[$requirement_index]}"
    normalized_requirement="$(normalize_whitespace "$requirement_statement" | tr '[:upper:]' '[:lower:]')"
    if [[ "$normalized_requirement" == *" must "* ]]; then
      weakened_variant="${normalized_requirement// must / should }"
      if [[ "$lower_task" == *"$weakened_variant"* ]]; then
        CONTRACT_ERROR_CLASS="RequirementWeakeningDetected"
        CONTRACT_ERROR_MESSAGE="Task $task_number weakens $requirement_id from 'must' to 'should'."
        return 1
      fi
    fi
    if [[ "$normalized_requirement" == *" must not "* ]]; then
      weakened_variant="${normalized_requirement// must not / should not }"
      if [[ "$lower_task" == *"$weakened_variant"* ]]; then
        CONTRACT_ERROR_CLASS="RequirementWeakeningDetected"
        CONTRACT_ERROR_MESSAGE="Task $task_number weakens $requirement_id from 'must not' to 'should not'."
        return 1
      fi
    fi
    if [[ "$lower_task" == *" should "* ]]; then
      shared_tokens="$(printf '%s\n' "$requirement_statement" | grep -o '\`[^`][^`]*\`' || true)"
      while IFS= read -r shared_token; do
        [[ -n "$shared_token" ]] || continue
        anchor="$(normalize_whitespace "$shared_token" | tr '[:upper:]' '[:lower:]')"
        if [[ -n "$anchor" && "$lower_task" == *"$anchor"* ]]; then
          CONTRACT_ERROR_CLASS="RequirementWeakeningDetected"
          CONTRACT_ERROR_MESSAGE="Task $task_number weakens $requirement_id by downgrading requirement force around $shared_token."
          return 1
        fi
      done <<< "$shared_tokens"
    fi
  done <<< "$coverage_ids"

  return 0
}

CONTRACT_ERROR_CLASS=""
CONTRACT_ERROR_MESSAGE=""

set_contract_error() {
  CONTRACT_ERROR_CLASS="$1"
  CONTRACT_ERROR_MESSAGE="$2"
  return 1
}

validate_plan_contract() {
  local spec_abs="$1"
  local plan_abs="$2"
  local task_index
  local task_number
  local coverage_ids
  local requirement_id
  local spec_task_refs="|"
  local matrix_index
  local matrix_task

  CONTRACT_ERROR_CLASS=""
  CONTRACT_ERROR_MESSAGE=""

  parse_requirement_index "$spec_abs"
  case $? in
    0) ;;
    2) set_contract_error "MalformedRequirementIndex" "Requirement Index is missing entries or contains malformed lines." || return 1 ;;
    3) set_contract_error "MissingRequirementIndex" "Spec is missing the required Requirement Index section." || return 1 ;;
    *) set_contract_error "UnexpectedPlanContractFailure" "Could not parse the source spec Requirement Index." || return 1 ;;
  esac

  plan_structure_parse "$plan_abs" || {
    set_contract_error "${PLAN_STRUCTURE_ERROR_CLASS:-MalformedTaskStructure}" "${PLAN_STRUCTURE_ERROR_MESSAGE:-Plan task structure is malformed.}" || return 1
  }

  parse_requirement_coverage_matrix "$plan_abs"
  case $? in
    0) ;;
    2) set_contract_error "CoverageMatrixMismatch" "Requirement Coverage Matrix is malformed." || return 1 ;;
    3) set_contract_error "MissingRequirementCoverage" "Requirement Coverage Matrix is missing or empty." || return 1 ;;
    *) set_contract_error "UnexpectedPlanContractFailure" "Could not parse the Requirement Coverage Matrix." || return 1 ;;
  esac

  for ((task_index=0; task_index<PLAN_STRUCTURE_TASK_COUNT; task_index++)); do
    task_number="${PLAN_STRUCTURE_TASK_NUMBERS[$task_index]}"
    coverage_ids="$(parse_task_coverage_ids "${PLAN_STRUCTURE_TASK_SPEC_COVERAGE[$task_index]}")"
    if [[ -z "$coverage_ids" ]]; then
      set_contract_error "TaskMissingSpecCoverage" "Task $task_number must include at least one Spec Coverage id." || return 1
    fi

    while IFS= read -r requirement_id; do
      [[ -n "$requirement_id" ]] || continue
      find_spec_requirement_index "$requirement_id" >/dev/null 2>&1 || {
        set_contract_error "UnknownRequirementId" "Task $task_number references unknown requirement id $requirement_id." || return 1
      }
      coverage_matrix_contains_task "$requirement_id" "$task_number" || {
        set_contract_error "CoverageMatrixMismatch" "Coverage Matrix does not map $requirement_id to Task $task_number." || return 1
      }
      spec_task_refs+="$requirement_id|"
    done <<< "$coverage_ids"

    if [[ "$(normalize_whitespace "${PLAN_STRUCTURE_TASK_OPEN_QUESTIONS[$task_index]}")" != "none" ]]; then
      set_contract_error "TaskOpenQuestionsNotResolved" "Task $task_number has unresolved Open Questions." || return 1
    fi

    detect_ambiguous_task_wording "${PLAN_STRUCTURE_TASK_BLOCKS[$task_index]}" "$task_number" || return 1
    detect_requirement_weakening "${PLAN_STRUCTURE_TASK_BLOCKS[$task_index]}" "$task_number" "$coverage_ids" || return 1
  done

  for ((matrix_index=0; matrix_index<COVERAGE_MATRIX_COUNT; matrix_index++)); do
    requirement_id="${COVERAGE_MATRIX_IDS[$matrix_index]}"
    find_spec_requirement_index "$requirement_id" >/dev/null 2>&1 || {
      set_contract_error "UnknownRequirementId" "Requirement Coverage Matrix references unknown requirement id $requirement_id." || return 1
    }
    while IFS= read -r matrix_task; do
      [[ -n "$matrix_task" ]] || continue
      plan_structure_find_task_index "$matrix_task" >/dev/null 2>&1 || {
        set_contract_error "CoverageMatrixMismatch" "Requirement Coverage Matrix references missing Task $matrix_task." || return 1
      }
    done <<< "${COVERAGE_MATRIX_TASKS[$matrix_index]}"
  done

  for requirement_id in "${SPEC_REQUIREMENT_IDS[@]}"; do
    if [[ "$spec_task_refs" != *"|$requirement_id|"* ]]; then
      set_contract_error "MissingRequirementCoverage" "$requirement_id is not covered by any task." || return 1
    fi
    find_coverage_matrix_index "$requirement_id" >/dev/null 2>&1 || {
      set_contract_error "MissingRequirementCoverage" "$requirement_id is missing from the Requirement Coverage Matrix." || return 1
    }
  done

  return 0
}

emit_string_array_json() {
  local value
  local first=1
  printf '['
  for value in "$@"; do
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '"%s"' "$(json_escape "$value")"
    first=0
  done
  printf ']'
}

emit_newline_list_json() {
  local values="$1"
  local first=1
  local item

  printf '['
  while IFS= read -r item; do
    [[ -n "$item" ]] || continue
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '"%s"' "$(json_escape "$item")"
    first=0
  done <<< "$values"
  printf ']'
}

emit_requirement_statements_json() {
  local coverage_ids="$1"
  local requirement_id
  local requirement_index
  local first=1

  printf '['
  while IFS= read -r requirement_id; do
    [[ -n "$requirement_id" ]] || continue
    requirement_index="$(find_spec_requirement_index "$requirement_id")" || continue
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '{'
    printf '"id":"%s",' "$(json_escape "$requirement_id")"
    printf '"type":"%s",' "$(json_escape "${SPEC_REQUIREMENT_TYPES[$requirement_index]}")"
    printf '"statement":"%s"' "$(json_escape "${SPEC_REQUIREMENT_STATEMENTS[$requirement_index]}")"
    printf '}'
    first=0
  done <<< "$coverage_ids"
  printf ']'
}

emit_file_entries_json() {
  local entries="$1"
  local entry action raw_path normalized_path
  local first=1

  printf '['
  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    action="${entry%%$'\t'*}"
    raw_path="${entry#*$'\t'}"
    normalized_path="${raw_path#*$'\t'}"
    raw_path="${raw_path%%$'\t'*}"
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '{'
    printf '"action":"%s",' "$(json_escape "$action")"
    printf '"path":"%s",' "$(json_escape "$raw_path")"
    printf '"normalized_path":"%s"' "$(json_escape "$normalized_path")"
    printf '}'
    first=0
  done <<< "$entries"
  printf ']'
}

emit_coverage_json() {
  local i
  local first=1
  local task

  printf '{'
  for ((i=0; i<COVERAGE_MATRIX_COUNT; i++)); do
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    printf '"%s":[' "$(json_escape "${COVERAGE_MATRIX_IDS[$i]}")"
    local first_task=1
    while IFS= read -r task; do
      [[ -n "$task" ]] || continue
      if [[ $first_task -eq 0 ]]; then
        printf ','
      fi
      printf '%s' "$task"
      first_task=0
    done <<< "${COVERAGE_MATRIX_TASKS[$i]}"
    printf ']'
    first=0
  done
  printf '}'
}

build_packet_markdown() {
  local plan_path="$1"
  local plan_revision="$2"
  local plan_fingerprint="$3"
  local source_spec_path="$4"
  local source_spec_revision="$5"
  local source_spec_fingerprint="$6"
  local task_number="$7"
  local task_title="$8"
  local coverage_ids="$9"
  local open_questions="${10}"
  local constraints="${11}"
  local task_block="${12}"
  local generated_at="${13}"
  local packet_fingerprint="${14}"
  local requirement_id=""
  local requirement_index
  local constraint=""

  printf '## Task Packet\n\n'
  printf '**Plan Path:** `%s`\n' "$plan_path"
  printf '**Plan Revision:** %s\n' "$plan_revision"
  printf '**Plan Fingerprint:** `%s`\n' "$plan_fingerprint"
  printf '**Source Spec Path:** `%s`\n' "$source_spec_path"
  printf '**Source Spec Revision:** %s\n' "$source_spec_revision"
  printf '**Source Spec Fingerprint:** `%s`\n' "$source_spec_fingerprint"
  printf '**Task Number:** %s\n' "$task_number"
  printf '**Task Title:** %s\n' "$task_title"
  printf '**Open Questions:** %s\n' "$open_questions"
  printf '**Packet Fingerprint:** `%s`\n' "$packet_fingerprint"
  printf '**Generated At:** %s\n\n' "$generated_at"

  printf '## Covered Requirements\n\n'
  while IFS= read -r requirement_id; do
    [[ -n "$requirement_id" ]] || continue
    requirement_index="$(find_spec_requirement_index "$requirement_id")" || continue
    printf -- '- [%s][%s] %s\n' \
      "$requirement_id" \
      "${SPEC_REQUIREMENT_TYPES[$requirement_index]}" \
      "${SPEC_REQUIREMENT_STATEMENTS[$requirement_index]}"
  done <<< "$coverage_ids"
  printf '\n'

  printf '## Plan Constraints\n\n'
  while IFS= read -r constraint; do
    [[ -n "$constraint" ]] || continue
    printf -- '- %s\n' "$constraint"
  done <<< "$constraints"
  printf '\n'

  printf '## Task Block\n\n'
  printf '%s\n' "$task_block"
}

packet_dir_path() {
  local slug_env=""
  local SLUG=""
  local BRANCH=""

  slug_env="$("$SCRIPT_DIR/superpowers-slug" 2>/dev/null || true)"
  if [[ -n "$slug_env" ]]; then
    eval "$slug_env"
  fi
  [[ -n "${SLUG:-}" ]] || SLUG="superpowers"
  [[ -n "${BRANCH:-}" ]] || BRANCH="current"
  printf '%s/projects/%s/%s-%s-task-packets\n' "$STATE_DIR" "$SLUG" "$USER_NAME" "$BRANCH"
}

packet_cache_path() {
  local plan_rel="$1"
  local task_number="$2"
  local plan_base
  local safe_base

  plan_base="$(basename "$plan_rel" .md)"
  safe_base="$(normalize_identifier_token "$plan_base")"
  printf '%s/%s-task-%s.packet.md\n' "$(packet_dir_path)" "$safe_base" "$task_number"
}

packet_cache_matches_current() {
  local cache_path="$1"
  local expected_plan_path="$2"
  local expected_plan_revision="$3"
  local expected_plan_fingerprint="$4"
  local expected_source_spec_path="$5"
  local expected_source_spec_revision="$6"
  local expected_source_spec_fingerprint="$7"
  local expected_task_number="$8"
  local expected_packet_fingerprint="$9"
  local line key value body_marker=0
  local cached_plan_path=""
  local cached_plan_revision=""
  local cached_plan_fingerprint=""
  local cached_source_spec_path=""
  local cached_source_spec_revision=""
  local cached_source_spec_fingerprint=""
  local cached_task_number=""
  local cached_packet_fingerprint=""

  [[ -f "$cache_path" ]] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "---" ]]; then
      body_marker=1
      break
    fi
    [[ "$line" == *=* ]] || return 1
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      plan_path) cached_plan_path="$value" ;;
      plan_revision) cached_plan_revision="$value" ;;
      plan_fingerprint) cached_plan_fingerprint="$value" ;;
      source_spec_path) cached_source_spec_path="$value" ;;
      source_spec_revision) cached_source_spec_revision="$value" ;;
      source_spec_fingerprint) cached_source_spec_fingerprint="$value" ;;
      task_number) cached_task_number="$value" ;;
      packet_fingerprint) cached_packet_fingerprint="$value" ;;
    esac
  done < "$cache_path"

  (( body_marker == 1 )) || return 1
  [[ -n "$cached_plan_path" && -n "$cached_packet_fingerprint" ]] || return 1

  [[ "$cached_plan_path" == "$expected_plan_path" ]] || return 1
  [[ "$cached_plan_revision" == "$expected_plan_revision" ]] || return 1
  [[ "$cached_plan_fingerprint" == "$expected_plan_fingerprint" ]] || return 1
  [[ "$cached_source_spec_path" == "$expected_source_spec_path" ]] || return 1
  [[ "$cached_source_spec_revision" == "$expected_source_spec_revision" ]] || return 1
  [[ "$cached_source_spec_fingerprint" == "$expected_source_spec_fingerprint" ]] || return 1
  [[ "$cached_task_number" == "$expected_task_number" ]] || return 1
  [[ "$cached_packet_fingerprint" == "$expected_packet_fingerprint" ]] || return 1

  return 0
}

write_packet_cache() {
  local cache_path="$1"
  local plan_path="$2"
  local plan_revision="$3"
  local plan_fingerprint="$4"
  local source_spec_path="$5"
  local source_spec_revision="$6"
  local source_spec_fingerprint="$7"
  local task_number="$8"
  local packet_fingerprint="$9"
  local generated_at="${10}"
  local packet_markdown="${11}"
  local tmp_path

  mkdir -p "$(dirname "$cache_path")"
  tmp_path="$(mktemp "${cache_path}.tmp.XXXXXX")"
  {
    printf 'plan_path=%s\n' "$plan_path"
    printf 'plan_revision=%s\n' "$plan_revision"
    printf 'plan_fingerprint=%s\n' "$plan_fingerprint"
    printf 'source_spec_path=%s\n' "$source_spec_path"
    printf 'source_spec_revision=%s\n' "$source_spec_revision"
    printf 'source_spec_fingerprint=%s\n' "$source_spec_fingerprint"
    printf 'task_number=%s\n' "$task_number"
    printf 'packet_fingerprint=%s\n' "$packet_fingerprint"
    printf 'generated_at=%s\n' "$generated_at"
    printf -- '---\n'
    printf '%s\n' "$packet_markdown"
  } > "$tmp_path"
  mv "$tmp_path" "$cache_path"
}

prune_packet_cache() {
  local packet_dir="$1"
  local limit="$PACKET_RETENTION_LIMIT"
  local path
  local index=0

  [[ "$limit" =~ ^[0-9]+$ ]] || limit=20
  (( limit > 0 )) || limit=20
  [[ -d "$packet_dir" ]] || return 0

  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    index=$((index + 1))
    if (( index > limit )); then
      rm -f "$path"
    fi
  done < <(ls -1t "$packet_dir"/*.packet.md 2>/dev/null || true)
}

build_packet_fingerprint() {
  local plan_path="$1"
  local plan_revision="$2"
  local plan_fingerprint="$3"
  local source_spec_path="$4"
  local source_spec_revision="$5"
  local source_spec_fingerprint="$6"
  local task_number="$7"
  local task_title="$8"
  local coverage_ids="$9"
  local constraints="${10}"
  local task_block="${11}"

  {
    printf 'plan_path=%s\n' "$plan_path"
    printf 'plan_revision=%s\n' "$plan_revision"
    printf 'plan_fingerprint=%s\n' "$plan_fingerprint"
    printf 'source_spec_path=%s\n' "$source_spec_path"
    printf 'source_spec_revision=%s\n' "$source_spec_revision"
    printf 'source_spec_fingerprint=%s\n' "$source_spec_fingerprint"
    printf 'task_number=%s\n' "$task_number"
    printf 'task_title=%s\n' "$task_title"
    printf 'coverage=%s\n' "$coverage_ids"
    printf 'constraints=%s\n' "$constraints"
    printf '%s\n' "$task_block"
  } | hash_stream
}

cmd_lint() {
  local spec_rel=""
  local plan_rel=""
  local spec_abs=""
  local plan_abs=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --spec) spec_rel="${2:-}"; shift 2 ;;
      --plan) plan_rel="${2:-}"; shift 2 ;;
      *) emit_error "InvalidCommandInput" "Unknown lint argument '$1'."; return 1 ;;
    esac
  done

  [[ -n "$spec_rel" && -n "$plan_rel" ]] || {
    emit_error "InvalidCommandInput" "lint requires --spec and --plan."
    return 1
  }

  spec_rel="$(normalize_required_repo_path "$spec_rel" "spec path")" || return 1
  plan_rel="$(normalize_required_repo_path "$plan_rel" "plan path")" || return 1
  spec_abs="$(plan_rel_to_abs "$spec_rel")"
  plan_abs="$(plan_rel_to_abs "$plan_rel")"

  [[ -f "$plan_abs" ]] || {
    emit_error "PlanContractInvalid" "Plan file does not exist."
    return 1
  }
  [[ -f "$spec_abs" ]] || {
    emit_lint_error "MissingRequirementIndex" "Spec file does not exist." "$spec_rel" "$plan_rel"
    return 1
  }
  parse_plan_headers "$plan_abs" || {
    emit_lint_error "UnexpectedPlanContractFailure" "Plan headers are missing or malformed." "$spec_rel" "$plan_rel"
    return 1
  }
  if [[ "$PLAN_SOURCE_SPEC" != "$spec_rel" ]]; then
    emit_lint_error "UnexpectedPlanContractFailure" "Plan Source Spec does not match the provided spec path." "$spec_rel" "$plan_rel"
    return 1
  fi
  if ! validate_plan_contract "$spec_abs" "$plan_abs"; then
    emit_lint_error "$CONTRACT_ERROR_CLASS" "$CONTRACT_ERROR_MESSAGE" "$spec_rel" "$plan_rel"
    return 1
  fi

  printf '{'
  printf '"status":"ok",'
  printf '"errors":[],'
  printf '"warnings":[],'
  printf '"spec_requirement_count":%s,' "$SPEC_REQUIREMENT_COUNT"
  printf '"plan_task_count":%s,' "$PLAN_STRUCTURE_TASK_COUNT"
  printf '"coverage":'
  emit_coverage_json
  printf '}'
  printf '\n'
}

cmd_build_task_packet() {
  local plan_rel=""
  local task_number=""
  local output_format="json"
  local persist="no"
  local plan_abs=""
  local spec_abs=""
  local task_index=""
  local coverage_ids=""
  local plan_fingerprint=""
  local source_spec_fingerprint=""
  local packet_fingerprint=""
  local packet_markdown=""
  local generated_at=""
  local packet_path="null"
  local cache_status="ephemeral"
  local persisted=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan) plan_rel="${2:-}"; shift 2 ;;
      --task) task_number="${2:-}"; shift 2 ;;
      --format)
        output_format="${2:-}"
        shift 2
        ;;
      --persist)
        persist="${2:-}"
        shift 2
        ;;
      *)
        emit_error "InvalidCommandInput" "Unknown build-task-packet argument '$1'."
        return 1
        ;;
    esac
  done

  [[ -n "$plan_rel" && -n "$task_number" ]] || {
    emit_error "InvalidCommandInput" "build-task-packet requires --plan and --task."
    return 1
  }

  case "$output_format" in
    json|markdown) ;;
    *)
      emit_error "InvalidCommandInput" "format must be json or markdown."
      return 1
      ;;
  esac

  case "$persist" in
    yes|no) ;;
    *)
      emit_error "InvalidCommandInput" "persist must be yes or no."
      return 1
      ;;
  esac

  plan_rel="$(normalize_required_repo_path "$plan_rel" "plan path")" || return 1
  plan_abs="$(plan_rel_to_abs "$plan_rel")"
  [[ -f "$plan_abs" ]] || {
    emit_error "PlanContractInvalid" "Plan file does not exist."
    return 1
  }
  parse_plan_headers "$plan_abs" || {
    emit_error "UnsupportedPlanRevision" "Plan headers are missing or malformed."
    return 1
  }
  spec_abs="$(plan_rel_to_abs "$PLAN_SOURCE_SPEC")"
  [[ -f "$spec_abs" ]] || {
    emit_error "SourceSpecUnavailable" "Source spec cannot be loaded from the approved plan."
    return 1
  }
  if ! validate_plan_contract "$spec_abs" "$plan_abs"; then
    emit_error "PlanContractInvalid" "$CONTRACT_ERROR_CLASS: $CONTRACT_ERROR_MESSAGE"
    return 1
  fi
  task_index="$(plan_structure_find_task_index "$task_number")" || {
    emit_error "TaskNotFound" "Task $task_number does not exist in the approved plan."
    return 1
  }

  coverage_ids="$(parse_task_coverage_ids "${PLAN_STRUCTURE_TASK_SPEC_COVERAGE[$task_index]}")"
  plan_fingerprint="$(hash_file "$plan_abs")" || {
    emit_error "TaskPacketBuildFailed" "Could not fingerprint the approved plan."
    return 1
  }
  source_spec_fingerprint="$(hash_file "$spec_abs")" || {
    emit_error "SourceSpecUnavailable" "Could not fingerprint the source spec."
    return 1
  }
  packet_fingerprint="$(build_packet_fingerprint \
    "$plan_rel" \
    "$PLAN_REVISION" \
    "$plan_fingerprint" \
    "$PLAN_SOURCE_SPEC" \
    "$PLAN_SOURCE_SPEC_REVISION" \
    "$source_spec_fingerprint" \
    "$task_number" \
    "${PLAN_STRUCTURE_TASK_TITLES[$task_index]}" \
    "$coverage_ids" \
    "${PLAN_STRUCTURE_TASK_CONSTRAINTS[$task_index]}" \
    "${PLAN_STRUCTURE_TASK_BLOCKS[$task_index]}")"
  generated_at="$(timestamp_utc)"
  packet_markdown="$(build_packet_markdown \
    "$plan_rel" \
    "$PLAN_REVISION" \
    "$plan_fingerprint" \
    "$PLAN_SOURCE_SPEC" \
    "$PLAN_SOURCE_SPEC_REVISION" \
    "$source_spec_fingerprint" \
    "$task_number" \
    "${PLAN_STRUCTURE_TASK_TITLES[$task_index]}" \
    "$coverage_ids" \
    "${PLAN_STRUCTURE_TASK_OPEN_QUESTIONS[$task_index]}" \
    "${PLAN_STRUCTURE_TASK_CONSTRAINTS[$task_index]}" \
    "${PLAN_STRUCTURE_TASK_BLOCKS[$task_index]}" \
    "$generated_at" \
    "$packet_fingerprint")"

  if [[ "$persist" == "yes" ]]; then
    persisted=true
    packet_path="$(packet_cache_path "$plan_rel" "$task_number")"
    if packet_cache_matches_current \
      "$packet_path" \
      "$plan_rel" \
      "$PLAN_REVISION" \
      "$plan_fingerprint" \
      "$PLAN_SOURCE_SPEC" \
      "$PLAN_SOURCE_SPEC_REVISION" \
      "$source_spec_fingerprint" \
      "$task_number" \
      "$packet_fingerprint"; then
      cache_status="reused"
    else
      if [[ -f "$packet_path" ]]; then
        cache_status="regenerated"
      else
        cache_status="fresh"
      fi
      write_packet_cache \
        "$packet_path" \
        "$plan_rel" \
        "$PLAN_REVISION" \
        "$plan_fingerprint" \
        "$PLAN_SOURCE_SPEC" \
        "$PLAN_SOURCE_SPEC_REVISION" \
        "$source_spec_fingerprint" \
        "$task_number" \
        "$packet_fingerprint" \
        "$generated_at" \
        "$packet_markdown" || {
          emit_error "TaskPacketBuildFailed" "Could not persist the task packet."
          return 1
        }
    fi
    prune_packet_cache "$(dirname "$packet_path")"
  fi

  if [[ "$output_format" == "markdown" ]]; then
    printf '%s\n' "$packet_markdown"
    return 0
  fi

  printf '{'
  printf '"status":"ok",'
  printf '"plan_path":"%s",' "$(json_escape "$plan_rel")"
  printf '"plan_revision":%s,' "$PLAN_REVISION"
  printf '"plan_fingerprint":"%s",' "$(json_escape "$plan_fingerprint")"
  printf '"source_spec_path":"%s",' "$(json_escape "$PLAN_SOURCE_SPEC")"
  printf '"source_spec_revision":%s,' "$PLAN_SOURCE_SPEC_REVISION"
  printf '"source_spec_fingerprint":"%s",' "$(json_escape "$source_spec_fingerprint")"
  printf '"task_number":%s,' "$task_number"
  printf '"task_title":"%s",' "$(json_escape "${PLAN_STRUCTURE_TASK_TITLES[$task_index]}")"
  printf '"task_block":"%s",' "$(json_escape "${PLAN_STRUCTURE_TASK_BLOCKS[$task_index]}")"
  printf '"step_list":'
  emit_newline_list_json "${PLAN_STRUCTURE_TASK_STEPS_RAW[$task_index]}"
  printf ','
  printf '"file_entries":'
  emit_file_entries_json "${PLAN_STRUCTURE_TASK_FILE_ENTRIES[$task_index]}"
  printf ','
  printf '"file_scope":'
  emit_newline_list_json "${PLAN_STRUCTURE_TASK_FILE_SCOPE[$task_index]}"
  printf ','
  printf '"requirement_ids":'
  emit_newline_list_json "$coverage_ids"
  printf ','
  printf '"requirement_statements":'
  emit_requirement_statements_json "$coverage_ids"
  printf ','
  printf '"plan_constraints":'
  emit_newline_list_json "${PLAN_STRUCTURE_TASK_CONSTRAINTS[$task_index]}"
  printf ','
  printf '"open_questions":"%s",' "$(json_escape "${PLAN_STRUCTURE_TASK_OPEN_QUESTIONS[$task_index]}")"
  printf '"packet_timestamp":"%s",' "$(json_escape "$generated_at")"
  printf '"packet_fingerprint":"%s",' "$(json_escape "$packet_fingerprint")"
  printf '"persisted":%s,' "$persisted"
  printf '"cache_status":"%s",' "$(json_escape "$cache_status")"
  if [[ "$persisted" == true ]]; then
    printf '"packet_path":"%s",' "$(json_escape "$packet_path")"
  else
    printf '"packet_path":null,'
  fi
  printf '"packet_markdown":"%s"' "$(json_escape "$packet_markdown")"
  printf '}'
  printf '\n'
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    lint) cmd_lint "$@" ;;
    build-task-packet) cmd_build_task_packet "$@" ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      emit_error "InvalidCommandInput" "Unknown subcommand '$command'."
      return 1
      ;;
  esac
}

main "$@"
