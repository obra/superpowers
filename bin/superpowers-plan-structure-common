#!/usr/bin/env bash

plan_structure_reset() {
  PLAN_STRUCTURE_ERROR_CLASS=""
  PLAN_STRUCTURE_ERROR_MESSAGE=""
  PLAN_STRUCTURE_TASK_COUNT=0
  PLAN_STRUCTURE_TASK_NUMBERS=()
  PLAN_STRUCTURE_TASK_TITLES=()
  PLAN_STRUCTURE_TASK_BLOCKS=()
  PLAN_STRUCTURE_TASK_SPEC_COVERAGE=()
  PLAN_STRUCTURE_TASK_OUTCOMES=()
  PLAN_STRUCTURE_TASK_CONSTRAINTS=()
  PLAN_STRUCTURE_TASK_OPEN_QUESTIONS=()
  PLAN_STRUCTURE_TASK_FILES_RAW=()
  PLAN_STRUCTURE_TASK_FILE_ENTRIES=()
  PLAN_STRUCTURE_TASK_FILE_SCOPE=()
  PLAN_STRUCTURE_TASK_STEPS_RAW=()
}

plan_structure_set_error() {
  PLAN_STRUCTURE_ERROR_CLASS="$1"
  PLAN_STRUCTURE_ERROR_MESSAGE="$2"
  return 1
}

plan_structure_strip_file_reference_suffix() {
  printf '%s' "$1" | sed -E 's/:[0-9]+([:-][0-9]+)*$//'
}

plan_structure_normalize_scope_path() {
  local raw_value="$1"
  local stripped

  stripped="$(plan_structure_strip_file_reference_suffix "$raw_value")"
  normalize_repo_relative_path "$stripped"
}

plan_structure_find_task_index() {
  local task_number="$1"
  local i

  for ((i=0; i<PLAN_STRUCTURE_TASK_COUNT; i++)); do
    if [[ "${PLAN_STRUCTURE_TASK_NUMBERS[$i]}" == "$task_number" ]]; then
      printf '%s\n' "$i"
      return 0
    fi
  done

  return 1
}

plan_structure_parse() {
  local plan_abs="$1"
  local require_full_fields="${PLAN_STRUCTURE_REQUIRE_FULL_TASK_FIELDS:-yes}"
  local line
  local current_task=""
  local current_title=""
  local current_block=""
  local current_spec_coverage=""
  local current_outcome=""
  local current_constraints=""
  local current_open_questions=""
  local current_files_raw=""
  local current_file_entries=""
  local current_file_scope=""
  local current_steps_raw=""
  local current_task_seen="|"
  local current_step_seen="|"
  local in_constraints=0
  local in_files=0
  local files_seen=0
  local files_count=0
  local steps_count=0
  local task_index=0
  local normalized_line=""
  local file_action=""
  local file_path=""
  local normalized_scope=""
  local current_step=""
  local current_step_title=""

  plan_structure_reset
  [[ -f "$plan_abs" ]] || {
    plan_structure_set_error "MalformedTaskStructure" "Plan file does not exist."
    return 1
  }

  plan_structure_finalize_current_task() {
    if [[ -z "$current_task" ]]; then
      return 0
    fi

    if [[ "$require_full_fields" != "no" ]]; then
      if [[ -z "$current_spec_coverage" ]]; then
        plan_structure_set_error "TaskMissingSpecCoverage" "Task $current_task is missing Spec Coverage."
        return 1
      fi
      if [[ -z "$current_outcome" ]]; then
        plan_structure_set_error "MalformedTaskStructure" "Task $current_task is missing Task Outcome."
        return 1
      fi
      if [[ -z "$current_constraints" ]]; then
        plan_structure_set_error "MalformedTaskStructure" "Task $current_task is missing Plan Constraints."
        return 1
      fi
      if [[ -z "$current_open_questions" ]]; then
        plan_structure_set_error "MalformedTaskStructure" "Task $current_task is missing Open Questions."
        return 1
      fi
    fi
    if (( files_seen == 0 || files_count == 0 )); then
      plan_structure_set_error "MalformedFilesBlock" "Task $current_task is missing a parseable Files block."
      return 1
    fi
    if (( steps_count == 0 )); then
      plan_structure_set_error "MalformedTaskStructure" "Task $current_task must include at least one step."
      return 1
    fi

    PLAN_STRUCTURE_TASK_NUMBERS[$task_index]="$current_task"
    PLAN_STRUCTURE_TASK_TITLES[$task_index]="$current_title"
    PLAN_STRUCTURE_TASK_BLOCKS[$task_index]="${current_block%$'\n'}"
    PLAN_STRUCTURE_TASK_SPEC_COVERAGE[$task_index]="$current_spec_coverage"
    PLAN_STRUCTURE_TASK_OUTCOMES[$task_index]="$current_outcome"
    PLAN_STRUCTURE_TASK_CONSTRAINTS[$task_index]="${current_constraints%$'\n'}"
    PLAN_STRUCTURE_TASK_OPEN_QUESTIONS[$task_index]="$current_open_questions"
    PLAN_STRUCTURE_TASK_FILES_RAW[$task_index]="${current_files_raw%$'\n'}"
    PLAN_STRUCTURE_TASK_FILE_ENTRIES[$task_index]="${current_file_entries%$'\n'}"
    PLAN_STRUCTURE_TASK_FILE_SCOPE[$task_index]="${current_file_scope%$'\n'}"
    PLAN_STRUCTURE_TASK_STEPS_RAW[$task_index]="${current_steps_raw%$'\n'}"
    task_index=$((task_index + 1))

    current_task=""
    current_title=""
    current_block=""
    current_spec_coverage=""
    current_outcome=""
    current_constraints=""
    current_open_questions=""
    current_files_raw=""
    current_file_entries=""
    current_file_scope=""
    current_steps_raw=""
    current_step_seen="|"
    in_constraints=0
    in_files=0
    files_seen=0
    files_count=0
    steps_count=0
    return 0
  }

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^###\ Task\ ([0-9]+): ]]; then
      plan_structure_set_error "MalformedTaskStructure" "Task headings must use canonical '## Task N:' form."
      return 1
    fi

    if [[ "$line" =~ ^##\ Task\ ([0-9]+):\ (.+)$ ]]; then
      plan_structure_finalize_current_task || return 1
      current_task="${BASH_REMATCH[1]}"
      current_title="${BASH_REMATCH[2]}"
      case "$current_task_seen" in
        *"|$current_task|"*)
          plan_structure_set_error "MalformedTaskStructure" "Task numbers must be unique within the plan."
          return 1
          ;;
      esac
      current_task_seen+="$current_task|"
      current_block+="$line"$'\n'
      continue
    fi

    if [[ -z "$current_task" ]]; then
      continue
    fi

    current_block+="$line"$'\n'
    normalized_line="$(normalize_whitespace "$line")"

    if (( in_constraints )); then
      if [[ "$line" =~ ^-\ (.+)$ ]]; then
        current_constraints+="${BASH_REMATCH[1]}"$'\n'
        continue
      fi
      if [[ -z "$normalized_line" ]]; then
        continue
      fi
      in_constraints=0
    fi

    if (( in_files )); then
      if [[ "$line" =~ ^-\ (Create|Modify|Delete|Test):\ \`(.+)\`$ ]]; then
        file_action="${BASH_REMATCH[1]}"
        file_path="${BASH_REMATCH[2]}"
        normalized_scope="$(plan_structure_normalize_scope_path "$file_path")" || {
          plan_structure_set_error "MalformedFilesBlock" "Task $current_task contains an invalid Files entry path."
          return 1
        }
        current_files_raw+="$line"$'\n'
        current_file_entries+="$file_action"$'\t'"$file_path"$'\t'"$normalized_scope"$'\n'
        current_file_scope+="$normalized_scope"$'\n'
        files_count=$((files_count + 1))
        continue
      fi
      if [[ -z "$normalized_line" ]]; then
        continue
      fi
      if [[ "$line" =~ ^-\ \[[[:space:]x]\]\ \*\*Step\ ([0-9]+):\ (.*)\*\*$ ]]; then
        in_files=0
      else
        plan_structure_set_error "MalformedFilesBlock" "Task $current_task contains a malformed Files block."
        return 1
      fi
    fi

    if [[ "$line" =~ ^\*\*Spec\ Coverage:\*\*\ (.+)$ ]]; then
      current_spec_coverage="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" =~ ^\*\*Task\ Outcome:\*\*\ (.+)$ ]]; then
      current_outcome="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" == "**Plan Constraints:**" ]]; then
      in_constraints=1
      continue
    fi
    if [[ "$line" =~ ^\*\*Open\ Questions:\*\*\ (.+)$ ]]; then
      current_open_questions="${BASH_REMATCH[1]}"
      continue
    fi
    if [[ "$line" == "**Files:**" ]]; then
      files_seen=1
      in_files=1
      continue
    fi
    if [[ "$line" =~ ^-\ \[[[:space:]x]\]\ \*\*Step\ ([0-9]+):\ (.*)\*\*$ ]]; then
      if (( files_seen == 0 )); then
        plan_structure_set_error "MalformedTaskStructure" "Task $current_task steps must appear after a Files block."
        return 1
      fi
      current_step="${BASH_REMATCH[1]}"
      current_step_title="${BASH_REMATCH[2]}"
      case "$current_step_seen" in
        *"|$current_step|"*)
          plan_structure_set_error "MalformedTaskStructure" "Task $current_task has duplicate Step $current_step."
          return 1
          ;;
      esac
      current_step_seen+="$current_step|"
      current_steps_raw+="$line"$'\n'
      steps_count=$((steps_count + 1))
      continue
    fi
  done < "$plan_abs"

  plan_structure_finalize_current_task || return 1
  PLAN_STRUCTURE_TASK_COUNT="$task_index"
  return 0
}
