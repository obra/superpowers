#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

resolve_runtime_entry() {
  if [[ -x "$SCRIPT_DIR/../compat/bash/superpowers" ]]; then
    printf '%s\n' "$SCRIPT_DIR/../compat/bash/superpowers"
    return 0
  fi

  local source="$SCRIPT_PATH"
  while [[ -L "$source" ]]; do
    local source_dir target
    source_dir="$(cd "$(dirname "$source")" && pwd)"
    target="$(readlink "$source")"
    if [[ "$target" == /* ]]; then
      source="$target"
    else
      source="$source_dir/$target"
    fi
  done

  local real_dir
  real_dir="$(cd "$(dirname "$source")" && pwd)"
  printf '%s\n' "$real_dir/../compat/bash/superpowers"
}

exec "$(resolve_runtime_entry)" update-check "$@"
