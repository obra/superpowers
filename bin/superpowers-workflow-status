#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/superpowers-runtime-common.sh
. "$SCRIPT_DIR/superpowers-runtime-common.sh"
# shellcheck source=bin/superpowers-plan-structure-common
. "$SCRIPT_DIR/superpowers-plan-structure-common"
STATE_DIR="${SUPERPOWERS_STATE_DIR:-$HOME/.superpowers}"
GIT_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
REPO_CONTEXT_AVAILABLE=1
if [ -n "$GIT_REPO_ROOT" ]; then
  REPO_ROOT="$GIT_REPO_ROOT"
else
  REPO_ROOT="$(pwd)"
  REPO_CONTEXT_AVAILABLE=0
fi

hash_repo_root() {
  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$REPO_ROOT" | shasum -a 256 | awk '{print substr($1, 1, 12)}'
    return
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$REPO_ROOT" | sha256sum | awk '{print substr($1, 1, 12)}'
    return
  fi
  printf '%s' "$REPO_ROOT" | cksum | awk '{print $1}'
}

derive_repo_slug() {
  local remote_url="$1"
  local slug repo_base
  slug="$(printf '%s\n' "$remote_url" | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1|;s|.*[:/]\([^/]*/[^/]*\)$|\1|' | tr '/' '-')"
  if [ -n "$slug" ]; then
    printf '%s\n' "$slug"
    return
  fi
  repo_base="$(basename "$REPO_ROOT")"
  printf '%s-%s\n' "$repo_base" "$(hash_repo_root)"
}

REMOTE_URL="$(git remote get-url origin 2>/dev/null || true)"
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo current)"
[ -n "$BRANCH" ] || BRANCH="current"
[ "$BRANCH" != "HEAD" ] || BRANCH="current"
RAW_BRANCH="$BRANCH"
SLUG=""
SAFE_BRANCH=""
if [ -x "$SCRIPT_DIR/superpowers-slug" ]; then
  IDENTITY_OUTPUT="$("$SCRIPT_DIR/superpowers-slug" 2>/dev/null || true)"
  if [ -n "$IDENTITY_OUTPUT" ]; then
    eval "$IDENTITY_OUTPUT"
    SAFE_BRANCH="$BRANCH"
  fi
fi
[ -n "$SLUG" ] || SLUG="$(derive_repo_slug "$REMOTE_URL")"
[ -n "$SAFE_BRANCH" ] || SAFE_BRANCH="$(normalize_identifier_token "$RAW_BRANCH")"
BRANCH="$RAW_BRANCH"
USER_NAME="$(whoami 2>/dev/null || echo user)"
MANIFEST_PATH="$STATE_DIR/projects/$SLUG/${USER_NAME}-${SAFE_BRANCH}-workflow-state.json"
FALLBACK_LIMIT="${SUPERPOWERS_WORKFLOW_STATUS_FALLBACK_LIMIT:-6}"
case "$FALLBACK_LIMIT" in
  ''|*[!0-9]*|0) FALLBACK_LIMIT=6 ;;
esac
RECOVERY_CANDIDATE_LIMIT=12

MANIFEST_SPEC_PATH=""
MANIFEST_PLAN_PATH=""
MANIFEST_STATUS=""
MANIFEST_NEXT_SKILL=""
MANIFEST_REASON=""
MANIFEST_REPO_ROOT=""
MANIFEST_BRANCH=""
MANIFEST_SOURCE_PATH=""
MANIFEST_VALID=0
MANIFEST_CORRUPT=0
MANIFEST_RECOVERED=0
MANIFEST_RECOVERY_AMBIGUOUS=0
MANIFEST_IDENTITY_MISMATCH=0
MANIFEST_IDENTITY_REASON=""

RESOLVED_SPEC_PATH=""
RESOLVED_PLAN_PATH=""
STATUS_CODE="needs_brainstorming"
NEXT_SKILL="superpowers:brainstorming"
STATUS_NOTE=""
CONTRACT_STATE="unknown"
SCHEMA_VERSION=2
SCAN_TRUNCATED="false"
SPEC_CANDIDATE_COUNT=0
PLAN_CANDIDATE_COUNT=0
STATUS_REASON_CODES=()
STATUS_DIAGNOSTICS=()

usage() {
  echo "Usage: superpowers-workflow-status {status|resolve|expect|sync} ..."
}

ensure_manifest_dir() {
  mkdir -p "$(dirname "$MANIFEST_PATH")"
}

json_escape() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  printf '%s' "$value"
}

emit_json() {
  local status_code="$1"
  local next_skill="$2"
  local spec_path="$3"
  local plan_path="$4"
  local reason="${5:-}"
  printf '{'
  printf '"schema_version":%s,' "$SCHEMA_VERSION"
  printf '"status":"%s",' "$(json_escape "$status_code")"
  printf '"next_skill":"%s",' "$(json_escape "$next_skill")"
  printf '"spec_path":"%s",' "$(json_escape "$spec_path")"
  printf '"plan_path":"%s",' "$(json_escape "$plan_path")"
  printf '"contract_state":"%s",' "$(json_escape "$CONTRACT_STATE")"
  printf '"reason_codes":%s,' "$(emit_reason_codes_json "$reason")"
  printf '"diagnostics":%s,' "$(emit_diagnostics_json)"
  printf '"scan_truncated":%s,' "$SCAN_TRUNCATED"
  printf '"spec_candidate_count":%s,' "$SPEC_CANDIDATE_COUNT"
  printf '"plan_candidate_count":%s,' "$PLAN_CANDIDATE_COUNT"
  printf '"manifest_path":"%s",' "$(json_escape "$MANIFEST_PATH")"
  printf '"root":"%s"' "$(json_escape "$REPO_ROOT")"
  if [ -n "$reason" ]; then
    printf ',"reason":"%s"' "$(json_escape "$reason")"
    printf ',"note":"%s"' "$(json_escape "$reason")"
  fi
  printf '}\n'
}

emit_resolve_json() {
  local status_code="$1"
  local next_skill="$2"
  local spec_path="$3"
  local plan_path="$4"
  local reason="${5:-}"
  local source_path="${6:-}"
  printf '{'
  printf '"outcome":"resolved",'
  printf '"schema_version":%s,' "$SCHEMA_VERSION"
  printf '"status":"%s",' "$(json_escape "$status_code")"
  printf '"next_skill":"%s",' "$(json_escape "$next_skill")"
  printf '"spec_path":"%s",' "$(json_escape "$spec_path")"
  printf '"plan_path":"%s",' "$(json_escape "$plan_path")"
  printf '"contract_state":"%s",' "$(json_escape "$CONTRACT_STATE")"
  printf '"reason_codes":%s,' "$(emit_reason_codes_json "$reason")"
  printf '"diagnostics":%s,' "$(emit_diagnostics_json)"
  printf '"scan_truncated":%s,' "$SCAN_TRUNCATED"
  printf '"spec_candidate_count":%s,' "$SPEC_CANDIDATE_COUNT"
  printf '"plan_candidate_count":%s,' "$PLAN_CANDIDATE_COUNT"
  printf '"manifest_path":"%s",' "$(json_escape "$MANIFEST_PATH")"
  printf '"manifest_source_path":"%s",' "$(json_escape "$source_path")"
  printf '"root":"%s"' "$(json_escape "$REPO_ROOT")"
  if [ -n "$reason" ]; then
    printf ',"reason":"%s"' "$(json_escape "$reason")"
    printf ',"note":"%s"' "$(json_escape "$reason")"
  fi
  printf '}\n'
}

emit_resolve_failure() {
  local failure_class="$1"
  local message="$2"
  printf '{'
  printf '"outcome":"runtime_failure",'
  printf '"failure_class":"%s",' "$(json_escape "$failure_class")"
  printf '"message":"%s",' "$(json_escape "$message")"
  printf '"manifest_path":"%s",' "$(json_escape "$MANIFEST_PATH")"
  printf '"root":"%s"' "$(json_escape "$REPO_ROOT")"
  printf '}\n'
}

emit_summary() {
  local status_code="$1"
  local next_skill="$2"
  local spec_path="$3"
  local plan_path="$4"
  local reason="${5:-}"
  local next_display="$next_skill"

  if [ "$status_code" = "implementation_ready" ] && [ -z "$next_display" ]; then
    next_display="execution_preflight"
  fi

  printf 'status=%s next=%s spec=%s plan=%s reason=%s\n' \
    "$status_code" \
    "$next_display" \
    "$spec_path" \
    "$plan_path" \
    "$reason"
}

repo_path_exists() {
  local rel="$1"
  [ -n "$rel" ] || return 1
  [ -f "$REPO_ROOT/$rel" ]
}

manifest_get_string() {
  local json="$1"
  local key="$2"
  local value

  value="${json#*"\"$key\":\""}"
  if [[ "$value" == "$json" ]]; then
    printf '%s' ""
    return 0
  fi
  value="${value%%\"*}"
  printf '%s' "$value"
}

reset_manifest_fields() {
  MANIFEST_SPEC_PATH=""
  MANIFEST_PLAN_PATH=""
  MANIFEST_STATUS=""
  MANIFEST_NEXT_SKILL=""
  MANIFEST_REASON=""
  MANIFEST_REPO_ROOT=""
  MANIFEST_BRANCH=""
  MANIFEST_SOURCE_PATH=""
  MANIFEST_VALID=0
  MANIFEST_CORRUPT=0
}

reset_manifest_diagnostics() {
  MANIFEST_RECOVERED=0
  MANIFEST_RECOVERY_AMBIGUOUS=0
  MANIFEST_IDENTITY_MISMATCH=0
  MANIFEST_IDENTITY_REASON=""
}

read_manifest_file() {
  local path="$1"
  reset_manifest_fields

  if [ ! -f "$path" ]; then
    return 1
  fi

  local json
  local trimmed
  json="$(<"$path")"
  if [ -z "$json" ]; then
    MANIFEST_CORRUPT=1
    return 2
  fi
  trimmed="$(trim_surrounding_whitespace "$json")"
  [[ "$trimmed" == \{*\} ]] || {
    MANIFEST_CORRUPT=1
    return 2
  }
  if [[ "$json" != *'"version":1'* && "$json" != *'"version" :1'* && "$json" != *'"version": 1'* && "$json" != *'"version" : 1'* ]]; then
    MANIFEST_CORRUPT=1
    return 2
  fi

  MANIFEST_SPEC_PATH="$(manifest_get_string "$json" "expected_spec_path")"
  MANIFEST_PLAN_PATH="$(manifest_get_string "$json" "expected_plan_path")"
  MANIFEST_STATUS="$(manifest_get_string "$json" "status")"
  MANIFEST_NEXT_SKILL="$(manifest_get_string "$json" "next_skill")"
  MANIFEST_REASON="$(manifest_get_string "$json" "reason")"
  if [ -z "$MANIFEST_REASON" ]; then
    MANIFEST_REASON="$(manifest_get_string "$json" "note")"
  fi
  MANIFEST_REPO_ROOT="$(manifest_get_string "$json" "repo_root")"
  MANIFEST_BRANCH="$(manifest_get_string "$json" "branch")"
  MANIFEST_SOURCE_PATH="$path"
  MANIFEST_VALID=1
  return 0
}

read_manifest() {
  read_manifest_file "$MANIFEST_PATH"
}

write_manifest() {
  local payload="$1"
  local tmp
  tmp="$(mktemp "$MANIFEST_PATH.tmp.XXXXXX")"
  printf '%s\n' "$payload" > "$tmp"
  mv "$tmp" "$MANIFEST_PATH"
}

write_manifest_with_retry() {
  local payload="$1"
  local attempt
  for attempt in 1 2; do
    if write_manifest "$payload"; then
      return 0
    fi
    if [ "$attempt" -eq 1 ]; then
      printf 'warning: manifest write conflict, retrying once\n' >&2
    fi
  done
  return 1
}

backup_corrupt_manifest() {
  local stamp backup
  stamp="$(date +%Y%m%d-%H%M%S)"
  backup="$MANIFEST_PATH.corrupt-$stamp"
  mv "$MANIFEST_PATH" "$backup"
  printf 'warning: corrupted workflow manifest moved to %s\n' "$backup" >&2
}

manifest_payload() {
  local spec_path="$1"
  local plan_path="$2"
  local status_code="$3"
  local next_skill="$4"
  local reason="${5:-}"
  local now
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{'
  printf '"version":1,'
  printf '"repo_root":"%s",' "$(json_escape "$REPO_ROOT")"
  printf '"branch":"%s",' "$(json_escape "$BRANCH")"
  printf '"expected_spec_path":"%s",' "$(json_escape "$spec_path")"
  printf '"expected_plan_path":"%s",' "$(json_escape "$plan_path")"
  printf '"status":"%s",' "$(json_escape "$status_code")"
  printf '"next_skill":"%s",' "$(json_escape "$next_skill")"
  if [ -n "$reason" ]; then
    printf '"reason":"%s",' "$(json_escape "$reason")"
    printf '"note":"%s",' "$(json_escape "$reason")"
  fi
  printf '"updated_at":"%s"' "$(json_escape "$now")"
  printf '}'
}

spec_state=""
spec_revision=""
spec_reviewer=""

parse_spec_headers() {
  local path="$1"
  local line
  spec_state=""
  spec_revision=""
  spec_reviewer=""
  [ -f "$path" ] || return 1

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ -z "$spec_state" && "$line" =~ ^\*\*Workflow\ State:\*\*\ (Draft|CEO\ Approved)$ ]]; then
      spec_state="${BASH_REMATCH[1]}"
    elif [[ -z "$spec_revision" && "$line" =~ ^\*\*Spec\ Revision:\*\*\ ([0-9]+)$ ]]; then
      spec_revision="${BASH_REMATCH[1]}"
    elif [[ -z "$spec_reviewer" && "$line" =~ ^\*\*Last\ Reviewed\ By:\*\*\ (brainstorming|plan-ceo-review)$ ]]; then
      spec_reviewer="${BASH_REMATCH[1]}"
    fi

    [[ -n "$spec_state" && -n "$spec_revision" && -n "$spec_reviewer" ]] && break
  done < "$path"

  [ -n "$spec_state" ] && [ -n "$spec_revision" ] && [ -n "$spec_reviewer" ]
}

plan_state=""
plan_source_spec=""
plan_source_revision=""
plan_reviewer=""

parse_plan_headers() {
  local path="$1"
  plan_state=""
  plan_source_spec=""
  plan_source_revision=""
  plan_reviewer=""
  [ -f "$path" ] || return 1

  plan_structure_parse_plan_headers "$path" || return 1
  plan_state="$PLAN_STRUCTURE_PLAN_WORKFLOW_STATE"
  plan_source_spec="$PLAN_STRUCTURE_PLAN_SOURCE_SPEC"
  plan_source_revision="$PLAN_STRUCTURE_PLAN_SOURCE_SPEC_REVISION"
  plan_reviewer="$PLAN_STRUCTURE_PLAN_LAST_REVIEWED_BY"
  return 0
}

list_newest_candidates() {
  local dir="$1"
  [ -d "$dir" ] || return 0
  # shellcheck disable=SC2012
  ls -1t "$dir"/*.md 2>/dev/null | head -n "$FALLBACK_LIMIT" || true
}

rel_from_root() {
  local abs="$1"
  case "$abs" in
    "$REPO_ROOT"/*) printf '%s\n' "${abs#"$REPO_ROOT"/}" ;;
    *) return 1 ;;
  esac
}

SPEC_FROM_MANIFEST=0
SPEC_EXPECTED_MISSING=0
SPEC_VALID=0
SPEC_AMBIGUOUS=0
PLAN_FROM_MANIFEST=0
PLAN_EXPECTED_MISSING=0
PLAN_VALID=0
PLAN_AMBIGUOUS=0

reset_resolution_flags() {
  SPEC_FROM_MANIFEST=0
  SPEC_EXPECTED_MISSING=0
  SPEC_VALID=0
  SPEC_AMBIGUOUS=0
  PLAN_FROM_MANIFEST=0
  PLAN_EXPECTED_MISSING=0
  PLAN_VALID=0
  PLAN_AMBIGUOUS=0
}

reset_status_diagnostics() {
  CONTRACT_STATE="unknown"
  SCHEMA_VERSION=2
  SCAN_TRUNCATED="false"
  SPEC_CANDIDATE_COUNT=0
  PLAN_CANDIDATE_COUNT=0
  STATUS_NOTE=""
  STATUS_REASON_CODES=()
  STATUS_DIAGNOSTICS=()
}

append_status_note() {
  local note="$1"
  [ -n "$note" ] || return 0
  if [ -z "$STATUS_NOTE" ]; then
    STATUS_NOTE="$note"
  else
    STATUS_NOTE="${STATUS_NOTE},$note"
  fi
}

append_reason_code() {
  local code="$1"
  local existing
  local has_reason_codes=0
  [ -n "$code" ] || return 0
  if declare -p STATUS_REASON_CODES >/dev/null 2>&1; then
    has_reason_codes=1
  fi
  if [ "$has_reason_codes" -eq 1 ] && [ -n "${STATUS_REASON_CODES[*]-}" ]; then
    for existing in "${STATUS_REASON_CODES[@]}"; do
      [ "$existing" = "$code" ] && return 0
    done
  else
    STATUS_REASON_CODES=()
  fi
  STATUS_REASON_CODES+=("$code")
}

emit_reason_codes_json() {
  local fallback_reason="${1:-}"
  local i=0
  local split_reason
  local -a codes=()
  local has_reason_codes=0

  if declare -p STATUS_REASON_CODES >/dev/null 2>&1; then
    has_reason_codes=1
  fi

  if [ "$has_reason_codes" -eq 1 ] && [ -n "${STATUS_REASON_CODES[*]-}" ]; then
    codes=("${STATUS_REASON_CODES[@]}")
  elif [ -n "$fallback_reason" ]; then
    OLD_IFS="$IFS"
    IFS=','
    for split_reason in $fallback_reason; do
      [ -n "$split_reason" ] && codes+=("$split_reason")
    done
    IFS="$OLD_IFS"
  fi

  printf '['
  for ((i=0; i<${#codes[@]}; i++)); do
    [ "$i" -gt 0 ] && printf ','
    printf '"%s"' "$(json_escape "${codes[$i]}")"
  done
  printf ']'
}

append_diagnostic() {
  local code="$1"
  local severity="$2"
  local artifact="$3"
  local message="$4"
  local remediation="${5:-}"
  local diagnostic

  diagnostic='{"code":"'"$(json_escape "$code")"'","severity":"'"$(json_escape "$severity")"'","artifact":"'"$(json_escape "$artifact")"'","message":"'"$(json_escape "$message")"'","remediation":"'"$(json_escape "$remediation")"'"}'
  if ! declare -p STATUS_DIAGNOSTICS >/dev/null 2>&1; then
    STATUS_DIAGNOSTICS=()
  fi
  STATUS_DIAGNOSTICS+=("$diagnostic")
}

emit_diagnostics_json() {
  local i
  local count=0

  if declare -p STATUS_DIAGNOSTICS >/dev/null 2>&1; then
    if [ -n "${STATUS_DIAGNOSTICS[*]-}" ]; then
      count="${#STATUS_DIAGNOSTICS[@]}"
    fi
  fi

  printf '['
  for ((i=0; i<count; i++)); do
    [ "$i" -gt 0 ] && printf ','
    printf '%s' "${STATUS_DIAGNOSTICS[$i]}"
  done
  printf ']'
}

count_candidates_in_dir() {
  local dir="$1"
  local count=0
  local path

  [ -d "$dir" ] || {
    printf '0\n'
    return 0
  }

  shopt -s nullglob
  for path in "$dir"/*.md; do
    count=$((count + 1))
  done
  shopt -u nullglob

  printf '%s\n' "$count"
}

camel_to_snake() {
  printf '%s' "$1" | sed -E 's/([a-z0-9])([A-Z])/\1_\2/g' | tr 'A-Z' 'a-z'
}

json_field_string() {
  local json="$1"
  local key="$2"
  local value

  value="${json#*"\"$key\":\""}"
  if [[ "$value" == "$json" ]]; then
    printf '%s' ""
    return 0
  fi
  value="${value%%\"*}"
  printf '%s' "$value"
}

record_contract_header_failure() {
  local artifact="$1"
  local reason_code="$2"
  local message="$3"

  CONTRACT_STATE="invalid"
  append_status_note "malformed_plan_headers"
  append_reason_code "$reason_code"
  append_diagnostic "$reason_code" "error" "$artifact" "$message" "Update the plan through the planning workflow."
}

record_invalid_contract_result() {
  local artifact="$1"
  local error_class="$2"
  local message="$3"
  local reason_code

  reason_code="$(camel_to_snake "$error_class")"
  [ -n "$reason_code" ] || reason_code="invalid_plan_contract"
  CONTRACT_STATE="invalid"
  append_status_note "$reason_code"
  append_reason_code "$reason_code"
  append_diagnostic "$reason_code" "error" "$artifact" "$message" "Fix the approved plan contract before execution preflight."
}

record_valid_contract_result() {
  CONTRACT_STATE="valid"
}

trim_leading_json_space() {
  local value="$1"
  while [[ -n "$value" ]]; do
    case "${value:0:1}" in
      ' '|$'\n'|$'\r'|$'\t') value="${value:1}" ;;
      *) break ;;
    esac
  done
  printf '%s' "$value"
}

trim_trailing_json_space() {
  local value="$1"
  while [[ -n "$value" ]]; do
    case "${value: -1}" in
      ' '|$'\n'|$'\r'|$'\t') value="${value::-1}" ;;
      *) break ;;
    esac
  done
  printf '%s' "$value"
}

json_consume_value() {
  local text
  local first=""
  local open=""
  local close=""
  local length=0
  local i=0
  local ch=""
  local value=""
  local depth=0
  local in_string=0
  local escape=0

  text="$(trim_leading_json_space "$1")"
  JSON_CONSUMED_VALUE=""
  [[ -n "$text" ]] || return 1

  first="${text:0:1}"
  case "$first" in
    '"')
      value='"'
      length="${#text}"
      i=1
      while (( i < length )); do
        ch="${text:i:1}"
        value+="$ch"
        if (( escape )); then
          escape=0
        else
          case "$ch" in
            '\\') escape=1 ;;
            '"') JSON_CONSUMED_VALUE="$value"; return 0 ;;
          esac
        fi
        i=$((i + 1))
      done
      return 1
      ;;
    '['|'{')
      open="$first"
      if [[ "$open" == "[" ]]; then
        close="]"
      else
        close="}"
      fi
      value="$first"
      depth=1
      in_string=0
      escape=0
      length="${#text}"
      i=1
      while (( i < length )); do
        ch="${text:i:1}"
        value+="$ch"
        if (( in_string )); then
          if (( escape )); then
            escape=0
          else
            case "$ch" in
              '\\') escape=1 ;;
              '"') in_string=0 ;;
            esac
          fi
        else
          case "$ch" in
            '"') in_string=1 ;;
            "$open") depth=$((depth + 1)) ;;
            "$close")
              depth=$((depth - 1))
              if (( depth == 0 )); then
                JSON_CONSUMED_VALUE="$value"
                return 0
              fi
              ;;
          esac
        fi
        i=$((i + 1))
      done
      return 1
      ;;
    *)
      length="${#text}"
      while (( i < length )); do
        ch="${text:i:1}"
        case "$ch" in
          ','|'}'|']') break ;;
          *) value+="$ch" ;;
        esac
        i=$((i + 1))
      done
      value="$(trim_trailing_json_space "$value")"
      [[ -n "$value" ]] || return 1
      JSON_CONSUMED_VALUE="$value"
      return 0
      ;;
  esac
}

json_top_level_field_value() {
  local json="$1"
  local key="$2"
  local search="\"$key\":"
  local remainder=""

  JSON_FIELD_VALUE=""
  remainder="${json#*$search}"
  [[ "$remainder" != "$json" ]] || return 1
  json_consume_value "$remainder" || return 1
  JSON_FIELD_VALUE="$JSON_CONSUMED_VALUE"
  return 0
}

json_array_elements() {
  local array_json="$1"
  local remainder=""

  JSON_ARRAY_COUNT=0
  JSON_ARRAY_VALUES=()
  [[ "${array_json:0:1}" == "[" && "${array_json: -1}" == "]" ]] || return 1

  remainder="${array_json:1:${#array_json}-2}"
  remainder="$(trim_leading_json_space "$remainder")"
  while [[ -n "$remainder" ]]; do
    json_consume_value "$remainder" || return 1
    JSON_ARRAY_VALUES[$JSON_ARRAY_COUNT]="$JSON_CONSUMED_VALUE"
    JSON_ARRAY_COUNT=$((JSON_ARRAY_COUNT + 1))
    remainder="${remainder:${#JSON_CONSUMED_VALUE}}"
    remainder="$(trim_leading_json_space "$remainder")"
    if [[ "${remainder:0:1}" == "," ]]; then
      remainder="${remainder:1}"
      remainder="$(trim_leading_json_space "$remainder")"
      continue
    fi
    break
  done
  return 0
}

json_unquote_simple_string() {
  local value="$1"

  [[ "${value:0:1}" == '"' && "${value: -1}" == '"' ]] || return 1
  JSON_UNQUOTED_STRING="${value:1:${#value}-2}"
  JSON_UNQUOTED_STRING="${JSON_UNQUOTED_STRING//\\\"/\"}"
  JSON_UNQUOTED_STRING="${JSON_UNQUOTED_STRING//\\\\/\\}"
  JSON_UNQUOTED_STRING="${JSON_UNQUOTED_STRING//\\n/$'\n'}"
  JSON_UNQUOTED_STRING="${JSON_UNQUOTED_STRING//\\r/$'\r'}"
  JSON_UNQUOTED_STRING="${JSON_UNQUOTED_STRING//\\t/$'\t'}"
  return 0
}

record_packet_buildability_failure() {
  CONTRACT_STATE="invalid"
  append_status_note "packet_buildability_failure"
  append_reason_code "packet_buildability_failure"
  append_diagnostic \
    "packet_buildability_failure" \
    "error" \
    "$1" \
    "Execution handoff requires every task packet to be buildable for the approved plan revision." \
    "Fix the approved plan contract until packet_buildable_tasks equals task_count."
}

import_contract_analysis_feedback() {
  local artifact="$1"
  local output="$2"
  local i=""

  json_top_level_field_value "$output" "contract_state" || return 1
  json_unquote_simple_string "$JSON_FIELD_VALUE" || return 1
  CONTRACT_STATE="$JSON_UNQUOTED_STRING"

  if json_top_level_field_value "$output" "task_count"; then
    CONTRACT_ANALYSIS_TASK_COUNT="$JSON_FIELD_VALUE"
  fi
  if json_top_level_field_value "$output" "packet_buildable_tasks"; then
    CONTRACT_ANALYSIS_PACKET_BUILDABLE_TASKS="$JSON_FIELD_VALUE"
  fi

  if json_top_level_field_value "$output" "reason_codes"; then
    json_array_elements "$JSON_FIELD_VALUE" || return 1
    for ((i=0; i<JSON_ARRAY_COUNT; i++)); do
      json_unquote_simple_string "${JSON_ARRAY_VALUES[$i]}" || return 1
      append_status_note "$JSON_UNQUOTED_STRING"
      append_reason_code "$JSON_UNQUOTED_STRING"
    done
  fi

  if json_top_level_field_value "$output" "diagnostics"; then
    json_array_elements "$JSON_FIELD_VALUE" || return 1
    for ((i=0; i<JSON_ARRAY_COUNT; i++)); do
      STATUS_DIAGNOSTICS+=("${JSON_ARRAY_VALUES[$i]}")
    done
  fi

  if [[ "$CONTRACT_STATE" == "valid" ]] &&
     [[ -n "$CONTRACT_ANALYSIS_TASK_COUNT" ]] &&
     [[ "$CONTRACT_ANALYSIS_PACKET_BUILDABLE_TASKS" != "$CONTRACT_ANALYSIS_TASK_COUNT" ]]; then
    record_packet_buildability_failure "$artifact"
  fi

  return 0
}

run_plan_contract_analysis() {
  local spec_path="$1"
  local plan_path="$2"
  local output
  local status=0

  CONTRACT_ANALYSIS_JSON=""
  CONTRACT_ANALYSIS_TASK_COUNT=""
  CONTRACT_ANALYSIS_PACKET_BUILDABLE_TASKS=""
  CONTRACT_ANALYSIS_ERROR_CLASS=""
  CONTRACT_ANALYSIS_MESSAGE=""

  output="$(
    cd "$REPO_ROOT" &&
      "$SCRIPT_DIR/superpowers-plan-contract" analyze-plan --spec "$spec_path" --plan "$plan_path" --format json
  )" || status=$?

  CONTRACT_ANALYSIS_JSON="$output"
  CONTRACT_ANALYSIS_ERROR_CLASS="$(json_field_string "$output" "error_class")"
  CONTRACT_ANALYSIS_MESSAGE="$(json_field_string "$output" "message")"

  if [ "$status" -ne 0 ]; then
    return 1
  fi

  import_contract_analysis_feedback "$plan_path" "$output" || return 1
  [[ "$CONTRACT_STATE" == "valid" ]]
}

resolve_preferred_spec() {
  local normalized abs local_rel first_any="" first_any_valid=0 valid_count=0

  SPEC_CANDIDATE_COUNT="$(count_candidates_in_dir "$REPO_ROOT/docs/superpowers/specs")"
  if [ "$SPEC_CANDIDATE_COUNT" -gt "$FALLBACK_LIMIT" ]; then
    SCAN_TRUNCATED="true"
  fi

  RESOLVED_SPEC_PATH=""

  if [ -n "$MANIFEST_SPEC_PATH" ]; then
    normalized="$(normalize_repo_relative_path "$MANIFEST_SPEC_PATH" 2>/dev/null || true)"
    if [ -n "$normalized" ]; then
      SPEC_FROM_MANIFEST=1
      MANIFEST_SPEC_PATH="$normalized"
      abs="$REPO_ROOT/$normalized"
      if [ -f "$abs" ]; then
        if parse_spec_headers "$abs"; then
          RESOLVED_SPEC_PATH="$normalized"
          SPEC_VALID=1
          return 0
        fi
        RESOLVED_SPEC_PATH="$normalized"
      else
        RESOLVED_SPEC_PATH="$normalized"
        SPEC_EXPECTED_MISSING=1
      fi
    else
      append_status_note "invalid_manifest_spec_path"
      MANIFEST_SPEC_PATH=""
    fi
  fi

  while IFS= read -r abs; do
    [ -n "$abs" ] || continue
    if ! rel_from_root "$abs" >/dev/null 2>&1; then
      continue
    fi
    local_rel="$(rel_from_root "$abs")"
    if [ -n "$MANIFEST_SPEC_PATH" ] && [ "$local_rel" = "$MANIFEST_SPEC_PATH" ]; then
      continue
    fi
    if [ -z "$first_any" ]; then
      first_any="$local_rel"
      if parse_spec_headers "$abs"; then
        first_any_valid=1
        valid_count=1
      fi
      continue
    fi
    if parse_spec_headers "$abs"; then
      valid_count=$((valid_count + 1))
    fi
  done < <(list_newest_candidates "$REPO_ROOT/docs/superpowers/specs")

  if [ -n "$first_any" ]; then
    RESOLVED_SPEC_PATH="$first_any"
    MANIFEST_SPEC_PATH="$first_any"
    if [ "$first_any_valid" -eq 1 ]; then
      parse_spec_headers "$REPO_ROOT/$first_any" || true
      SPEC_VALID=1
      if [ "$valid_count" -gt 1 ]; then
        SPEC_AMBIGUOUS=1
      fi
    fi
    return 0
  fi

  return 0
}

resolve_preferred_plan() {
  local normalized abs local_rel first_any="" first_any_valid=0 valid_count=0

  PLAN_CANDIDATE_COUNT="$(count_candidates_in_dir "$REPO_ROOT/docs/superpowers/plans")"
  if [ "$PLAN_CANDIDATE_COUNT" -gt "$FALLBACK_LIMIT" ]; then
    SCAN_TRUNCATED="true"
  fi

  RESOLVED_PLAN_PATH=""

  if [ -n "$MANIFEST_PLAN_PATH" ]; then
    normalized="$(normalize_repo_relative_path "$MANIFEST_PLAN_PATH" 2>/dev/null || true)"
    if [ -n "$normalized" ]; then
      PLAN_FROM_MANIFEST=1
      MANIFEST_PLAN_PATH="$normalized"
      abs="$REPO_ROOT/$normalized"
      if [ -f "$abs" ]; then
        if parse_plan_headers "$abs"; then
          RESOLVED_PLAN_PATH="$normalized"
          PLAN_VALID=1
          return 0
        fi
        RESOLVED_PLAN_PATH="$normalized"
      else
        RESOLVED_PLAN_PATH="$normalized"
        PLAN_EXPECTED_MISSING=1
      fi
    else
      append_status_note "invalid_manifest_plan_path"
      MANIFEST_PLAN_PATH=""
    fi
  fi

  while IFS= read -r abs; do
    [ -n "$abs" ] || continue
    if ! rel_from_root "$abs" >/dev/null 2>&1; then
      continue
    fi
    local_rel="$(rel_from_root "$abs")"
    if [ -n "$MANIFEST_PLAN_PATH" ] && [ "$local_rel" = "$MANIFEST_PLAN_PATH" ]; then
      continue
    fi
    if [ -z "$first_any" ]; then
      first_any="$local_rel"
      if parse_plan_headers "$abs"; then
        first_any_valid=1
        valid_count=1
      fi
      continue
    fi
    if parse_plan_headers "$abs"; then
      valid_count=$((valid_count + 1))
    fi
  done < <(list_newest_candidates "$REPO_ROOT/docs/superpowers/plans")

  if [ -n "$first_any" ]; then
    RESOLVED_PLAN_PATH="$first_any"
    MANIFEST_PLAN_PATH="$first_any"
    if [ "$first_any_valid" -eq 1 ]; then
      parse_plan_headers "$REPO_ROOT/$first_any" || true
      PLAN_VALID=1
      if [ "$valid_count" -gt 1 ]; then
        PLAN_AMBIGUOUS=1
      fi
    fi
    return 0
  fi

  return 0
}

derive_status() {
  local spec_abs="" plan_abs="" normalized_source=""
  reset_resolution_flags
  reset_status_diagnostics
  STATUS_CODE="needs_brainstorming"
  NEXT_SKILL="superpowers:brainstorming"

  resolve_preferred_spec
  resolve_preferred_plan

  if [ "$SPEC_AMBIGUOUS" -eq 1 ]; then
    STATUS_CODE="spec_draft"
    NEXT_SKILL="superpowers:plan-ceo-review"
    append_status_note "fallback_ambiguity_spec"
    append_reason_code "ambiguous_spec_candidates"
    append_diagnostic "ambiguous_spec_candidates" "error" "$RESOLVED_SPEC_PATH" "More than one current spec candidate matches the fallback scan window." "Reduce spec ambiguity before proceeding."
    return 0
  fi

  if [ -n "$RESOLVED_SPEC_PATH" ]; then
    spec_abs="$REPO_ROOT/$RESOLVED_SPEC_PATH"
  fi

  if [ -z "$spec_abs" ] || [ ! -f "$spec_abs" ]; then
    if [ "$SPEC_EXPECTED_MISSING" -eq 1 ]; then
      append_status_note "missing_expected_spec"
    fi
    STATUS_CODE="needs_brainstorming"
    NEXT_SKILL="superpowers:brainstorming"
    return 0
  fi

  if [ "$SPEC_VALID" -ne 1 ] && ! parse_spec_headers "$spec_abs"; then
    STATUS_CODE="spec_draft"
    NEXT_SKILL="superpowers:plan-ceo-review"
    append_status_note "malformed_spec_headers"
    append_reason_code "malformed_spec_headers"
    append_diagnostic "malformed_spec_headers" "error" "$RESOLVED_SPEC_PATH" "The current spec headers are missing or malformed." "Update the spec through the review workflow."
    return 0
  fi

  if [ "$SPEC_VALID" -ne 1 ]; then
    SPEC_VALID=1
  fi

  if [ "$spec_state" = "Draft" ]; then
    STATUS_CODE="spec_draft"
    NEXT_SKILL="superpowers:plan-ceo-review"
    return 0
  fi

  if [ "$PLAN_AMBIGUOUS" -eq 1 ]; then
    STATUS_CODE="spec_approved_needs_plan"
    NEXT_SKILL="superpowers:writing-plans"
    append_status_note "fallback_ambiguity_plan"
    append_reason_code "ambiguous_plan_candidates"
    append_diagnostic "ambiguous_plan_candidates" "error" "$RESOLVED_PLAN_PATH" "More than one current plan candidate matches the fallback scan window." "Reduce plan ambiguity before proceeding."
    return 0
  fi

  if [ -n "$RESOLVED_PLAN_PATH" ]; then
    plan_abs="$REPO_ROOT/$RESOLVED_PLAN_PATH"
  fi

  if [ -z "$plan_abs" ] || [ ! -f "$plan_abs" ]; then
    if [ "$PLAN_EXPECTED_MISSING" -eq 1 ]; then
      append_status_note "missing_expected_plan"
    fi
    STATUS_CODE="spec_approved_needs_plan"
    NEXT_SKILL="superpowers:writing-plans"
    return 0
  fi

  if [ "$PLAN_VALID" -ne 1 ] && ! parse_plan_headers "$plan_abs"; then
    STATUS_CODE="plan_draft"
    NEXT_SKILL="superpowers:plan-eng-review"
    record_contract_header_failure "$RESOLVED_PLAN_PATH" "${PLAN_STRUCTURE_HEADER_REASON_CODE:-malformed_plan_headers}" "${PLAN_STRUCTURE_HEADER_ERROR_MESSAGE:-Plan headers are malformed.}"
    return 0
  fi

  if [ "$PLAN_VALID" -ne 1 ]; then
    PLAN_VALID=1
  fi

  if [ "$plan_state" = "Draft" ]; then
    STATUS_CODE="plan_draft"
    NEXT_SKILL="superpowers:plan-eng-review"
    append_status_note "plan_draft"
    append_reason_code "plan_draft"
    return 0
  fi

  normalized_source="$(normalize_repo_relative_path "$plan_source_spec" 2>/dev/null || true)"
  if [ -z "$normalized_source" ] || [ "$normalized_source" != "$RESOLVED_SPEC_PATH" ] || [ "$plan_source_revision" != "$spec_revision" ]; then
    STATUS_CODE="stale_plan"
    NEXT_SKILL="superpowers:writing-plans"
    CONTRACT_STATE="stale"
    append_status_note "stale_plan"
    append_reason_code "stale_spec_plan_linkage"
    append_diagnostic "stale_spec_plan_linkage" "error" "$RESOLVED_PLAN_PATH" "The approved plan does not match the latest approved spec path and revision." "Rewrite the plan from the latest approved spec."
    return 0
  fi

  if ! run_plan_contract_analysis "$RESOLVED_SPEC_PATH" "$RESOLVED_PLAN_PATH"; then
    STATUS_CODE="plan_draft"
    NEXT_SKILL="superpowers:plan-eng-review"
    if [[ "$CONTRACT_STATE" != "invalid" ]]; then
      record_invalid_contract_result "$RESOLVED_PLAN_PATH" "${CONTRACT_ANALYSIS_ERROR_CLASS:-InvalidPlanContract}" "${CONTRACT_ANALYSIS_MESSAGE:-Plan contract analysis failed.}"
    fi
    return 0
  fi

  record_valid_contract_result

  STATUS_CODE="implementation_ready"
  NEXT_SKILL=""
  append_status_note "implementation_ready"
  append_reason_code "implementation_ready"
  return 0
}

load_manifest_or_recover() {
  local rc=0
  local candidate matched="" matched_count=0 inspected=0 candidate_root candidate_branch
  reset_manifest_diagnostics
  if read_manifest; then
    if [ -n "$MANIFEST_REPO_ROOT" ] && [ "$MANIFEST_REPO_ROOT" != "$REPO_ROOT" ]; then
      MANIFEST_IDENTITY_MISMATCH=1
      MANIFEST_IDENTITY_REASON="repo_root_mismatch"
      printf 'warning: workflow manifest repo_root mismatch; rebuilding from current repo context\n' >&2
    elif [ -n "$MANIFEST_BRANCH" ] && [ "$MANIFEST_BRANCH" != "$BRANCH" ]; then
      MANIFEST_IDENTITY_MISMATCH=1
      MANIFEST_IDENTITY_REASON="branch_mismatch"
      printf 'warning: workflow manifest branch mismatch; rebuilding from current repo context\n' >&2
    fi
    return 0
  fi
  rc=$?
  if [ "$rc" -eq 2 ] || [ "$MANIFEST_CORRUPT" -eq 1 ]; then
    backup_corrupt_manifest
    MANIFEST_SPEC_PATH=""
    MANIFEST_PLAN_PATH=""
    return 2
  fi

  # Recovery across prior slug paths only applies to repos with stable remote-based
  # identities. Throwaway local repos derive their slug from the checkout path, so
  # scanning sibling project manifests adds cost without a viable recovery target.
  if [ -z "$REMOTE_URL" ]; then
    return 1
  fi

  shopt -s nullglob
  for candidate in "$STATE_DIR"/projects/*/"${USER_NAME}-${SAFE_BRANCH}-workflow-state.json"; do
    [ "$candidate" = "$MANIFEST_PATH" ] && continue
    inspected=$((inspected + 1))
    if [ "$inspected" -gt "$RECOVERY_CANDIDATE_LIMIT" ]; then
      break
    fi
    if read_manifest_file "$candidate"; then
      candidate_root="$MANIFEST_REPO_ROOT"
      candidate_branch="$MANIFEST_BRANCH"
      if [ "$candidate_root" = "$REPO_ROOT" ] && [ "$candidate_branch" = "$BRANCH" ]; then
        matched="$candidate"
        matched_count=$((matched_count + 1))
        if [ "$matched_count" -gt 1 ]; then
          break
        fi
      fi
    fi
  done
  shopt -u nullglob

  if [ "$matched_count" -gt 1 ]; then
    MANIFEST_RECOVERY_AMBIGUOUS=1
    reset_manifest_fields
    printf 'warning: multiple prior workflow manifests matched this repo identity; routing conservatively\n' >&2
    return 1
  fi

  if [ "$matched_count" -eq 1 ] && read_manifest_file "$matched"; then
    MANIFEST_RECOVERED=1
    printf 'warning: recovered workflow manifest from previous repo slug %s\n' "$matched" >&2
    return 0
  fi

  reset_manifest_fields
  return 1
}

load_manifest_read_only() {
  local rc=0
  local current_manifest_corrupt=0
  local candidate matched="" matched_count=0 inspected=0 candidate_root candidate_branch

  reset_manifest_diagnostics
  MANIFEST_CORRUPT=0

  if read_manifest; then
    if [ -n "$MANIFEST_REPO_ROOT" ] && [ "$MANIFEST_REPO_ROOT" != "$REPO_ROOT" ]; then
      MANIFEST_IDENTITY_MISMATCH=1
      MANIFEST_IDENTITY_REASON="repo_root_mismatch"
    elif [ -n "$MANIFEST_BRANCH" ] && [ "$MANIFEST_BRANCH" != "$BRANCH" ]; then
      MANIFEST_IDENTITY_MISMATCH=1
      MANIFEST_IDENTITY_REASON="branch_mismatch"
    fi
    return 0
  fi
  rc=$?
  if [ "$rc" -eq 2 ] || [ "$MANIFEST_CORRUPT" -eq 1 ]; then
    current_manifest_corrupt=1
    MANIFEST_SPEC_PATH=""
    MANIFEST_PLAN_PATH=""
  fi

  if [ -z "$REMOTE_URL" ]; then
    reset_manifest_fields
    MANIFEST_CORRUPT="$current_manifest_corrupt"
    return 1
  fi

  shopt -s nullglob
  for candidate in "$STATE_DIR"/projects/*/"${USER_NAME}-${SAFE_BRANCH}-workflow-state.json"; do
    [ "$candidate" = "$MANIFEST_PATH" ] && continue
    inspected=$((inspected + 1))
    if [ "$inspected" -gt "$RECOVERY_CANDIDATE_LIMIT" ]; then
      break
    fi
    if read_manifest_file "$candidate"; then
      candidate_root="$MANIFEST_REPO_ROOT"
      candidate_branch="$MANIFEST_BRANCH"
      if [ "$candidate_root" = "$REPO_ROOT" ] && [ "$candidate_branch" = "$BRANCH" ]; then
        matched="$candidate"
        matched_count=$((matched_count + 1))
        if [ "$matched_count" -gt 1 ]; then
          break
        fi
      fi
    fi
  done
  shopt -u nullglob

  if [ "$matched_count" -gt 1 ]; then
    MANIFEST_RECOVERY_AMBIGUOUS=1
    reset_manifest_fields
    MANIFEST_CORRUPT="$current_manifest_corrupt"
    return 1
  fi

  if [ "$matched_count" -eq 1 ] && read_manifest_file "$matched"; then
    MANIFEST_RECOVERED=1
    MANIFEST_CORRUPT="$current_manifest_corrupt"
    return 0
  fi

  reset_manifest_fields
  MANIFEST_CORRUPT="$current_manifest_corrupt"
  return 1
}

validate_repo_relative_path() {
  local input="$1"
  local normalized
  normalized="$(normalize_repo_relative_path "$input" 2>/dev/null || true)"
  if [ -z "$normalized" ]; then
    printf 'Invalid artifact path: %s\n' "$input" >&2
    return 1
  fi
  case "$REPO_ROOT/$normalized" in
    "$REPO_ROOT"/*) ;;
    *)
      printf 'Invalid artifact path: %s\n' "$input" >&2
      return 1
      ;;
  esac
  printf '%s\n' "$normalized"
}

manifest_paths_for_write() {
  local write_spec="$MANIFEST_SPEC_PATH"
  local write_plan="$MANIFEST_PLAN_PATH"

  if [ -z "$write_spec" ] && [ "$SPEC_AMBIGUOUS" -eq 0 ]; then
    write_spec="$RESOLVED_SPEC_PATH"
  fi
  if [ -z "$write_plan" ] && [ "$PLAN_AMBIGUOUS" -eq 0 ]; then
    write_plan="$RESOLVED_PLAN_PATH"
  fi

  printf '%s\n%s\n' "$write_spec" "$write_plan"
}

split_manifest_paths() {
  local payload="$1"

  SPLIT_MANIFEST_SPEC="${payload%%$'\n'*}"
  if [[ "$payload" == *$'\n'* ]]; then
    SPLIT_MANIFEST_PLAN="${payload#*$'\n'}"
  else
    SPLIT_MANIFEST_PLAN=""
  fi
}

write_and_emit_result() {
  local spec_path="$1"
  local plan_path="$2"
  local output_mode="${3:-json}"
  local payload

  payload="$(manifest_payload "$spec_path" "$plan_path" "$STATUS_CODE" "$NEXT_SKILL" "$STATUS_NOTE")"
  if ! write_manifest_with_retry "$payload"; then
    STATUS_CODE="needs_brainstorming"
    NEXT_SKILL="superpowers:brainstorming"
    STATUS_NOTE="manifest_write_conflict"
    if [ "$output_mode" = "summary" ]; then
      emit_summary "$STATUS_CODE" "$NEXT_SKILL" "$spec_path" "$plan_path" "$STATUS_NOTE"
    else
      emit_json "$STATUS_CODE" "$NEXT_SKILL" "$spec_path" "$plan_path" "$STATUS_NOTE"
    fi
    return 0
  fi

  if [ "$output_mode" = "summary" ]; then
    emit_summary "$STATUS_CODE" "$NEXT_SKILL" "$spec_path" "$plan_path" "$STATUS_NOTE"
  else
    emit_json "$STATUS_CODE" "$NEXT_SKILL" "$spec_path" "$plan_path" "$STATUS_NOTE"
  fi
  return 0
}

apply_resolution_diagnostics() {
  local mode="${1:-mutating}"
  local corrupted="${2:-0}"

  if [ "$mode" = "mutating" ] && [ "$corrupted" -eq 1 ]; then
    STATUS_CODE="needs_brainstorming"
    NEXT_SKILL="superpowers:brainstorming"
    STATUS_NOTE="corrupt_manifest_recovered"
    append_reason_code "corrupt_manifest_recovered"
  elif [ "$mode" = "read_only" ] && [ "$MANIFEST_CORRUPT" -eq 1 ]; then
    append_status_note "corrupt_manifest_present"
    append_reason_code "corrupt_manifest_present"
  fi

  if [ "$MANIFEST_IDENTITY_MISMATCH" -eq 1 ]; then
    append_status_note "$MANIFEST_IDENTITY_REASON"
    append_reason_code "$MANIFEST_IDENTITY_REASON"
  fi
  if [ "$MANIFEST_RECOVERED" -eq 1 ]; then
    append_status_note "repo_slug_recovered"
    append_reason_code "repo_slug_recovered"
  fi
  if [ "$MANIFEST_RECOVERY_AMBIGUOUS" -eq 1 ]; then
    append_status_note "repo_slug_recovery_ambiguous"
    append_reason_code "repo_slug_recovery_ambiguous"
  fi
}

cmd_status() {
  local refresh=0 summary=0 arg corrupted=0
  local persisted_paths persisted_spec="" persisted_plan=""

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --refresh) refresh=1 ;;
      --summary) summary=1 ;;
      *)
        printf 'Unknown status option: %s\n' "$arg" >&2
        usage
        return 1
        ;;
    esac
    shift
  done

  ensure_manifest_dir

  load_manifest_or_recover >/dev/null || true
  if [ "$MANIFEST_CORRUPT" -eq 1 ]; then
    corrupted=1
  fi

  if [ "$refresh" -eq 0 ] && [ "$MANIFEST_VALID" -eq 1 ] && [ "$corrupted" -eq 0 ] && [ "$MANIFEST_RECOVERED" -eq 0 ] && [ "$MANIFEST_IDENTITY_MISMATCH" -eq 0 ] && [ "$MANIFEST_RECOVERY_AMBIGUOUS" -eq 0 ]; then
    if [ "$summary" -eq 1 ]; then
      emit_summary \
        "${MANIFEST_STATUS:-needs_brainstorming}" \
        "${MANIFEST_NEXT_SKILL:-}" \
        "$MANIFEST_SPEC_PATH" \
        "$MANIFEST_PLAN_PATH" \
        "$MANIFEST_REASON"
    else
      emit_json \
        "${MANIFEST_STATUS:-needs_brainstorming}" \
        "${MANIFEST_NEXT_SKILL:-}" \
        "$MANIFEST_SPEC_PATH" \
        "$MANIFEST_PLAN_PATH" \
        "$MANIFEST_REASON"
    fi
    return 0
  fi

  derive_status
  apply_resolution_diagnostics mutating "$corrupted"

  persisted_paths="$(manifest_paths_for_write)"
  split_manifest_paths "$persisted_paths"
  persisted_spec="$SPLIT_MANIFEST_SPEC"
  persisted_plan="$SPLIT_MANIFEST_PLAN"

  if [ "$summary" -eq 1 ]; then
    write_and_emit_result "$persisted_spec" "$persisted_plan" summary
  else
    write_and_emit_result "$persisted_spec" "$persisted_plan" json
  fi
}

cmd_resolve() {
  local arg debug=0

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --debug) debug=1 ;;
      *)
        emit_resolve_failure "InvalidCommandInput" "Unknown resolve option: $arg"
        return 1
        ;;
    esac
    shift
  done

  case "${SUPERPOWERS_WORKFLOW_RESOLVE_TEST_FAILPOINT:-}" in
    runtime_failure)
      emit_resolve_failure "ResolverRuntimeFailure" "Injected read-only resolver failpoint triggered."
      return 1
      ;;
    invalid_contract)
      emit_resolve_failure "ResolverContractViolation" "Injected invalid resolve-contract failpoint triggered."
      return 1
      ;;
  esac

  if [ "${SUPERPOWERS_WORKFLOW_STATUS_TEST_FAILPOINT:-}" = "resolve_runtime_failure" ]; then
    emit_resolve_failure "ResolverRuntimeFailure" "Injected read-only resolver failpoint triggered."
    return 1
  fi

  if [ "$REPO_CONTEXT_AVAILABLE" -ne 1 ]; then
    emit_resolve_failure "RepoContextUnavailable" "Read-only workflow resolution requires a git repo."
    return 1
  fi

  load_manifest_read_only >/dev/null || true
  derive_status
  apply_resolution_diagnostics read_only 0

  if [ "$debug" -eq 1 ]; then
    :
  fi

  emit_resolve_json "$STATUS_CODE" "$NEXT_SKILL" "$RESOLVED_SPEC_PATH" "$RESOLVED_PLAN_PATH" "$STATUS_NOTE" "$MANIFEST_SOURCE_PATH"
}

cmd_expect() {
  local artifact="" path="" arg normalized
  local persisted_paths persisted_spec="" persisted_plan=""

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --artifact)
        artifact="${2:-}"
        shift
        ;;
      --path)
        path="${2:-}"
        shift
        ;;
      *)
        printf 'Unknown expect option: %s\n' "$arg" >&2
        usage
        return 1
        ;;
    esac
    shift
  done

  case "$artifact" in
    spec|plan) ;;
    *)
      printf 'expect requires --artifact {spec|plan}\n' >&2
      return 1
      ;;
  esac

  if [ -z "$path" ]; then
    printf 'expect requires --path <repo-relative-path>\n' >&2
    return 1
  fi

  ensure_manifest_dir
  load_manifest_or_recover >/dev/null || true

  normalized="$(validate_repo_relative_path "$path")" || return 1
  if [ "$artifact" = "spec" ]; then
    MANIFEST_SPEC_PATH="$normalized"
  else
    MANIFEST_PLAN_PATH="$normalized"
  fi

  derive_status
  append_status_note "expect_set"

  persisted_paths="$(manifest_paths_for_write)"
  split_manifest_paths "$persisted_paths"
  persisted_spec="$SPLIT_MANIFEST_SPEC"
  persisted_plan="$SPLIT_MANIFEST_PLAN"

  write_and_emit_result "$persisted_spec" "$persisted_plan"
}

cmd_sync() {
  local artifact="" path="" arg
  local normalized target_path persisted_paths persisted_spec="" persisted_plan=""
  local missing_artifact=0

  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --artifact)
        artifact="${2:-}"
        shift
        ;;
      --path)
        path="${2:-}"
        shift
        ;;
      *)
        printf 'Unknown sync option: %s\n' "$arg" >&2
        usage
        return 1
        ;;
    esac
    shift
  done

  case "$artifact" in
    spec|plan) ;;
    *)
      printf 'sync requires --artifact {spec|plan}\n' >&2
      return 1
      ;;
  esac

  ensure_manifest_dir
  load_manifest_or_recover >/dev/null || true

  if [ -n "$path" ]; then
    normalized="$(validate_repo_relative_path "$path")" || return 1
    target_path="$normalized"
  else
    if [ "$artifact" = "spec" ]; then
      target_path="$MANIFEST_SPEC_PATH"
    else
      target_path="$MANIFEST_PLAN_PATH"
    fi
  fi

  if [ -z "$target_path" ] || ! repo_path_exists "$target_path"; then
    missing_artifact=1
    if [ "$artifact" = "spec" ]; then
      MANIFEST_SPEC_PATH="$target_path"
    else
      MANIFEST_PLAN_PATH="$target_path"
    fi
  else
    if [ "$artifact" = "spec" ]; then
      MANIFEST_SPEC_PATH="$target_path"
    else
      MANIFEST_PLAN_PATH="$target_path"
    fi
  fi

  derive_status
  append_status_note "sync_${artifact}"

  if [ "$missing_artifact" -eq 1 ]; then
    append_status_note "missing_artifact"
    if [ "$artifact" = "spec" ]; then
      STATUS_CODE="needs_brainstorming"
      NEXT_SKILL="superpowers:brainstorming"
    fi
  fi

  persisted_paths="$(manifest_paths_for_write)"
  split_manifest_paths "$persisted_paths"
  persisted_spec="$SPLIT_MANIFEST_SPEC"
  persisted_plan="$SPLIT_MANIFEST_PLAN"

  write_and_emit_result "$persisted_spec" "$persisted_plan"
}

case "${1:-}" in
  status) shift; cmd_status "$@" ;;
  resolve) shift; cmd_resolve "$@" ;;
  expect) shift; cmd_expect "$@" ;;
  sync) shift; cmd_sync "$@" ;;
  *) usage; exit 1 ;;
esac
