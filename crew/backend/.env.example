# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL should be: http://localhost:3001/auth/callback (dev)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=your_random_32_char_secret

# Frontend URL (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Backend port
PORT=3001

# Path to .team/ data directory (relative to kanban/backend/)
TEAM_DIR=../../.team
