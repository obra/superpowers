# ── Required ──────────────────────────────────────────────────────────────────
# Your Ethereum wallet private key (hex, with or without 0x prefix)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Wallet type ───────────────────────────────────────────────────────────────
# 0 = EOA (MetaMask / hardware wallet) — you must set allowances manually once
# 1 = Magic/email wallet
# 2 = Gnosis Safe proxy
POLYMARKET_SIGNATURE_TYPE=0

# Only needed for signature_type=1 or 2
# POLYMARKET_FUNDER_ADDRESS=0x...

# ── Strategy (all optional — defaults shown) ──────────────────────────────────
MAX_ENTRY_PRICE=0.02          # Max price ($) to enter a position
POSITION_SIZE_USD=10.0        # Dollars to spend per position
MAX_POSITIONS=50              # Maximum simultaneous open positions
TOTAL_BUDGET_USD=500.0        # Hard cap on total capital deployed
TAKE_PROFIT_PRICE=0.90        # Sell when position reaches this price
MIN_ASK_LIQUIDITY=100.0       # Minimum shares on ask side before buying
MIN_DAYS_TO_RESOLUTION=1      # Skip markets resolving in < N days

# ── Timing ────────────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300     # Re-scan for new opportunities every 5 min
MONITOR_INTERVAL_SECONDS=60   # Check open positions every 1 min
