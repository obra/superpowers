{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/.codex/hooks/session-start.py",
            "statusMessage": "running superpowers session-start hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /absolute/path/to/.codex/hooks/stop.py",
            "statusMessage": "running superpowers stop hook"
          }
        ]
      }
    ]
  }
}
