{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalyzePlanReport",
  "type": "object",
  "properties": {
    "contract_state": {
      "type": "string"
    },
    "coverage_complete": {
      "type": "boolean"
    },
    "dependency_diagram_present": {
      "type": "boolean"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContractDiagnostic"
      }
    },
    "execution_strategy_present": {
      "type": "boolean"
    },
    "execution_topology_valid": {
      "type": "boolean"
    },
    "files_blocks_valid": {
      "type": "boolean"
    },
    "open_questions_resolved": {
      "type": "boolean"
    },
    "overlapping_write_scopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OverlappingWriteScope"
      }
    },
    "packet_buildable_tasks": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    },
    "parallel_lane_ownership_valid": {
      "type": "boolean"
    },
    "parallel_workspace_isolation_valid": {
      "type": "boolean"
    },
    "parallel_worktree_groups": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      }
    },
    "parallel_worktree_requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ParallelWorktreeRequirement"
      }
    },
    "plan_fidelity_receipt": {
      "$ref": "#/$defs/PlanFidelityGateReport"
    },
    "plan_fingerprint": {
      "type": "string"
    },
    "plan_path": {
      "type": "string"
    },
    "plan_revision": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "serial_hazards_resolved": {
      "type": "boolean"
    },
    "spec_fingerprint": {
      "type": "string"
    },
    "spec_path": {
      "type": "string"
    },
    "spec_revision": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "task_count": {
      "type": "integer",
      "format": "uint",
      "minimum": 0
    },
    "task_structure_valid": {
      "type": "boolean"
    }
  },
  "required": [
    "contract_state",
    "spec_path",
    "spec_revision",
    "spec_fingerprint",
    "plan_path",
    "plan_revision",
    "plan_fingerprint",
    "task_count",
    "packet_buildable_tasks",
    "coverage_complete",
    "open_questions_resolved",
    "task_structure_valid",
    "files_blocks_valid",
    "execution_strategy_present",
    "dependency_diagram_present",
    "execution_topology_valid",
    "serial_hazards_resolved",
    "parallel_lane_ownership_valid",
    "parallel_workspace_isolation_valid",
    "parallel_worktree_groups",
    "parallel_worktree_requirements",
    "reason_codes",
    "overlapping_write_scopes",
    "plan_fidelity_receipt",
    "diagnostics"
  ],
  "$defs": {
    "ContractDiagnostic": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ]
    },
    "OverlappingWriteScope": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint32",
            "minimum": 0
          }
        }
      },
      "required": [
        "path",
        "tasks"
      ]
    },
    "ParallelWorktreeRequirement": {
      "type": "object",
      "properties": {
        "declared_worktrees": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "required_worktrees": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint32",
            "minimum": 0
          }
        }
      },
      "required": [
        "tasks",
        "declared_worktrees",
        "required_worktrees"
      ]
    },
    "PlanFidelityGateReport": {
      "type": "object",
      "properties": {
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContractDiagnostic"
          }
        },
        "provenance_source": {
          "type": "string"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "receipt_path": {
          "type": "string"
        },
        "reviewer_stage": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "verified_execution_topology": {
          "type": "boolean"
        },
        "verified_requirement_index": {
          "type": "boolean"
        }
      },
      "required": [
        "state",
        "receipt_path",
        "reviewer_stage",
        "provenance_source",
        "verified_requirement_index",
        "verified_execution_topology",
        "reason_codes",
        "diagnostics"
      ]
    }
  }
}
