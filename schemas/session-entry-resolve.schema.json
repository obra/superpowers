{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SessionEntryResolveOutput",
  "type": "object",
  "properties": {
    "decision_path": {
      "type": "string"
    },
    "decision_source": {
      "$ref": "#/$defs/SessionDecisionSourceSchemaDoc"
    },
    "failure_class": {
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/SessionOutcomeSchemaDoc"
    },
    "persisted": {
      "type": "boolean"
    },
    "policy_source": {
      "type": "string"
    },
    "prompt": {
      "anyOf": [
        {
          "$ref": "#/$defs/SessionPrompt"
        },
        {
          "type": "null"
        }
      ]
    },
    "reason": {
      "type": "string"
    },
    "session_key": {
      "type": "string"
    }
  },
  "required": [
    "outcome",
    "decision_source",
    "session_key",
    "decision_path",
    "policy_source",
    "persisted",
    "failure_class",
    "reason"
  ],
  "$defs": {
    "SessionDecisionSourceSchemaDoc": {
      "type": "string",
      "enum": [
        "existing_enabled",
        "existing_bypassed",
        "missing",
        "malformed",
        "explicit_reentry",
        "explicit_reentry_unpersisted",
        "spawned_subagent_default",
        "spawned_subagent_opt_in",
        "spawned_subagent_opt_in_unpersisted"
      ]
    },
    "SessionOutcomeSchemaDoc": {
      "type": "string",
      "enum": [
        "enabled",
        "bypassed",
        "needs_user_choice"
      ]
    },
    "SessionPrompt": {
      "type": "object",
      "properties": {
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SessionPromptOption"
          }
        },
        "question": {
          "type": "string"
        },
        "recommended_option": {
          "type": "string"
        }
      },
      "required": [
        "question",
        "recommended_option",
        "options"
      ]
    },
    "SessionPromptOption": {
      "type": "object",
      "properties": {
        "decision": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "decision",
        "label"
      ]
    }
  }
}
